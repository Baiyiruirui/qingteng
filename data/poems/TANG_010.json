{
  "poem_id": "TANG_010",
  "title": "望岳",
  "author": "杜甫",
  "dynasty": "唐",
  "grade": "初中",
  "text_type": "五言律诗",
  "themes": [
    "登高望远",
    "壮志豪情",
    "热爱自然",
    "胸襟开阔"
  ],
  "imagery": [
    "泰山",
    "齐鲁",
    "云",
    "归鸟",
    "绝顶",
    "众山"
  ],
  "rhetoric": [
    "设问",
    "夸张",
    "对仗",
    "衬托",
    "拟人"
  ],
  "lines": [
    {
      "line_id": "TANG_010_L1",
      "content": "岱宗夫如何？",
      "imagery": [
        "泰山"
      ],
      "emotion": [
        "疑问",
        "仰慕",
        "向往"
      ],
      "translation": "雄伟的泰山啊，它究竟是怎样的呢？",
      "translation_keywords": [
        "岱宗",
        "如何"
      ],
      "explanation": "诗人以设问开篇，直接点出对泰山雄伟的疑问和无限向往，语气中充满敬仰之情，引发读者对泰山壮丽景象的期待。"
    },
    {
      "line_id": "TANG_010_L2",
      "content": "齐鲁青未了。",
      "imagery": [
        "泰山",
        "齐鲁大地",
        "青色"
      ],
      "emotion": [
        "壮阔",
        "辽远"
      ],
      "translation": "它的青翠山色，绵延整个齐鲁大地，望不到尽头。",
      "translation_keywords": [
        "齐鲁",
        "青",
        "未了"
      ],
      "explanation": "诗人从远处眺望泰山，其苍翠的轮廓与齐鲁大地连成一片，无边无际，极言泰山的高大广阔，气势磅礴，为全诗奠定雄浑基调。"
    },
    {
      "line_id": "TANG_010_L3",
      "content": "造化钟神秀，",
      "imagery": [
        "造化",
        "神秀"
      ],
      "emotion": [
        "赞叹",
        "神圣",
        "敬畏"
      ],
      "translation": "大自然把神奇和秀丽都集中在了泰山身上，",
      "translation_keywords": [
        "造化",
        "钟",
        "神秀"
      ],
      "explanation": "诗人进一步赞美泰山，认为它是天地造化的精华凝聚之地，集雄伟、秀丽、神奇于一身，赋予泰山以人格化的神圣色彩，表达了对大自然鬼斧神工的赞叹。"
    },
    {
      "line_id": "TANG_010_L4",
      "content": "阴阳割昏晓。",
      "imagery": [
        "泰山",
        "山阴",
        "山阳",
        "昏",
        "晓"
      ],
      "emotion": [
        "震撼",
        "雄伟",
        "神奇"
      ],
      "translation": "它的山南山北，竟能将白天和黑夜分隔开来。",
      "translation_keywords": [
        "阴阳",
        "割",
        "昏晓"
      ],
      "explanation": "运用夸张手法，形象地描绘了泰山的高大，山体庞大到可以分隔阴阳，使山南山北出现不同的光照和景象，进一步突出其超凡的雄伟和气势，令人惊叹。"
    },
    {
      "line_id": "TANG_010_L5",
      "content": "荡胸生曾云，",
      "imagery": [
        "胸襟",
        "云",
        "曾云"
      ],
      "emotion": [
        "豪迈",
        "开阔",
        "涤荡"
      ],
      "translation": "看到那层层叠叠的云彩从山中升起，我的胸中也随之荡漾开阔，豪情万丈；",
      "translation_keywords": [
        "荡胸",
        "生",
        "曾云"
      ],
      "explanation": "诗人写登临泰山时的感受。面对壮丽的云海，诗人胸襟开阔，情感激荡，将自然景物与内心感受融合，抒发了豪迈而超脱之情。"
    },
    {
      "line_id": "TANG_010_L6",
      "content": "决眦入归鸟。",
      "imagery": [
        "眼睛",
        "归鸟"
      ],
      "emotion": [
        "入神",
        "专注",
        "渺小"
      ],
      "translation": "眺望远方，直到眼眶都快裂开，才看到那归巢的飞鸟隐没在远山之中。",
      "translation_keywords": [
        "决眦",
        "入",
        "归鸟"
      ],
      "explanation": "诗人极力远眺，连眼角都快撑裂，才看到渺小的归鸟消失在天地间，这不仅反衬出泰山的广阔和高远，也表现了诗人沉醉于美景中的专注和物我两忘的境界。"
    },
    {
      "line_id": "TANG_010_L7",
      "content": "会当凌绝顶，",
      "imagery": [
        "绝顶"
      ],
      "emotion": [
        "壮志",
        "决心",
        "豪迈"
      ],
      "translation": "我定要登上泰山的最高峰，",
      "translation_keywords": [
        "会当",
        "凌",
        "绝顶"
      ],
      "explanation": "诗人立下宏愿，表达了征服自然的决心和豪迈的抱负。这里的“绝顶”不仅是泰山之巅，更是诗人心中人生理想的顶峰，是全诗情感的升华。"
    },
    {
      "line_id": "TANG_010_L8",
      "content": "一览众山小。",
      "imagery": [
        "众山"
      ],
      "emotion": [
        "雄心",
        "自信",
        "胸襟开阔",
        "俯瞰"
      ],
      "translation": "那时便能把所有山峦都踩在脚下，领略一览众山小的壮丽景象。",
      "translation_keywords": [
        "一览",
        "众山",
        "小"
      ],
      "explanation": "站在最高处俯瞰，所有山峰都显得矮小，这不仅是视觉上的感受，更是诗人由登高望远而产生的开阔胸襟和凌云壮志的体现，点明全诗主旨，展现了诗人积极向上、不畏艰难的远大抱负。"
    }
  ]
}