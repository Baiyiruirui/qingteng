  "lines": [
    {
      "line_id": "TANG_049_L1",
      "content": "孤山寺北贾亭西，水面初平云脚低。",
      "imagery": [
        "孤山寺",
        "贾亭",
        "水面",
        "云脚"
      ],
      "emotion": [
        "开阔",
        "平静",
        "远阔"
      ],
      "translation": "从孤山寺的北面、贾公亭的西面望去，湖水初涨，水面平坦，天空的云层低垂。",
      "translation_keywords": [
        "孤山寺北",
        "贾亭西",
        "水面",
        "初平",
        "云脚低"
      ],
      "explanation": "交代了游览的地点，描绘了钱塘湖春日的全景，湖面平静开阔，云彩低垂，渲染出一种宁静悠远的氛围。"
    },
    {
      "line_id": "TANG_049_L2",
      "content": "几处早莺争暖树，谁家新燕啄春泥。",
      "imagery": [
        "早莺",
        "暖树",
        "新燕",
        "春泥"
      ],
      "emotion": [
        "生机",
        "活泼",
        "欢快"
      ],
      "translation": "几只早春的黄莺正在争抢着栖息在向阳的暖树上，谁家的新燕在衔泥筑巢呢？",
      "translation_keywords": [
        "几处",
        "早莺",
        "争暖树",
        "谁家",
        "新燕",
        "啄春泥"
      ],
      "explanation": "选取早莺、新燕两个典型意象，通过它们的动态活动描绘了春天的勃勃生机和无限活力，充满了喜悦之情。"
    },
    {
      "line_id": "TANG_049_L3",
      "content": "乱花渐欲迷人眼，浅草才能没马蹄。",
      "imagery": [
        "乱花",
        "眼",
        "浅草",
        "马蹄"
      ],
      "emotion": [
        "陶醉",
        "新绿",
        "欣喜"
      ],
      "translation": "繁多的野花渐渐地开满山野，几乎要迷住人的眼睛；刚刚生长的浅草，也只能勉强没过马蹄。",
      "translation_keywords": [
        "乱花",
        "渐欲",
        "迷人眼",
        "浅草",
        "才能",
        "没马蹄"
      ],
      "explanation": "通过花草的生长状态，表现了春天由初到盛的特点。“迷人眼”写出花的繁盛和醉人，“没马蹄”写出草的浅嫩和铺展，展现春色迷人。"
    },
    {
      "line_id": "TANG_049_L4",
      "content": "最爱湖东行不足，绿杨阴里白沙堤。",
      "imagery": [
        "湖东",
        "绿杨",
        "白沙堤"
      ],
      "emotion": [
        "喜爱",
        "流连忘返",
        "惬意"
      ],
      "translation": "最喜爱的是湖东一带，在这绿杨成荫的白沙堤上，我怎么也走不够。",
      "translation_keywords": [
        "最爱",
        "湖东",
        "行不足",
        "绿杨阴里",
        "白沙堤"
      ],
      "explanation": "点明作者最喜爱钱塘湖东的景致，尤其是绿杨成荫的白沙堤，表达了诗人流连忘返、沉醉于美景之中的愉悦心情，深化了对钱塘湖春色的赞美。"
    }
  ]
