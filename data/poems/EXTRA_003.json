  "lines": [
    {
      "line_id": "EXTRA_003_L1",
      "content": "敕勒川",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "敕勒族人居住的大草原啊，就在那阴山脚下。",
      "translation_keywords": [
        "敕勒川",
        "阴山",
        "脚下"
      ],
      "explanation": "开头点出地点，用“敕勒川”和“阴山下”交代了草原的位置，让人感受到草原的辽阔和壮美。"
    },
    {
      "line_id": "EXTRA_003_L2",
      "content": "阴山下",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "敕勒族人居住的大草原啊，就在那阴山脚下。",
      "translation_keywords": [
        "敕勒川",
        "阴山",
        "脚下"
      ],
      "explanation": "开头点出地点，用“敕勒川”和“阴山下”交代了草原的位置，让人感受到草原的辽阔和壮美。"
    },
    {
      "line_id": "EXTRA_003_L3",
      "content": "天似穹庐",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "天空像游牧民族住的圆顶帐篷一样，笼罩着四面的大地。",
      "translation_keywords": [
        "天",
        "穹庐",
        "笼盖"
      ],
      "explanation": "运用比喻，把天空比作“穹庐”（帐篷），生动地写出了草原上天地相接、浑然一体的感觉，也体现了游牧民族的生活特色。"
    },
    {
      "line_id": "EXTRA_003_L4",
      "content": "笼盖四野",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "天空像游牧民族住的圆顶帐篷一样，笼罩着四面的大地。",
      "translation_keywords": [
        "天",
        "穹庐",
        "笼盖"
      ],
      "explanation": "运用比喻，把天空比作“穹庐”（帐篷），生动地写出了草原上天地相接、浑然一体的感觉，也体现了游牧民族的生活特色。"
    },
    {
      "line_id": "EXTRA_003_L5",
      "content": "天苍苍",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "天空蓝蓝的，草原一望无际。",
      "translation_keywords": [
        "苍苍",
        "茫茫",
        "辽阔"
      ],
      "explanation": "“苍苍”形容天空的深蓝，“茫茫”形容草原的广阔，两个叠词增强了画面感，让人仿佛看到无边无际的天地。"
    },
    {
      "line_id": "EXTRA_003_L6",
      "content": "野茫茫",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "天空蓝蓝的，草原一望无际。",
      "translation_keywords": [
        "苍苍",
        "茫茫",
        "辽阔"
      ],
      "explanation": "“苍苍”形容天空的深蓝，“茫茫”形容草原的广阔，两个叠词增强了画面感，让人仿佛看到无边无际的天地。"
    },
    {
      "line_id": "EXTRA_003_L7",
      "content": "风吹草低见牛羊",
      "imagery": [
        "天空",
        "草原",
        "牛羊"
      ],
      "emotion": [
        "草原",
        "自然"
      ],
      "translation": "一阵风吹来，草低下了头，露出了藏在草丛里的牛羊。",
      "translation_keywords": [
        "风吹",
        "草低",
        "见牛羊"
      ],
      "explanation": "动态描写，用“风吹草低”的细节，让画面活了起来，展现了草原的生机和富饶，也表达了牧民对生活的满足。"
    }
  ]
