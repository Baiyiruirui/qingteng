{
  "poem_id": "EXTRA_017",
  "title": "乌衣巷",
  "author": "刘禹锡",
  "dynasty": "唐",
  "grade": "初中",
  "text_type": "绝句",
  "themes": [
    "怀古",
    "兴亡"
  ],
  "imagery": [
    "野草",
    "夕阳",
    "飞燕"
  ],
  "rhetoric": [
    "对比",
    "借景抒情",
    "以小见大"
  ],
  "lines": [
    {
      "line_id": "EXTRA_017_L1",
      "content": "朱雀桥边野草花",
      "imagery": [
        "野草",
        "夕阳",
        "飞燕"
      ],
      "emotion": [
        "怀古",
        "兴亡"
      ],
      "translation": "朱雀桥边长满了野草和野花。",
      "translation_keywords": [
        "朱雀桥",
        "边",
        "野草",
        "花"
      ],
      "explanation": "开篇写朱雀桥边的荒凉景象。朱雀桥曾是繁华之地，如今却野草丛生、野花乱开，暗示昔日的热闹已经消失，为全诗营造了衰败的氛围。"
    },
    {
      "line_id": "EXTRA_017_L2",
      "content": "乌衣巷口夕阳斜",
      "imagery": [
        "野草",
        "夕阳",
        "飞燕"
      ],
      "emotion": [
        "怀古",
        "兴亡"
      ],
      "translation": "乌衣巷口只有夕阳斜照着。",
      "translation_keywords": [
        "乌衣巷",
        "口",
        "夕阳",
        "斜"
      ],
      "explanation": "继续写乌衣巷的冷落。夕阳西下，光线斜照，更显巷子空寂。夕阳常象征衰落，这里借夕阳渲染出昔盛今衰的伤感。"
    },
    {
      "line_id": "EXTRA_017_L3",
      "content": "旧时王谢堂前燕",
      "imagery": [
        "野草",
        "夕阳",
        "飞燕"
      ],
      "emotion": [
        "怀古",
        "兴亡"
      ],
      "translation": "从前在王导、谢安等贵族家的燕子。",
      "translation_keywords": [
        "旧时",
        "王谢",
        "堂前",
        "燕"
      ],
      "explanation": "诗人由眼前景物联想到历史。王谢是东晋豪门，他们的宅第曾显赫一时，如今只剩燕子还在。燕子是候鸟，年年归来，但主人已换，暗示世事无常。"
    },
    {
      "line_id": "EXTRA_017_L4",
      "content": "飞入寻常百姓家",
      "imagery": [
        "野草",
        "夕阳",
        "飞燕"
      ],
      "emotion": [
        "怀古",
        "兴亡"
      ],
      "translation": "如今飞进了普通老百姓的家里。",
      "translation_keywords": [
        "飞入",
        "寻常",
        "百姓",
        "家"
      ],
      "explanation": "最后一句点明主题：燕子还是那些燕子，但筑巢的地方已从豪门变为平民家。通过燕子的视角，巧妙对比了昔日的繁华与今日的平凡，表达了对历史变迁的深沉感慨。"
    }
  ]
}
