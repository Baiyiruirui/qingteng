    "东流水"
  ],
  "rhetoric": [
    "设问",
    "比喻",
    "动静结合",
    "场景描写"
  ],
  "lines": [
    {
      "line_id": "TANG_090_L1",
      "content": "风吹柳花满店香，吴姬压酒唤客尝。",
      "imagery": [
        "风",
        "柳花",
        "酒",
        "吴姬"
      ],
      "emotion": [
        "欢快",
        "留恋"
      ],
      "translation": "风吹着柳絮，芬芳的香气弥漫了整个酒肆，吴地少女正在压酒，招呼客人品尝。",
      "translation_keywords": [
        "风吹",
        "柳花",
        "满店香",
        "吴姬",
        "压酒",
        "唤客尝"
      ],
      "explanation": "描绘了酒肆里热闹、芬芳的景象，烘托出离别前热烈的气氛。"
    },
    {
      "line_id": "TANG_090_L2",
      "content": "金陵子弟来相送，欲行不行各尽觞。",
      "imagery": [
        "觞"
      ],
      "emotion": [
        "惜别",
        "豪迈"
      ],
      "translation": "金陵的年轻朋友们都来为我送行，要走的和留下的人都把杯中酒一饮而尽。",
      "translation_keywords": [
        "金陵子弟",
        "相送",
        "欲行",
        "不行",
        "尽觞"
      ],
      "explanation": "描绘了送别者与被送别者开怀畅饮的豪迈情景，表达了深厚的友情和惜别之情。"
    },
    {
      "line_id": "TANG_090_L3",
      "content": "请君试问东流水，别意与之谁短长？",
      "imagery": [
        "东流水"
      ],
      "emotion": [
        "深情",
        "夸张"
      ],
      "translation": "请你们试试去问那东流的江水，我的离愁别绪和它相比，哪个更长更深呢？",
      "translation_keywords": [
        "请君",
        "东流水",
        "别意",
        "短长"
      ],
      "explanation": "用东流的江水比喻深沉的离愁别绪，反问句式更显诗人情感的强烈与不舍。"
    }
  ]
}