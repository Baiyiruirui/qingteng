{
  "poem_id": "TANG_100",
  "title": "逢雪宿芙蓉山主人",
  "author": "刘长卿",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "漂泊",
    "困顿",
    "孤寂",
    "乡村生活",
    "温暖"
  ],
  "imagery": [
    "日暮",
    "苍山",
    "天寒",
    "白屋",
    "柴门",
    "犬吠",
    "风雪",
    "夜归人"
  ],
  "rhetoric": [
    "白描",
    "对仗",
    "动静结合"
  ],
  "lines": [
    {
      "line_id": "TANG_100_L1",
      "content": "日暮苍山远，",
      "imagery": [
        "日暮",
        "苍山"
      ],
      "emotion": [
        "苍凉",
        "孤寂",
        "广阔"
      ],
      "translation": "傍晚时分，远处的群山在暮色中显得苍茫。",
      "translation_keywords": [
        "日暮",
        "苍山",
        "远"
      ],
      "explanation": "描绘了傍晚时分，诗人行路于群山之中，感到天地广阔而人烟稀少，心生孤寂。"
    },
    {
      "line_id": "TANG_100_L2",
      "content": "天寒白屋贫。",
      "imagery": [
        "天寒",
        "白屋"
      ],
      "emotion": [
        "贫寒",
        "艰辛"
      ],
      "translation": "天气寒冷，只有一间简陋的茅屋孤零零地立着。",
      "translation_keywords": [
        "天寒",
        "白屋",
        "贫"
      ],
      "explanation": "在寒冷的天气中，诗人看到一座贫寒的白色小屋，点明了投宿之家的简朴，也衬托了旅途的艰辛。"
    },
    {
      "line_id": "TANG_100_L3",
      "content": "柴门闻犬吠，",
      "imagery": [
        "柴门",
        "犬吠"
      ],
      "emotion": [
        "惊喜",
        "温暖",
        "有生气"
      ],
      "translation": "忽然，从柴门里传来一阵狗叫声。",
      "translation_keywords": [
        "柴门",
        "闻犬吠"
      ],
      "explanation": "正在孤寂困顿之时，突然听到狗叫，打破了沉寂，给漂泊的旅人带来一丝希望与温暖。"
    },
    {
      "line_id": "TANG_100_L4",
      "content": "风雪夜归人。",
      "imagery": [
        "风雪",
        "夜归人"
      ],
      "emotion": [
        "归家之感",
        "旅途艰辛"
      ],
      "translation": "在这风雪交加的夜晚，一位夜归的旅人正要投宿。",
      "translation_keywords": [
        "风雪",
        "夜归人"
      ],
      "explanation": "狗吠声中，在风雪之夜，诗人终于找到了可以投宿的地方，暗示他就是那个风雪夜归的旅人，感受到了一点点归宿的温暖。"
    }
  ]
}