    "象征"
  ],
  "lines": [
    {
      "line_id": "TANG_052_L1",
      "content": "汉皇重色思倾国，御宇多年求不得。",
      "imagery": [
        "汉皇"
      ],
      "emotion": [
        "思慕",
        "不得"
      ],
      "translation": "汉明皇好色，想寻得一位绝代佳人，他统治天下多年却一直未能如愿。",
      "translation_keywords": [
        "汉皇",
        "重色",
        "倾国",
        "求不得"
      ],
      "explanation": "开篇点出唐玄宗沉迷女色，苦苦寻觅绝色佳人的背景。"
    },
    {
      "line_id": "TANG_052_L2",
      "content": "杨家有女初长成，养在深闺人未识。",
      "imagery": [
        "杨家有女",
        "深闺"
      ],
      "emotion": [
        "未识",
        "待字闺中"
      ],
      "translation": "杨家有位少女刚刚长大，养在深闺中不为世人所知。",
      "translation_keywords": [
        "杨家",
        "初长成",
        "深闺",
        "未识"
      ],
      "explanation": "介绍杨贵妃的出身和她初时未被发现的情景，为后文埋下伏笔。"
    },
    {
      "line_id": "TANG_052_L3",
      "content": "天生丽质难自弃，一朝选在君王侧。",
      "imagery": [
        "丽质",
        "君王侧"
      ],
      "emotion": [
        "惊艳",
        "受宠"
      ],
      "translation": "她天生丽质难以被埋没，终于有一天被选入宫中陪伴在君王身旁。",
      "translation_keywords": [
        "天生丽质",
        "难自弃",
        "一朝",
        "君王侧"
      ],
      "explanation": "承接上文，写杨贵妃终被发现，并以其绝色入宫，得到皇帝宠幸。"
    },
    {
      "line_id": "TANG_052_L4",
      "content": "回眸一笑百媚生，六宫粉黛无颜色。",
      "imagery": [
        "回眸一笑",
        "百媚",
        "六宫粉黛"
      ],
      "emotion": [
        "倾城",
        "艳压群芳"
      ],
      "translation": "她回眸一笑，千娇百媚顿生，使得六宫佳丽都黯然失色。",
      "translation_keywords": [
        "回眸一笑",
        "百媚生",
        "六宫",
        "粉黛",
        "无颜色"
      ],
      "explanation": "极言杨贵妃的美丽和魅力，她的一个笑容便能让所有宫妃失色，烘托其绝世容颜。"
    },
    {
      "line_id": "TANG_052_L5",
      "content": "春寒赐浴华清池，温泉水滑洗凝脂。",
      "imagery": [
        "春寒",
        "华清池",
        "温泉",
        "凝脂"
      ],
      "emotion": [
        "恩宠",
        "香艳"
      ],
      "translation": "春寒料峭时，皇上赐她在华清池沐浴，那温润的泉水洗涤着她滑腻的肌肤。",
      "translation_keywords": [
        "春寒",
        "华清池",
        "温泉",
        "凝脂"
      ],
      "explanation": "描写唐玄宗对杨贵妃的极致宠爱，在华清池享受奢华的生活。"
    },
    {
      "line_id": "TANG_052_L6",
      "content": "渔阳鼙鼓动地来，惊破霓裳羽衣曲。",
      "imagery": [
        "渔阳鼙鼓",
        "霓裳羽衣曲"
      ],
      "emotion": [
        "震惊",
        "危机"
      ],
      "translation": "渔阳的战鼓震天动地而来，惊破了悠扬的《霓裳羽衣曲》。",
      "translation_keywords": [
        "渔阳",
        "鼙鼓",
        "动地",
        "惊破",
        "霓裳羽衣曲"
      ],
      "explanation": "急转直下，以“渔阳鼙鼓”的突兀声响，象征安史之乱的爆发，打破了宫中的太平盛世。"
    },
    {
      "line_id": "TANG_052_L7",
      "content": "九重城阙烟尘生，千乘万骑西南行。",
      "imagery": [
        "九重城阙",
        "烟尘",
        "千乘万骑",
        "西南行"
      ],
      "emotion": [
        "战乱",
        "仓皇"
      ],
      "translation": "皇城内外狼烟四起，皇帝的庞大队伍仓皇地向西南逃亡。",
      "translation_keywords": [
        "九重城阙",
        "烟尘",
        "千乘万骑",
        "西南行"
      ],
      "explanation": "描写京城陷落，唐玄宗携杨贵妃及众臣仓皇出逃的狼狈景象。"
    },
    {
      "line_id": "TANG_052_L8",
      "content": "六军不发无奈何，宛转蛾眉马前死。",
      "imagery": [
        "六军",
        "蛾眉",
        "马前"
      ],
      "emotion": [
        "无奈",
        "悲痛",
        "牺牲"
      ],
      "translation": "禁卫军停止不前，无可奈何之下，杨贵妃在马嵬坡前被逼自缢。",
      "translation_keywords": [
        "六军",
        "不发",
        "无奈何",
        "宛转",
        "蛾眉",
        "马前死"
      ],
      "explanation": "诗歌的高潮，描述了马嵬坡兵变中，杨贵妃被逼赐死的悲剧性一幕。"
    },
    {
      "line_id": "TANG_052_L9",
      "content": "君王掩面救不得，回看血泪相和流。",
      "imagery": [
        "君王掩面",
        "血泪"
      ],
      "emotion": [
        "悲痛",
        "悔恨",
        "无能为力"
      ],
      "translation": "君王掩面想救却不能，回头看时已是血泪和着眼泪流淌。",
      "translation_keywords": [
        "君王",
        "掩面",
        "救不得",
        "血泪",
        "相和流"
      ],
      "explanation": "描写唐玄宗眼睁睁看着爱妃死去却无能为力的悲痛与悔恨。"
    },
    {
      "line_id": "TANG_052_L10",
      "content": "此恨绵绵无绝期。",
      "imagery": [],
      "emotion": [
        "深恨",
        "永恒的悲伤"
      ],
      "translation": "这遗恨绵长不绝，永无尽头。",
      "translation_keywords": [
        "此恨",
        "绵绵",
        "无绝期"
      ],
      "explanation": "全诗的最后一句，总结了唐玄宗对杨贵妃的深情与无尽的遗恨，点明了诗题“长恨”的含义。"
    }
  ]
}