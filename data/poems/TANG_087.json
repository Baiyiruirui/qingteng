  "lines": [
    {
      "line_id": "TANG_087_L1",
      "content": "结庐在人境，而无车马喧。",
      "imagery": [
        "茅庐",
        "车马"
      ],
      "emotion": [
        "宁静",
        "怡然"
      ],
      "translation": "我在人世间建造居所，却没有车马的喧嚣。",
      "translation_keywords": [
        "结庐",
        "人境",
        "车马",
        "喧"
      ],
      "explanation": "诗人在喧嚣的尘世中建房居住，却感受不到外界的吵闹。"
    },
    {
      "line_id": "TANG_087_L2",
      "content": "问君何能尔？心远地自偏。",
      "imagery": [],
      "emotion": [
        "顿悟",
        "超脱"
      ],
      "translation": "问我为什么能这样呢？心意超脱，自然觉得所住之地偏远宁静。",
      "translation_keywords": [
        "问君",
        "何能",
        "心远",
        "地偏"
      ],
      "explanation": "作者自问自答，点明了关键在于内心的超脱，心境淡泊，环境自然也就变得清幽。"
    },
    {
      "line_id": "TANG_087_L3",
      "content": "采菊东篱下，悠然见南山。",
      "imagery": [
        "菊花",
        "东篱",
        "南山"
      ],
      "emotion": [
        "闲适",
        "悠然"
      ],
      "translation": "在东边的篱笆下采摘菊花，悠闲地看到了南山。",
      "translation_keywords": [
        "采菊",
        "东篱",
        "悠然",
        "南山"
      ],
      "explanation": "描绘了诗人采菊的闲适情景，无意中看到南山，体现了其悠然自得的心境。"
    },
    {
      "line_id": "TANG_087_L4",
      "content": "山气日夕佳，飞鸟相与还。",
      "imagery": [
        "山气",
        "夕阳",
        "飞鸟"
      ],
      "emotion": [
        "恬淡",
        "和谐"
      ],
      "translation": "山间的景色傍晚时分尤其美好，鸟儿们也结伴归巢。",
      "translation_keywords": [
        "山气",
        "日夕",
        "飞鸟",
        "相与还"
      ],
      "explanation": "傍晚时分山色宜人，飞鸟结伴归巢，构成一幅和谐静谧的画面，与诗人内心感受相通。"
    },
    {
      "line_id": "TANG_087_L5",
      "content": "此中有真意，欲辨已忘言。",
      "imagery": [],
      "emotion": [
        "超然",
        "领悟"
      ],
      "translation": "这其中蕴含着人生的真谛，想要分辨清楚却又难以用语言表达。",
      "translation_keywords": [
        "真意",
        "辨",
        "忘言"
      ],
      "explanation": "诗人领悟到了生活的真谛，这是一种只可意会不可言传的境界，体现了深沉的哲理思考。"
    }
  ]
}