{
  "poem_id": "TANG_088",
  "title": "杂诗",
  "author": "陶渊明",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "古体诗",
  "themes": [
    "人生苦短",
    "珍惜时光",
    "友谊",
    "劝世"
  ],
  "imagery": [
    "根蒂",
    "尘",
    "风",
    "酒"
  ],
  "rhetoric": [
    "比喻",
    "感叹",
    "劝诫"
  ],
  "lines": [
    {
      "line_id": "TANG_088_L1",
      "content": "人生无根蒂，飘如陌上尘。",
      "imagery": [
        "根蒂",
        "尘"
      ],
      "emotion": [
        "慨叹",
        "渺茫"
      ],
      "translation": "人生就像没有根蒂的植物，飘零如田间路上的灰尘。",
      "translation_keywords": [
        "人生",
        "无根蒂",
        "飘",
        "陌上尘"
      ],
      "explanation": "诗人感叹人生虚无缥缈，像尘土一样无依无靠。"
    },
    {
      "line_id": "TANG_088_L2",
      "content": "分散逐风转，此已非常身。",
      "imagery": [
        "风"
      ],
      "emotion": [
        "无奈",
        "易逝"
      ],
      "translation": "随着风四处飘散旋转，这已经不是原来的身体了。",
      "translation_keywords": [
        "分散",
        "逐风转",
        "非常身"
      ],
      "explanation": "尘土随风飘散，比喻人生世事变迁，身不由己，生命不再是原来的样子。"
    },
    {
      "line_id": "TANG_088_L3",
      "content": "落地为兄弟，何必骨肉亲！",
      "imagery": [],
      "emotion": [
        "豁达",
        "友爱"
      ],
      "translation": "只要是生在世上的人，都可以是兄弟，何必拘泥于骨肉至亲呢！",
      "translation_keywords": [
        "落地",
        "兄弟",
        "骨肉亲"
      ],
      "explanation": "表达了广阔的胸襟，认为凡是活在世上的人都可以成为朋友，不必只看重血缘关系。"
    },
    {
      "line_id": "TANG_088_L4",
      "content": "得欢当作乐，斗酒聚比邻。",
      "imagery": [
        "酒",
        "比邻"
      ],
      "emotion": [
        "及时行乐",
        "友善"
      ],
      "translation": "遇到开心的事就该及时行乐，用一斗酒与邻居们欢聚一堂。",
      "translation_keywords": [
        "得欢",
        "作乐",
        "斗酒",
        "聚比邻"
      ],
      "explanation": "倡导珍惜当下，享受生活，与邻里和睦相处，用简单的快乐来丰盈人生。"
    },
    {
      "line_id": "TANG_088_L5",
      "content": "盛年不重来，一日难再晨。",
      "imagery": [
        "晨"
      ],
      "emotion": [
        "警醒",
        "珍惜"
      ],
      "translation": "青春盛年不会再次到来，就像一天之中不会有两个早晨一样。",
      "translation_keywords": [
        "盛年",
        "不重来",
        "一日",
        "再晨"
      ],
      "explanation": "警示人们青春易逝，时光一去不复返，强调了时间的宝贵。"
    },
    {
      "line_id": "TANG_088_L6",
      "content": "及时当勉励，岁月不待人。",
      "imagery": [],
      "emotion": [
        "勉励",
        "紧迫"
      ],
      "translation": "应当及时努力奋斗，美好的岁月是不会等待任何人的。",
      "translation_keywords": [
        "及时",
        "勉励",
        "岁月",
        "不待人"
      ],
      "explanation": "总结全诗，劝诫人们要珍惜时间，及时努力，不要虚度光阴。"
    }
  ]
}