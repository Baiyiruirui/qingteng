  "lines": [
    {
      "line_id": "TANG_097_L1",
      "content": "寂寂花时闭院门，",
      "imagery": [
        "花",
        "院门"
      ],
      "emotion": [
        "寂寞",
        "封闭",
        "压抑"
      ],
      "translation": "寂静的花开时节，宫院的大门紧闭着。",
      "translation_keywords": [
        "寂寂",
        "花时",
        "闭院门"
      ],
      "explanation": "描述宫廷深处与世隔绝、寂寞冷清的景象，暗示宫女生活的孤寂。"
    },
    {
      "line_id": "TANG_097_L2",
      "content": "美人相并立琼轩。",
      "imagery": [
        "美人",
        "琼轩"
      ],
      "emotion": [
        "幽怨",
        "无聊"
      ],
      "translation": "美丽的宫女们并排站立在华美的窗轩前。",
      "translation_keywords": [
        "美人",
        "相并",
        "琼轩"
      ],
      "explanation": "描绘宫女们百无聊赖地并立在华丽的窗前，她们的青春和美丽被禁锢在深宫中。"
    },
    {
      "line_id": "TANG_097_L3",
      "content": "含情欲说宫中事，",
      "imagery": [],
      "emotion": [
        "欲言又止",
        "压抑",
        "伤感"
      ],
      "translation": "她们心中饱含着情感，想要倾诉宫中的往事或心事。",
      "translation_keywords": [
        "含情",
        "欲说",
        "宫中事"
      ],
      "explanation": "宫女们心中藏有许多想说的话，可能是对宫中生活的抱怨，也可能是对自由的向往。"
    },
    {
      "line_id": "TANG_097_L4",
      "content": "鹦鹉前头不敢言。",
      "imagery": [
        "鹦鹉"
      ],
      "emotion": [
        "恐惧",
        "谨慎",
        "压抑"
      ],
      "translation": "却因为鹦鹉在前面，她们不敢开口说话。",
      "translation_keywords": [
        "鹦鹉",
        "前头",
        "不敢言"
      ],
      "explanation": "鹦鹉能学舌，宫女们担心秘密泄露，连在动物面前也保持沉默，深刻反映了宫中言语受限、生活压抑的氛围。"
    }
  ]
}