  "lines": [
    {
      "line_id": "TANG_062_L1",
      "content": "葡萄美酒夜光杯",
      "imagery": [
        "葡萄美酒",
        "夜光杯"
      ],
      "emotion": [
        "享受",
        "豪迈",
        "浪漫"
      ],
      "translation": "晶莹的夜光杯中斟满了甘醇的葡萄美酒。",
      "translation_keywords": [
        "葡萄美酒",
        "夜光杯"
      ],
      "explanation": "描绘了边塞将士饮酒的场景，美酒与美器相得益彰，营造出一种边塞特有的豪放与浪漫。"
    },
    {
      "line_id": "TANG_062_L2",
      "content": "欲饮琵琶马上催",
      "imagery": [
        "琵琶",
        "马"
      ],
      "emotion": [
        "急促",
        "紧张",
        "离愁"
      ],
      "translation": "正想开怀畅饮，却听见马上琵琶声催人出发。",
      "translation_keywords": [
        "欲饮",
        "琵琶",
        "马上催"
      ],
      "explanation": "饮酒尚未尽兴，军中琵琶声已催促将士们上马出征，表现了战争的紧迫与残酷，乐景衬哀情。"
    },
    {
      "line_id": "TANG_062_L3",
      "content": "醉卧沙场君莫笑",
      "imagery": [
        "沙场"
      ],
      "emotion": [
        "悲壮",
        "豪迈",
        "无所畏惧"
      ],
      "translation": "即使醉倒在战场上，请您也莫要嘲笑。",
      "translation_keywords": [
        "醉卧",
        "沙场",
        "君莫笑"
      ],
      "explanation": "表现了将士们对生死的超脱和视死如归的悲壮情怀，即使战死沙场，也是一种光荣。"
    },
    {
      "line_id": "TANG_062_L4",
      "content": "古来征战几人回",
      "imagery": [],
      "emotion": [
        "悲凉",
        "疑问",
        "无奈"
      ],
      "translation": "从古至今，出征的人有几人能够活着返回家乡呢？",
      "translation_keywords": [
        "古来",
        "征战",
        "几人回"
      ],
      "explanation": "以反问句的形式点明战争的残酷性，加深了诗歌的悲剧色彩，表达了对生命逝去的无奈和感慨，也反衬了前面视死如归的豪情。"
    }
  ]
}