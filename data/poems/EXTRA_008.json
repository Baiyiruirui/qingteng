{
  "poem_id": "EXTRA_008",
  "title": "出塞",
  "author": "王昌龄",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "边塞",
    "家国"
  ],
  "imagery": [
    "明月",
    "边关",
    "阴山"
  ],
  "rhetoric": [
    "互文",
    "用典",
    "借代",
    "对比"
  ],
  "lines": [
    {
      "line_id": "EXTRA_008_L1",
      "content": "秦时明月汉时关",
      "imagery": [
        "明月",
        "边关",
        "阴山"
      ],
      "emotion": [
        "边塞",
        "家国"
      ],
      "translation": "依旧是秦朝时的明月，汉朝时的边关。",
      "translation_keywords": [
        "秦朝",
        "明月",
        "汉朝",
        "边关"
      ],
      "explanation": "这句诗运用了互文的手法，意思是说边关的月亮和秦汉时一样，暗示战争从秦汉一直延续到现在，时间漫长，边关依旧。"
    },
    {
      "line_id": "EXTRA_008_L2",
      "content": "万里长征人未还",
      "imagery": [
        "明月",
        "边关",
        "阴山"
      ],
      "emotion": [
        "边塞",
        "家国"
      ],
      "translation": "离家万里远征的将士们，至今还没有回来。",
      "translation_keywords": [
        "万里",
        "长征",
        "将士",
        "未还"
      ],
      "explanation": "这句写征人远赴边疆，长期不能回家，表达了诗人对将士们长期征战、无法归家的同情与无奈。"
    },
    {
      "line_id": "EXTRA_008_L3",
      "content": "但使龙城飞将在",
      "imagery": [
        "明月",
        "边关",
        "阴山"
      ],
      "emotion": [
        "边塞",
        "家国"
      ],
      "translation": "只要像李广那样英勇的将军还在边疆驻守。",
      "translation_keywords": [
        "只要",
        "龙城",
        "飞将",
        "在"
      ],
      "explanation": "“龙城飞将”指汉代名将李广，这里用典，表达诗人对英勇善战的将领的渴望。"
    },
    {
      "line_id": "EXTRA_008_L4",
      "content": "不教胡马度阴山",
      "imagery": [
        "明月",
        "边关",
        "阴山"
      ],
      "emotion": [
        "边塞",
        "家国"
      ],
      "translation": "就不会让敌人的骑兵越过阴山来侵犯。",
      "translation_keywords": [
        "不教",
        "胡马",
        "度",
        "阴山"
      ],
      "explanation": "这句写出将士们保卫边疆的决心，也暗含对当时朝廷用人不当、边关不宁的批评。"
    }
  ]
}
