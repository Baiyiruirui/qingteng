  "lines": [
    {
      "line_id": "TANG_043_L1",
      "content": "剑外忽传收蓟北",
      "imagery": [
        "剑外",
        "蓟北"
      ],
      "emotion": [
        "惊喜",
        "振奋"
      ],
      "translation": "剑门关外忽然传来捷报，叛军已被平定，收复了河北、河南等地。",
      "translation_keywords": [
        "剑外",
        "忽然",
        "传来",
        "收复",
        "蓟北",
        "消息"
      ],
      "explanation": "在剑门关外的我，突然听到传来收复蓟北（指河北、河南等地）的捷报，心情无比激动。"
    },
    {
      "line_id": "TANG_043_L2",
      "content": "初闻涕泪满衣裳",
      "imagery": [
        "涕泪",
        "衣裳"
      ],
      "emotion": [
        "激动",
        "狂喜"
      ],
      "translation": "刚刚听到这个消息，高兴得泪水止不住地流淌，打湿了衣裳。",
      "translation_keywords": [
        "初闻",
        "涕泪",
        "满",
        "衣裳",
        "喜极而泣"
      ],
      "explanation": "初闻捷报时，喜极而泣，热泪盈眶，沾湿了衣裳。"
    },
    {
      "line_id": "TANG_043_L3",
      "content": "却看妻子愁何在",
      "imagery": [
        "妻子",
        "愁"
      ],
      "emotion": [
        "喜悦",
        "轻松"
      ],
      "translation": "回头再看看妻子儿女，他们脸上的愁容不知到哪里去了，都和我一样高兴。",
      "translation_keywords": [
        "却看",
        "妻子",
        "愁",
        "何在",
        "忧愁全无"
      ],
      "explanation": "回望妻儿，他们脸上的愁容已一扫而空，和自己一样充满了喜悦。"
    },
    {
      "line_id": "TANG_043_L4",
      "content": "漫卷诗书喜欲狂",
      "imagery": [
        "诗书"
      ],
      "emotion": [
        "狂喜",
        "解脱"
      ],
      "translation": "随手卷起诗书，高兴得几乎要发狂了。",
      "translation_keywords": [
        "漫卷",
        "诗书",
        "喜",
        "欲狂",
        "狂喜"
      ],
      "explanation": "我胡乱地卷起诗书，高兴得简直要发狂，表现出极度的狂喜之情。"
    },
    {
      "line_id": "TANG_043_L5",
      "content": "白日放歌须纵酒",
      "imagery": [
        "白日",
        "放歌",
        "纵酒"
      ],
      "emotion": [
        "尽情",
        "豪迈"
      ],
      "translation": "白天也要尽情地放歌，开怀畅饮，以示庆祝。",
      "translation_keywords": [
        "白日",
        "放歌",
        "纵酒",
        "尽情",
        "豪迈"
      ],
      "explanation": "即便在白天，也要放声高歌，开怀畅饮，尽情庆祝这来之不易的胜利。"
    },
    {
      "line_id": "TANG_043_L6",
      "content": "青春作伴好还乡",
      "imagery": [
        "青春"
      ],
      "emotion": [
        "轻松",
        "美好",
        "归乡"
      ],
      "translation": "趁着这美好的春天，作伴同行，正好回到故乡。",
      "translation_keywords": [
        "青春",
        "作伴",
        "还乡",
        "美好",
        "归家"
      ],
      "explanation": "正好趁着这美好的春光，与家人作伴，一起回到阔别已久的故乡。"
    },
    {
      "line_id": "TANG_043_L7",
      "content": "即从巴峡穿巫峡",
      "imagery": [
        "巴峡",
        "巫峡"
      ],
      "emotion": [
        "急切",
        "顺畅"
      ],
      "translation": "立刻就从巴峡出发，穿过巫峡。",
      "translation_keywords": [
        "即从",
        "巴峡",
        "穿",
        "巫峡",
        "归途"
      ],
      "explanation": "我恨不得立刻就从巴峡出发，穿过巫峡，踏上归途。"
    },
    {
      "line_id": "TANG_043_L8",
      "content": "便下襄阳向洛阳",
      "imagery": [
        "襄阳",
        "洛阳"
      ],
      "emotion": [
        "急切",
        "目标"
      ],
      "translation": "然后顺流而下，经过襄阳，直奔洛阳故乡。",
      "translation_keywords": [
        "便下",
        "襄阳",
        "向",
        "洛阳",
        "急切",
        "目标"
      ],
      "explanation": "然后顺江而下，经过襄阳，直奔我心心念念的洛阳故乡。"
    }
  ]
}