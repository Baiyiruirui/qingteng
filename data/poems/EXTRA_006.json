{
  "poem_id": "EXTRA_006",
  "title": "回乡偶书",
  "author": "贺知章",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "思乡",
    "人生"
  ],
  "imagery": [
    "乡音",
    "儿童"
  ],
  "rhetoric": [
    "对比",
    "设问"
  ],
  "lines": [
    {
      "line_id": "EXTRA_006_L1",
      "content": "少小离家老大回",
      "imagery": [
        "乡音",
        "儿童"
      ],
      "emotion": [
        "思乡",
        "人生"
      ],
      "translation": "年少时离开家乡，到了年老才回来。",
      "translation_keywords": [
        "年少",
        "离开",
        "家乡",
        "年老",
        "回来"
      ],
      "explanation": "这句诗用“少小”和“老大”的对比，写出了诗人离乡时间之长，从年轻到年老，突出了时光飞逝、人生易老的感慨。"
    },
    {
      "line_id": "EXTRA_006_L2",
      "content": "乡音无改鬓毛衰",
      "imagery": [
        "乡音",
        "儿童"
      ],
      "emotion": [
        "思乡",
        "人生"
      ],
      "translation": "家乡的口音没有改变，但两鬓的头发已经稀疏斑白了。",
      "translation_keywords": [
        "乡音",
        "未改",
        "鬓毛",
        "衰"
      ],
      "explanation": "“乡音无改”说明诗人始终心系故乡，而“鬓毛衰”则用外貌的变化，进一步强调岁月的无情，形成鲜明对比。"
    },
    {
      "line_id": "EXTRA_006_L3",
      "content": "儿童相见不相识",
      "imagery": [
        "乡音",
        "儿童"
      ],
      "emotion": [
        "思乡",
        "人生"
      ],
      "translation": "家乡的孩子们见到我都不认识。",
      "translation_keywords": [
        "儿童",
        "相见",
        "不相识"
      ],
      "explanation": "这句写诗人回到故乡后的陌生感。孩子们不认识他，暗示他离开太久，故乡已物是人非，令人心酸。"
    },
    {
      "line_id": "EXTRA_006_L4",
      "content": "笑问客从何处来",
      "imagery": [
        "乡音",
        "儿童"
      ],
      "emotion": [
        "思乡",
        "人生"
      ],
      "translation": "他们笑着问我：“客人是从哪里来的呀？”",
      "translation_keywords": [
        "笑问",
        "客",
        "何处来"
      ],
      "explanation": "孩子们天真地称诗人为“客”，这个细节既有趣又心酸。诗人本是故乡人，却被当作客人，用反问手法强化了游子归乡的无奈与感慨。"
    }
  ]
}
