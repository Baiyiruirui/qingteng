{
  "poem_id": "EXTRA_034",
  "title": "游园不值",
  "author": "叶绍翁",
  "dynasty": "宋",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "春景",
    "哲理"
  ],
  "imagery": [
    "苍苔",
    "红杏"
  ],
  "rhetoric": [
    "拟人",
    "借景抒情",
    "以小见大"
  ],
  "lines": [
    {
      "line_id": "EXTRA_034_L1",
      "content": "应怜屐齿印苍苔",
      "imagery": [
        "苍苔",
        "红杏"
      ],
      "emotion": [
        "春景",
        "哲理"
      ],
      "translation": "大概是主人爱惜青苔，怕我的木屐鞋底在上面留下脚印吧。",
      "translation_keywords": [
        "爱惜",
        "木屐",
        "脚印",
        "青苔"
      ],
      "explanation": "诗人猜想园主人爱惜园中的青苔，所以自己轻轻敲门也没人来开。用“应怜”二字，把青苔当作有感情的事物，写出诗人对园主人爱惜景物的理解。"
    },
    {
      "line_id": "EXTRA_034_L2",
      "content": "小扣柴扉久不开",
      "imagery": [
        "苍苔",
        "红杏"
      ],
      "emotion": [
        "春景",
        "哲理"
      ],
      "translation": "我轻轻地敲了很久的柴门，却一直没有人来开门。",
      "translation_keywords": [
        "轻轻",
        "敲",
        "柴门",
        "很久",
        "不开"
      ],
      "explanation": "“小扣”写出诗人礼貌、轻柔的动作，“久不开”则写出等待的漫长和失望。这句为后面的惊喜做铺垫。"
    },
    {
      "line_id": "EXTRA_034_L3",
      "content": "春色满园关不住",
      "imagery": [
        "苍苔",
        "红杏"
      ],
      "emotion": [
        "春景",
        "哲理"
      ],
      "translation": "满园的春色是关也关不住的。",
      "translation_keywords": [
        "满园",
        "春色",
        "关不住"
      ],
      "explanation": "诗人虽然没能进园，却想象园内春色满溢，用“关不住”把春色拟人化，写出春天的生机和活力无法被阻挡。"
    },
    {
      "line_id": "EXTRA_034_L4",
      "content": "一枝红杏出墙来",
      "imagery": [
        "苍苔",
        "红杏"
      ],
      "emotion": [
        "春景",
        "哲理"
      ],
      "translation": "一枝红杏已经从墙头探了出来。",
      "translation_keywords": [
        "一枝",
        "红杏",
        "出墙"
      ],
      "explanation": "诗人看到一枝红杏伸出墙外，用具体的“一枝”代表满园的春色，以小见大，写出春天的蓬勃生机。红杏出墙的画面充满动感和惊喜。"
    }
  ]
}
