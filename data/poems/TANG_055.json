  "lines": [
    {
      "line_id": "TANG_055_L1",
      "content": "天街小雨润如酥，草色遥看近却无。",
      "imagery": [
        "天街",
        "小雨",
        "草色"
      ],
      "emotion": [
        "清新",
        "朦胧",
        "细腻"
      ],
      "translation": "京城的大街上飘洒着蒙蒙细雨，滋润得像酥油一样；远远看去草色青青，走近了却似乎又没有。",
      "translation_keywords": [
        "天街",
        "小雨",
        "润如酥",
        "草色",
        "遥看",
        "近却无"
      ],
      "explanation": "首句描绘早春细雨的滋润和朦胧，第二句写初生草色之淡，虚实结合，描绘了早春独有的含蓄美。"
    },
    {
      "line_id": "TANG_055_L2",
      "content": "最是一年春好处，绝胜烟柳满皇都。",
      "imagery": [
        "春",
        "烟柳",
        "皇都"
      ],
      "emotion": [
        "喜爱",
        "赞美",
        "独特"
      ],
      "translation": "这正是春天最美妙的时候，远远胜过那些烟柳弥漫、繁花盛开的京城景象。",
      "translation_keywords": [
        "最是",
        "一年",
        "春好处",
        "绝胜",
        "烟柳",
        "满皇都"
      ],
      "explanation": "后两句表达诗人对早春的独特喜爱，认为这种含蓄的生机比盛春的浓艳更胜一筹，突显了诗人不落俗套的审美情趣。"
    }
  ]
}