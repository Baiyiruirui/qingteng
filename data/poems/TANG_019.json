  ],
  "lines": [
    {
      "line_id": "TANG_019_L1",
      "content": "红豆生南国，",
      "imagery": [
        "红豆",
        "南国"
      ],
      "emotion": [
        "思念",
        "引子"
      ],
      "translation": "红豆生长在遥远的南方，",
      "translation_keywords": [
        "红豆",
        "生长",
        "南方"
      ],
      "explanation": "开篇点明了相思的象征物——红豆，并交代了它的产地“南国”，为全诗奠定了思念的基调。"
    },
    {
      "line_id": "TANG_019_L2",
      "content": "春来发几枝？",
      "imagery": [
        "春",
        "枝"
      ],
      "emotion": [
        "询问",
        "关切",
        "思念增长"
      ],
      "translation": "春天来了，它该生出多少新枝呢？",
      "translation_keywords": [
        "春天",
        "生发",
        "多少",
        "新枝"
      ],
      "explanation": "以设问句的形式，看似询问红豆生长情况，实则暗示时光流转、季节更替，表达了对远方友人的深切关怀，以及思念之情如同红豆发枝般不断增长、繁茂。"
    },
    {
      "line_id": "TANG_019_L3",
      "content": "愿君多采撷，",
      "imagery": [
        "采撷"
      ],
      "emotion": [
        "叮嘱",
        "期盼",
        "深情"
      ],
      "translation": "希望你能够多多采摘它，",
      "translation_keywords": [
        "希望",
        "多多",
        "采摘"
      ],
      "explanation": "直接抒发了对友人的真挚情感，希望友人能“多采撷”红豆，将无形的相思之情具象化，暗示友人珍惜这份情谊。"
    },
    {
      "line_id": "TANG_019_L4",
      "content": "此物最相思。",
      "imagery": [
        "红豆"
      ],
      "emotion": [
        "点题",
        "强调",
        "深情"
      ],
      "translation": "因为它最能寄托相思之情。",
      "translation_keywords": [
        "此物",
        "最能",
        "相思"
      ],
      "explanation": "点明全诗主旨，揭示了红豆与相思的紧密联系，将红豆的象征意义推向高潮，表达了诗人对友人深厚而炽热的思念之情。"
    }
  ]
}