  "lines": [
    {
      "line_id": "TANG_013_L1",
      "content": "京口瓜洲一水间",
      "imagery": [
        "京口",
        "瓜洲",
        "一水"
      ],
      "emotion": [
        "地理描述",
        "平静"
      ],
      "translation": "京口和瓜洲只隔了一条水域。",
      "translation_keywords": [
        "京口",
        "瓜洲",
        "一水间",
        "相隔"
      ],
      "explanation": "诗歌开篇点明了瓜洲与京口（今镇江）之间水域相连的地理位置，用“一水间”强调两者距离之近，为下文引出故乡钟山作铺垫。"
    },
    {
      "line_id": "TANG_013_L2",
      "content": "钟山只隔数重山",
      "imagery": [
        "钟山",
        "数重山"
      ],
      "emotion": [
        "地理描述",
        "思念萌生"
      ],
      "translation": "从瓜洲望去，家乡的钟山也只隔了几重山而已。",
      "translation_keywords": [
        "钟山",
        "只隔",
        "数重山",
        "家乡"
      ],
      "explanation": "诗人进一步指出瓜洲与钟山（南京，作者曾隐居于此，代指故乡）仅隔数重山，看似不远，却也暗含了身在他乡的距离感，将思乡之情引入，为全诗主旨埋下伏笔。"
    },
    {
      "line_id": "TANG_013_L3",
      "content": "春风又绿江南岸",
      "imagery": [
        "春风",
        "绿",
        "江南岸"
      ],
      "emotion": [
        "生机",
        "喜悦",
        "感慨"
      ],
      "translation": "和煦的春风又吹绿了江南两岸。",
      "translation_keywords": [
        "春风",
        "绿",
        "江南岸",
        "生机勃勃"
      ],
      "explanation": "这是全诗的炼句。一个“绿”字将抽象的春风拟人化，使其具有了点染万物的魔力，生动描绘了江南大地一派生机勃勃的景象。句中的“又”字，则流露出诗人对季节更替、时光流逝的淡淡感慨。"
    },
    {
      "line_id": "TANG_013_L4",
      "content": "明月何时照我还",
      "imagery": [
        "明月"
      ],
      "emotion": [
        "思乡",
        "期盼",
        "惆怅"
      ],
      "translation": "明月啊，你何时才能照着我回到故乡去呢？",
      "translation_keywords": [
        "明月",
        "何时",
        "照我",
        "还",
        "回家",
        "期盼"
      ],
      "explanation": "诗歌以设问句结尾，情感强烈。诗人借明月这一经典的思乡意象，直抒胸臆，表达了对故乡的深切思念和渴望归家的强烈愿望，将前三句的景物描写和地理铺垫都归结于这浓郁的乡愁之中，情景交融，余味悠长。"
    }
  ]
