  "lines": [
    {
      "line_id": "TANG_075_L1",
      "content": "独怜幽草涧边生，上有黄鹂深树鸣。",
      "imagery": [
        "幽草",
        "涧边",
        "黄鹂",
        "深树"
      ],
      "emotion": [
        "喜爱",
        "宁静",
        "生机"
      ],
      "translation": "我特别喜爱那在小溪边独自生长的幽静野草，树林深处有黄鹂鸟在欢快鸣唱。",
      "translation_keywords": [
        "独",
        "喜爱",
        "幽静",
        "野草",
        "涧边",
        "生长",
        "黄鹂",
        "深树",
        "鸣叫"
      ],
      "explanation": "诗人独自一人，只喜爱那在小溪边默默生长的幽深野草。在这片宁静的景象中，还有黄鹂鸟在茂密的树林深处欢快地歌唱，为画面增添了生机。"
    },
    {
      "line_id": "TANG_075_L2",
      "content": "春潮带雨晚来急，野渡无人舟自横。",
      "imagery": [
        "春潮",
        "雨",
        "晚",
        "野渡",
        "舟"
      ],
      "emotion": [
        "闲适",
        "孤寂",
        "恬淡"
      ],
      "translation": "春天的潮水带着雨水，傍晚时分水势更加湍急，野外的渡口没有一个人，小船独自横停在水边。",
      "translation_keywords": [
        "春潮",
        "带雨",
        "傍晚",
        "急速",
        "野渡",
        "无人",
        "舟",
        "横着"
      ],
      "explanation": "傍晚时分，春潮伴随着细雨，水流变得湍急。然而，在野外的渡口，却空无一人，只有一只小船独自横靠在岸边。这一句以动衬静，以急促的春潮反衬渡口的无人和船的闲置，营造出一种恬淡、清幽而又略带孤寂的意境。"
    }
  ]
}