    "人踪",
    "孤舟",
    "蓑笠翁",
    "寒江",
    "雪"
  ],
  "rhetoric": [
    "对仗",
    "白描",
    "烘托",
    "对比",
    "反衬"
  ],
  "lines": [
    {
      "line_id": "TANG_011_L1",
      "content": "千山鸟飞绝",
      "imagery": [
        "千山",
        "鸟"
      ],
      "emotion": [
        "空旷",
        "寂寥"
      ],
      "translation": "所有的山上都没有飞鸟的踪迹了。",
      "translation_keywords": [
        "千山",
        "鸟",
        "飞绝"
      ],
      "explanation": "开篇点出广袤的山野，连鸟的踪迹都已断绝，渲染出一种极度的空旷与寂静，为全诗奠定清冷基调。"
    },
    {
      "line_id": "TANG_011_L2",
      "content": "万径人踪灭",
      "imagery": [
        "万径",
        "人踪"
      ],
      "emotion": [
        "寂静",
        "孤独"
      ],
      "translation": "所有的道路上都没有人的足迹了。",
      "translation_keywords": [
        "万径",
        "人踪",
        "灭"
      ],
      "explanation": "进一步深化了“绝”的意境，从天上到地上，从空间到时间，全面描绘了人迹罕至的场景，强调了环境的孤寂，与上一句形成完美的对仗。"
    },
    {
      "line_id": "TANG_011_L3",
      "content": "孤舟蓑笠翁",
      "imagery": [
        "孤舟",
        "蓑笠翁"
      ],
      "emotion": [
        "独立",
        "孤寂"
      ],
      "translation": "只有一叶孤零零的小船上，坐着一位身披蓑衣、头戴斗笠的老渔翁。",
      "translation_keywords": [
        "孤舟",
        "蓑笠翁"
      ],
      "explanation": "在“绝”与“灭”的背景下，一个具象的人物突然出现，打破了死寂。用“孤”字修饰小舟，暗示了人物遗世独立的形象，引人深思。"
    },
    {
      "line_id": "TANG_011_L4",
      "content": "独钓寒江雪",
      "imagery": [
        "独钓",
        "寒江",
        "雪"
      ],
      "emotion": [
        "坚韧",
        "傲岸",
        "清冷"
      ],
      "translation": "他独自一人在冰冷的江上，冒着大雪垂钓。",
      "translation_keywords": [
        "独钓",
        "寒江",
        "雪"
      ],
      "explanation": "“独钓”进一步突显了人物的孤独与高傲，他选择在“寒江雪”这样恶劣的环境中坚持，衬托出老翁不畏严寒、超凡脱俗的坚韧品格和不与世俗同流合污的清高情怀。"
    }
  ]
}