{
  "poem_id": "EXTRA_011",
  "title": "送元二使安西",
  "author": "王维",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "送别",
    "友情"
  ],
  "imagery": [
    "朝雨",
    "柳色",
    "阳关"
  ],
  "rhetoric": [
    "借景抒情",
    "直抒胸臆"
  ],
  "lines": [
    {
      "line_id": "EXTRA_011_L1",
      "content": "渭城朝雨浥轻尘",
      "imagery": [
        "朝雨",
        "柳色",
        "阳关"
      ],
      "emotion": [
        "送别",
        "友情"
      ],
      "translation": "清晨的细雨打湿了渭城的尘土。",
      "translation_keywords": [
        "渭城",
        "早晨",
        "雨",
        "湿润",
        "尘土"
      ],
      "explanation": "这句写送别时的天气和地点。渭城是送别的地方，早晨的细雨轻轻打湿了路面上的尘土，让空气变得清新。诗人用“浥轻尘”三个字，写出雨不大，刚好把尘土压住，给人一种干净、宁静的感觉。"
    },
    {
      "line_id": "EXTRA_011_L2",
      "content": "客舍青青柳色新",
      "imagery": [
        "朝雨",
        "柳色",
        "阳关"
      ],
      "emotion": [
        "送别",
        "友情"
      ],
      "translation": "旅店旁的柳树被雨水洗过，颜色更加青翠。",
      "translation_keywords": [
        "客舍",
        "柳树",
        "青色",
        "新鲜"
      ],
      "explanation": "这句写送别地点的景物。客舍是旅店，暗示元二即将远行。柳树在古诗中常代表离别（“柳”谐音“留”），这里柳色青青，既写出雨后柳树的鲜亮，也暗含诗人对朋友的挽留和不舍。"
    },
    {
      "line_id": "EXTRA_011_L3",
      "content": "劝君更尽一杯酒",
      "imagery": [
        "朝雨",
        "柳色",
        "阳关"
      ],
      "emotion": [
        "送别",
        "友情"
      ],
      "translation": "劝你再喝一杯送别的酒吧。",
      "translation_keywords": [
        "劝",
        "再",
        "一杯",
        "酒"
      ],
      "explanation": "这句直接写送别的动作。诗人劝朋友再喝一杯酒，因为这一别，不知何时才能再见。“更尽”两个字，写出诗人想多留朋友一会儿的心情，也表现出深厚的友情。"
    },
    {
      "line_id": "EXTRA_011_L4",
      "content": "西出阳关无故人",
      "imagery": [
        "朝雨",
        "柳色",
        "阳关"
      ],
      "emotion": [
        "送别",
        "友情"
      ],
      "translation": "等你出了阳关向西走，就再也见不到老朋友了。",
      "translation_keywords": [
        "西出",
        "阳关",
        "没有",
        "老朋友"
      ],
      "explanation": "这句点明送别的原因和结果。阳关是通往西域的关口，出了阳关就是荒凉的边塞。诗人说“无故人”，既写出朋友此行的孤独，也表达自己对朋友的牵挂和担忧。"
    }
  ]
}
