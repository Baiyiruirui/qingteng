{
  "poem_id": "EXTRA_024",
  "title": "江南春",
  "author": "杜牧",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "江南",
    "春景"
  ],
  "imagery": [
    "莺啼",
    "酒旗",
    "烟雨"
  ],
  "rhetoric": [
    "夸张",
    "对仗",
    "借景抒情"
  ],
  "lines": [
    {
      "line_id": "EXTRA_024_L1",
      "content": "千里莺啼绿映红",
      "imagery": [
        "莺啼",
        "酒旗",
        "烟雨"
      ],
      "emotion": [
        "江南",
        "春景"
      ],
      "translation": "千里江南，到处是黄莺啼叫，绿叶映衬着红花。",
      "translation_keywords": [
        "千里",
        "莺啼",
        "绿",
        "红"
      ],
      "explanation": "首句以“千里”总写江南春色之广阔，黄莺啼叫和红绿相映的视觉、听觉意象，生动展现生机盎然的春景。"
    },
    {
      "line_id": "EXTRA_024_L2",
      "content": "水村山郭酒旗风",
      "imagery": [
        "莺啼",
        "酒旗",
        "烟雨"
      ],
      "emotion": [
        "江南",
        "春景"
      ],
      "translation": "水边的村庄、山边的城郭，酒旗在风中飘动。",
      "translation_keywords": [
        "水村",
        "山郭",
        "酒旗",
        "风"
      ],
      "explanation": "此句描绘江南水乡和山城风光，酒旗随风招展，增添生活气息，动静结合，画面丰富。"
    },
    {
      "line_id": "EXTRA_024_L3",
      "content": "南朝四百八十寺",
      "imagery": [
        "莺啼",
        "酒旗",
        "烟雨"
      ],
      "emotion": [
        "江南",
        "春景"
      ],
      "translation": "南朝遗留下来的许多寺庙。",
      "translation_keywords": [
        "南朝",
        "四百八十",
        "寺"
      ],
      "explanation": "“四百八十”是夸张手法，形容寺庙之多，引出历史感，为下句的烟雨朦胧做铺垫。"
    },
    {
      "line_id": "EXTRA_024_L4",
      "content": "多少楼台烟雨中",
      "imagery": [
        "莺啼",
        "酒旗",
        "烟雨"
      ],
      "emotion": [
        "江南",
        "春景"
      ],
      "translation": "有多少楼台笼罩在蒙蒙烟雨之中。",
      "translation_keywords": [
        "楼台",
        "烟雨",
        "多少"
      ],
      "explanation": "末句以“烟雨”收束，将历史遗迹融入迷蒙雨景，虚实结合，含蓄表达对历史兴衰的淡淡感慨。"
    }
  ]
}
