  "lines": [
    {
      "line_id": "TANG_024_L1",
      "content": "君自故乡来，",
      "imagery": [
        "君 (友人)",
        "故乡"
      ],
      "emotion": [
        "惊喜",
        "亲切",
        "期待"
      ],
      "translation": "你刚刚从我的故乡来到这里，",
      "translation_keywords": [
        "你",
        "自",
        "故乡",
        "来"
      ],
      "explanation": "诗人遇到一位从故乡来的朋友，心情惊喜，充满期待。"
    },
    {
      "line_id": "TANG_024_L2",
      "content": "应知故乡事。",
      "imagery": [
        "故乡",
        "事 (事情)"
      ],
      "emotion": [
        "询问",
        "渴求信息"
      ],
      "translation": "应该知道故乡的许多事情吧？",
      "translation_keywords": [
        "应该",
        "知道",
        "故乡",
        "事情"
      ],
      "explanation": "诗人猜测这位朋友一定对故乡的情况很了解，急切地想询问家乡的消息。"
    },
    {
      "line_id": "TANG_024_L3",
      "content": "来日绮窗前，",
      "imagery": [
        "绮窗 (雕花的窗户)",
        "来日 (来的时候)"
      ],
      "emotion": [
        "回忆",
        "关注"
      ],
      "translation": "来的时候，我家华丽的窗前，",
      "translation_keywords": [
        "来的时候",
        "华丽",
        "窗前"
      ],
      "explanation": "诗人回忆或想象朋友出发前，在自己故乡家里的绮窗前。"
    },
    {
      "line_id": "TANG_024_L4",
      "content": "寒梅着花未？",
      "imagery": [
        "寒梅",
        "着花 (开花)"
      ],
      "emotion": [
        "关心",
        "乡愁",
        "牵挂"
      ],
      "translation": "寒梅有没有开放呢？",
      "translation_keywords": [
        "寒梅",
        "开花",
        "没有"
      ],
      "explanation": "诗人不问亲人状况，却问寒梅开花与否，以小见大，反衬对家乡深沉的思念，因为梅花是报春的使者，也是故乡的象征。"
    }
  ]
}