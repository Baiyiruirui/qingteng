{
  "poem_id": "TANG_084",
  "title": "春夜喜雨",
  "author": "杜甫",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "律诗",
  "themes": [
    "喜雨",
    "农耕",
    "自然之美",
    "生机勃勃"
  ],
  "imagery": [
    "好雨",
    "春夜",
    "风",
    "野径",
    "江船",
    "火",
    "红湿",
    "花",
    "锦官城"
  ],
  "rhetoric": [
    "拟人",
    "对仗",
    "借景抒情",
    "动静结合"
  ],
  "lines": [
    {
      "line_id": "TANG_084_L1",
      "content": "好雨知时节，",
      "imagery": [
        "好雨"
      ],
      "emotion": [
        "喜悦",
        "赞美"
      ],
      "translation": "这场好雨知道适宜的时节，",
      "translation_keywords": [
        {
          "word": "好雨",
          "meaning": "指下得及时、对庄稼有益的雨。"
        },
        {
          "word": "知时节",
          "meaning": "懂得季节的变化，指雨下得非常及时。"
        }
      ],
      "explanation": "诗人一开始就用拟人手法赞美春雨，说它仿佛通人性，懂得农作物最需要滋润的时节，表达了对这场雨的喜爱和感激之情。"
    },
    {
      "line_id": "TANG_084_L2",
      "content": "当春乃发生。",
      "imagery": [
        "春"
      ],
      "emotion": [
        "期待",
        "生机"
      ],
      "translation": "正是草木萌芽的春天它才降临。",
      "translation_keywords": [
        {
          "word": "当春",
          "meaning": "正值春天的时候。"
        },
        {
          "word": "乃发生",
          "meaning": "于是就降临、发生。"
        }
      ],
      "explanation": "承接上句，进一步强调春雨的及时性。它在万物复苏的春天降临，滋润大地，促使草木生长，充满了生机。"
    },
    {
      "line_id": "TANG_084_L3",
      "content": "随风潜入夜，",
      "imagery": [
        "风",
        "夜"
      ],
      "emotion": [
        "安静",
        "细密"
      ],
      "translation": "它伴随微风悄悄地潜入夜色之中，",
      "translation_keywords": [
        {
          "word": "随风",
          "meaning": "伴随着风。"
        },
        {
          "word": "潜入夜",
          "meaning": "悄悄地在夜里到来。一个“潜”字写出了雨的轻柔和无声无息。"
        }
      ],
      "explanation": "这句描绘了春雨温柔的到来方式。它乘着夜色，伴随微风，悄无声息地降临，不打扰人们的休息，体现了雨的细腻和无私。"
    },
    {
      "line_id": "TANG_084_L4",
      "content": "润物细无声。",
      "imagery": [],
      "emotion": [
        "滋润",
        "恩泽"
      ],
      "translation": "默默地滋润着万物，细微得几乎听不见声音。",
      "translation_keywords": [
        {
          "word": "润物",
          "meaning": "滋润万物。"
        },
        {
          "word": "细无声",
          "meaning": "雨点细密，悄然无声。形容雨的特点和作用。"
        }
      ],
      "explanation": "“润物细无声”是千古名句，生动地描绘了春雨的特点——细密而无声，却能默默滋润万物。它无私奉献的精神令人赞叹。"
    },
    {
      "line_id": "TANG_084_L5",
      "content": "野径云俱黑，",
      "imagery": [
        "野径",
        "云"
      ],
      "emotion": [
        "深沉",
        "宁静"
      ],
      "translation": "乡野小路上的天空乌云密布，一片漆黑，",
      "translation_keywords": [
        {
          "word": "野径",
          "meaning": "乡间小路。"
        },
        {
          "word": "云俱黑",
          "meaning": "乌云全都变得漆黑。"
        }
      ],
      "explanation": "写雨夜的景象。雨下了一夜，野外小路上的天空被乌云笼罩，一片漆黑，突出了夜雨的绵长和深沉。"
    },
    {
      "line_id": "TANG_084_L6",
      "content": "江船火独明。",
      "imagery": [
        "江船",
        "火"
      ],
      "emotion": [
        "对比",
        "温暖"
      ],
      "translation": "唯有江中船上的灯火独自闪亮。",
      "translation_keywords": [
        {
          "word": "江船",
          "meaning": "江上的船只。"
        },
        {
          "word": "火独明",
          "meaning": "船上的灯火独自明亮。"
        }
      ],
      "explanation": "在漆黑的雨夜中，江船上的点点灯火显得格外明亮，形成鲜明对比。这束微弱的火光不仅照亮了黑暗，也给雨夜增添了一丝温暖和人间气息。"
    },
    {
      "line_id": "TANG_084_L7",
      "content": "晓看红湿处，",
      "imagery": [
        "红",
        "湿"
      ],
      "emotion": [
        "期待",
        "喜悦"
      ],
      "translation": "等到天亮的时候，去看看那被雨水浸润的红色花朵，",
      "translation_keywords": [
        {
          "word": "晓看",
          "meaning": "天亮时去看。"
        },
        {
          "word": "红湿处",
          "meaning": "被雨水打湿的红色花朵的地方。"
        }
      ],
      "explanation": "诗人充满期待地展望第二天清晨的景象，想象着雨后的花朵被雨水滋润，颜色会更加鲜艳，充满生机。"
    },
    {
      "line_id": "TANG_084_L8",
      "content": "花重锦官城。",
      "imagery": [
        "花",
        "锦官城"
      ],
      "emotion": [
        "丰盛",
        "繁荣"
      ],
      "translation": "整个锦官城都被雨水浸润得花朵饱满沉重。",
      "translation_keywords": [
        {
          "word": "花重",
          "meaning": "花朵饱含雨水，显得沉甸甸的。形容花朵繁茂，被雨水滋润后的娇艳姿态。"
        },
        {
          "word": "锦官城",
          "meaning": "指成都，古时以盛产锦而得名。"
        }
      ],
      "explanation": "结尾描绘了雨后锦官城（成都）一派繁花似锦的景象。经过春雨的洗礼，花朵饱满欲滴，整个城市都充满了盎然的生机和美丽。表达了诗人对春雨的喜爱以及对美好春色的赞叹。"
    }
  ]
}