  "lines": [
    {
      "line_id": "TANG_085_L1",
      "content": "细草微风岸，",
      "imagery": [
        "细草",
        "微风",
        "岸"
      ],
      "emotion": [
        "萧瑟",
        "孤独"
      ],
      "translation": "微风吹拂着江岸边纤细的青草，",
      "translation_keywords": [
        {
          "word": "细草",
          "meaning": "细小柔弱的草。"
        },
        {
          "word": "微风",
          "meaning": "轻微的风。"
        },
        {
          "word": "岸",
          "meaning": "江边，水岸。"
        }
      ],
      "explanation": "首句描绘了夜色下江岸的景象：细小的青草在微风中摇曳。这看似平静的画面，却透着一丝凄凉和萧瑟，为全诗定下了基调。"
    },
    {
      "line_id": "TANG_085_L2",
      "content": "危樯独夜舟。",
      "imagery": [
        "危樯",
        "夜舟"
      ],
      "emotion": [
        "漂泊",
        "无依"
      ],
      "translation": "高耸的桅杆立在孤独的夜航船上。",
      "translation_keywords": [
        {
          "word": "危樯",
          "meaning": "高高的桅杆。危，高耸。"
        },
        {
          "word": "独夜舟",
          "meaning": "夜晚独自停泊的船只。象征诗人的孤寂和漂泊。"
        }
      ],
      "explanation": "诗人将视线转向江面，一艘高桅杆的船只在夜色中独自停泊。这艘孤独的船，正是诗人漂泊无依、孑然一身的写照，充满着羁旅愁绪。"
    },
    {
      "line_id": "TANG_085_L3",
      "content": "星垂平野阔，",
      "imagery": [
        "星",
        "平野"
      ],
      "emotion": [
        "辽阔",
        "渺小"
      ],
      "translation": "星星低垂，显得原野更加广阔，",
      "translation_keywords": [
        {
          "word": "星垂",
          "meaning": "星星似乎低垂到地面。形容星空低沉而广阔。"
        },
        {
          "word": "平野阔",
          "meaning": "平坦的原野显得非常辽阔。"
        }
      ],
      "explanation": "视野进一步开阔，写夜空星辰低垂，映衬出大地平野的无边无际。这种宏大的景象，反衬出诗人自身的渺小和孤独。"
    },
    {
      "line_id": "TANG_085_L4",
      "content": "月涌大江流。",
      "imagery": [
        "月",
        "大江"
      ],
      "emotion": [
        "奔腾",
        "深远"
      ],
      "translation": "月光随波涌动，大江滚滚东流。",
      "translation_keywords": [
        {
          "word": "月涌",
          "meaning": "月光随着江水波涛翻涌。形象地描绘月色与江水的互动。"
        },
        {
          "word": "大江流",
          "meaning": "大江水势浩荡，奔腾不息。"
        }
      ],
      "explanation": "月光与江水交织，月影在江水中翻涌，大江奔腾不息。这句描绘了壮阔的江流景象，既有动态美，也暗含着时光流逝的感慨。"
    },
    {
      "line_id": "TANG_085_L5",
      "content": "名岂文章著，",
      "imagery": [],
      "emotion": [
        "自嘲",
        "不甘"
      ],
      "translation": "我的名声难道仅仅因为文章写得好而闻名吗？",
      "translation_keywords": [
        {
          "word": "名",
          "meaning": "名声，名气。"
        },
        {
          "word": "岂",
          "meaning": "难道。表示反问。"
        },
        {
          "word": "文章著",
          "meaning": "因文章而著称。"
        }
      ],
      "explanation": "诗人在这里发出疑问，表面上是自嘲自己的名声仅限于诗文，实则表达了自己渴望通过报国建功立业的远大抱负，不甘心只做一位诗人。"
    },
    {
      "line_id": "TANG_085_L6",
      "content": "官应老病休。",
      "imagery": [],
      "emotion": [
        "无奈",
        "悲叹"
      ],
      "translation": "做官只应该等到年老多病的时候再辞休。",
      "translation_keywords": [
        {
          "word": "官应",
          "meaning": "做官本应。"
        },
        {
          "word": "老病休",
          "meaning": "年老多病才辞官休息。诗人暗示自己并非因年老病痛而休官，而是壮志未酬。"
        }
      ],
      "explanation": "这句流露出诗人对自身命运的悲叹。他认为做官应该是因为年老多病才退隐，而自己现在虽然漂泊，却并非因年老体衰，暗示了自己报国无门、壮志难酬的遗憾。"
    },
    {
      "line_id": "TANG_085_L7",
      "content": "飘飘何所似？",
      "imagery": [
        "飘飘"
      ],
      "emotion": [
        "迷茫",
        "自问"
      ],
      "translation": "我这漂泊无定的身世像什么呢？",
      "translation_keywords": [
        {
          "word": "飘飘",
          "meaning": "漂泊不定的样子。"
        },
        {
          "word": "何所似",
          "meaning": "像什么。"
        }
      ],
      "explanation": "诗人自问，将自己的漂泊人生比作什么。这是一种内心深处的追问，充满了迷茫和对未来的不确定性。"
    },
    {
      "line_id": "TANG_085_L8",
      "content": "天地一沙鸥。",
      "imagery": [
        "天地",
        "沙鸥"
      ],
      "emotion": [
        "孤独",
        "悲凉"
      ],
      "translation": "就像天地间一只孤独的沙鸥。",
      "translation_keywords": [
        {
          "word": "天地",
          "meaning": "广阔的天地之间。"
        },
        {
          "word": "一沙鸥",
          "meaning": "一只孤独的沙鸥。比喻诗人漂泊无依，孤独凄凉的处境。"
        }
      ],
      "explanation": "以“天地一沙鸥”作结，将自己的漂泊生涯比作天地间一只孤独的沙鸥，形象地写出了诗人漂泊无依、孤独凄凉的处境，情感深沉而悲凉，令人动容。"
    }
  ]
