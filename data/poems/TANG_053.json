{
  "poem_id": "TANG_053",
  "title": "望月怀远",
  "author": "张九龄",
  "dynasty": "唐",
  "grade": "初中",
  "text_type": "五言律诗",
  "themes": [
    "思乡",
    "怀友",
    "望月抒情",
    "孤独"
  ],
  "imagery": [
    "海上明月",
    "天涯",
    "清辉",
    "离人",
    "相思",
    "明镜",
    "白云"
  ],
  "rhetoric": [
    "借景抒情",
    "比喻",
    "对仗",
    "问答",
    "虚实结合"
  ],
  "lines": [
    {
      "line_id": "TANG_053_L1",
      "content": "海上生明月，天涯共此时。",
      "imagery": [
        "海上明月",
        "天涯"
      ],
      "emotion": [
        "思念",
        "共情"
      ],
      "translation": "一轮明月从海上冉冉升起，远隔天涯的我们共同沐浴在此时的月光下。",
      "translation_keywords": [
        "海上",
        "明月",
        "天涯",
        "共此时"
      ],
      "explanation": "首联以景入情，描绘了壮丽的月升景象，并立刻将月亮与远方的亲友联系起来，点明怀远主题。"
    },
    {
      "line_id": "TANG_053_L2",
      "content": "情人怨遥夜，竟夕起相思。",
      "imagery": [
        "遥夜"
      ],
      "emotion": [
        "怨",
        "相思"
      ],
      "translation": "有情人怨恨漫漫长夜，整夜都涌起无尽的相思之情。",
      "translation_keywords": [
        "情人",
        "怨",
        "遥夜",
        "竟夕",
        "相思"
      ],
      "explanation": "颔联承上，直接抒发了对远方亲人的思念，将自身感情融入普遍的“情人”之怨，加深了情感的普适性。"
    },
    {
      "line_id": "TANG_053_L3",
      "content": "灭烛怜光满，披衣觉露滋。",
      "imagery": [
        "烛光",
        "月光",
        "露水"
      ],
      "emotion": [
        "爱怜",
        "清冷",
        "孤独"
      ],
      "translation": "熄灭了蜡烛，反倒怜爱满屋的月光；披上衣服，才感到露水渐渐沾湿。",
      "translation_keywords": [
        "灭烛",
        "怜",
        "光满",
        "披衣",
        "觉",
        "露滋"
      ],
      "explanation": "颈联通过两个细微的动作和感受，细腻地刻画了诗人因思念而辗转反侧、无法入眠，与月光为伴的形象。"
    },
    {
      "line_id": "TANG_053_L4",
      "content": "不堪盈手赠，还寝梦佳期。",
      "imagery": [
        "月光"
      ],
      "emotion": [
        "遗憾",
        "期盼",
        "慰藉"
      ],
      "translation": "这美好的月光我无法捧满双手赠送给你，不如回去睡觉，期待在梦中与你相会。",
      "translation_keywords": [
        "不堪",
        "盈手赠",
        "还寝",
        "梦",
        "佳期"
      ],
      "explanation": "尾联从对月思念转入对未来的期盼，表达了诗人对团聚的渴望，也流露出无法实现现实相见的无奈。"
    }
  ]
}