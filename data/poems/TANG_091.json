  "lines": [
    {
      "line_id": "TANG_091_L1",
      "content": "故人西辞黄鹤楼，烟花三月下扬州。",
      "imagery": [
        "黄鹤楼",
        "烟花",
        "扬州"
      ],
      "emotion": [
        "惜别",
        "祝愿"
      ],
      "translation": "老朋友孟浩然在西边的黄鹤楼与我告别，在繁花似锦的三月前往扬州。",
      "translation_keywords": [
        "故人",
        "西辞",
        "黄鹤楼",
        "烟花三月",
        "下扬州"
      ],
      "explanation": "点明了送别的地点、时间和目的地，描绘了春天扬州的繁华景象，衬托出送别时的美好却又带着一丝离愁。"
    },
    {
      "line_id": "TANG_091_L2",
      "content": "孤帆远影碧空尽，唯见长江天际流。",
      "imagery": [
        "孤帆",
        "远影",
        "碧空",
        "长江",
        "天际"
      ],
      "emotion": [
        "怅惘",
        "不舍"
      ],
      "translation": "孤单的船帆渐渐远去，最后消失在碧绿的天边，只看见长江滚滚地向天边流去。",
      "translation_keywords": [
        "孤帆",
        "远影",
        "碧空尽",
        "唯见",
        "长江",
        "天际流"
      ],
      "explanation": "描绘了船只渐行渐远直至消失的画面，诗人目送友人远去，内心充满不舍与怅惘，也体现了友情的深厚。"
    }
  ]
}