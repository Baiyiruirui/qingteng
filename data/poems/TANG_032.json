  "lines": [
    {
      "line_id": "TANG_032_L1",
      "content": "单车欲问边，属国过居延。",
      "imagery": [
        "单车",
        "居延"
      ],
      "emotion": [
        "远行",
        "边塞",
        "任务"
      ],
      "translation": "我乘坐着一辆简朴的马车，想要前往边塞探问军情；途经了归附汉朝的居延属国。",
      "translation_keywords": [
        "单车",
        "问边",
        "属国",
        "居延"
      ],
      "explanation": "诗人受命出使边塞，乘坐简朴马车，途经汉朝的属国居延，点明了此行的目的和地点，暗示旅途的艰辛。"
    },
    {
      "line_id": "TANG_032_L2",
      "content": "征蓬出汉塞，归雁入胡天。",
      "imagery": [
        "征蓬",
        "汉塞",
        "归雁",
        "胡天"
      ],
      "emotion": [
        "漂泊",
        "思乡",
        "苍凉",
        "孤寂"
      ],
      "translation": "我像随风飘荡的蓬草一样离开了汉朝边塞，又像南归的大雁飞入了异族的天空。",
      "translation_keywords": [
        "征蓬",
        "汉塞",
        "归雁",
        "胡天"
      ],
      "explanation": "诗人自比随风飘荡的蓬草，离开汉朝边塞，又见大雁北归，飞入胡地天空，寓示自己此行的艰辛与孤单，流露出漂泊之感。"
    },
    {
      "line_id": "TANG_032_L3",
      "content": "大漠孤烟直，长河落日圆。",
      "imagery": [
        "大漠",
        "孤烟",
        "长河",
        "落日"
      ],
      "emotion": [
        "壮阔",
        "苍凉",
        "寂寥",
        "雄浑"
      ],
      "translation": "浩瀚的沙漠上升起一股笔直的狼烟，万里长河之上，一轮落日浑圆。",
      "translation_keywords": [
        "大漠",
        "孤烟直",
        "长河",
        "落日圆"
      ],
      "explanation": "此乃千古名句，描绘了边塞奇特的自然景观：广阔的沙漠中一缕孤烟笔直向上，夕阳映照着大河，显得浑圆巨大。画面雄浑壮丽，静中有动，极富张力。"
    },
    {
      "line_id": "TANG_032_L4",
      "content": "萧关逢候骑，都护在燕然。",
      "imagery": [
        "萧关",
        "候骑",
        "都护",
        "燕然"
      ],
      "emotion": [
        "尽职",
        "军情",
        "期盼",
        "慰藉"
      ],
      "translation": "在萧关遇到了边防的巡逻骑兵，他们告诉我，都护大人正在燕然山指挥战斗。",
      "translation_keywords": [
        "萧关",
        "逢",
        "候骑",
        "都护",
        "燕然"
      ],
      "explanation": "在边塞要塞萧关遇到巡逻骑兵，得知都护正驻守燕然前线，表明边防将士尽职尽责，也回应了开篇“问边”的目的，使全诗结构完整。"
    }
  ]
