  ],
  "lines": [
    {
      "line_id": "TANG_048_L1",
      "content": "卖炭翁，伐薪烧炭南山中。",
      "imagery": [
        "卖炭翁",
        "薪",
        "炭",
        "南山"
      ],
      "emotion": [
        "劳动",
        "艰辛"
      ],
      "translation": "有一位卖炭的老翁，在南山里砍柴烧炭。",
      "translation_keywords": [
        "卖炭翁",
        "砍柴",
        "烧炭",
        "南山"
      ],
      "explanation": "开篇点出主人公卖炭翁的身份和劳作地点，直接展现他劳动人民的形象。"
    },
    {
      "line_id": "TANG_048_L2",
      "content": "满面尘灰烟火色，两鬓苍苍十指黑。",
      "imagery": [
        "面部",
        "尘灰",
        "烟火色",
        "两鬓",
        "苍苍",
        "十指",
        "黑"
      ],
      "emotion": [
        "辛苦",
        "衰老",
        "疲惫"
      ],
      "translation": "他满脸是灰尘和烟火的颜色，两鬓头发花白，十个手指头都被炭染黑了。",
      "translation_keywords": [
        "满面",
        "尘灰",
        "烟火色",
        "两鬓",
        "苍苍",
        "十指",
        "黑"
      ],
      "explanation": "通过外貌描写，细致地刻画了卖炭翁长期辛劳、饱受风霜的形象，突出了其劳作的艰辛和生活的困苦。"
    },
    {
      "line_id": "TANG_048_L3",
      "content": "卖炭得钱何所营？身上衣裳口中食。",
      "imagery": [
        "钱",
        "衣裳",
        "食"
      ],
      "emotion": [
        "无奈",
        "生存"
      ],
      "translation": "卖炭得来的钱是用来做什么的呢？不过是为了换取身上的衣裳和口中的食物。",
      "translation_keywords": [
        "卖炭",
        "得钱",
        "所营",
        "衣裳",
        "食物"
      ],
      "explanation": "以设问的方式点出卖炭翁劳作的目的，仅仅是为了最基本的生存需求，揭示了劳动人民生活的贫困。"
    },
    {
      "line_id": "TANG_048_L4",
      "content": "可怜身上衣正单，心忧炭贱愿天寒。",
      "imagery": [
        "衣裳",
        "单",
        "炭",
        "天寒"
      ],
      "emotion": [
        "可怜",
        "矛盾",
        "期盼"
      ],
      "translation": "可怜他身上穿着单薄的衣裳，却还担心炭卖不出好价钱而盼望着天气更加寒冷。",
      "translation_keywords": [
        "可怜",
        "衣单",
        "心忧",
        "炭贱",
        "愿",
        "天寒"
      ],
      "explanation": "写出了卖炭翁生活中的一个深刻矛盾：自己衣不蔽体，却为了生计盼望严寒，揭示了劳动人民的悲惨境遇。"
    },
    {
      "line_id": "TANG_048_L5",
      "content": "夜来城外一尺雪，晓驾炭车辗冰辙。",
      "imagery": [
        "夜",
        "城外",
        "雪",
        "晓",
        "炭车",
        "冰辙"
      ],
      "emotion": [
        "艰苦",
        "辛劳"
      ],
      "translation": "夜里城外下了一尺厚的大雪，清晨他便驾着炭车碾着冰冻的车辙前行。",
      "translation_keywords": [
        "夜来",
        "城外",
        "一尺雪",
        "晓驾",
        "炭车",
        "辗",
        "冰辙"
      ],
      "explanation": "环境描写，通过“一尺雪”和“冰辙”烘托出天气的严寒和道路的艰难，进一步突出了卖炭翁的勤劳和不易。"
    },
    {
      "line_id": "TANG_048_L6",
      "content": "牛困人饥日已高，市南门外泥中歇。",
      "imagery": [
        "牛",
        "人",
        "饥",
        "日",
        "高",
        "市南门",
        "泥",
        "歇"
      ],
      "emotion": [
        "疲惫",
        "饥饿",
        "困顿"
      ],
      "translation": "牛累了，人也饿了，太阳已经升得老高，他们只好在市南门外的泥泞中休息。",
      "translation_keywords": [
        "牛困",
        "人饥",
        "日高",
        "市南门外",
        "泥中歇"
      ],
      "explanation": "承接上句，描写了卖炭翁和他的老牛在严寒中长途跋涉后的疲惫和饥饿，环境的恶劣与他们的困顿形成鲜明对比。"
    },
    {
      "line_id": "TANG_048_L7",
      "content": "翩翩两骑来是谁？黄衣使者白衫儿。",
      "imagery": [
        "翩翩",
        "两骑",
        "黄衣使者",
        "白衫儿"
      ],
      "emotion": [
        "疑问",
        "转折",
        "不祥预感"
      ],
      "translation": "突然轻快地来了两个人骑马，他们是谁呢？是穿着黄衣的宦官使者和穿着白衫的少年。",
      "translation_keywords": [
        "翩翩",
        "两骑",
        "黄衣使者",
        "白衫儿"
      ],
      "explanation": "场景转换，打破了之前的苦寒景象，突然出现两个身份不明的骑者，为后文的矛盾冲突埋下伏笔。"
    },
    {
      "line_id": "TANG_048_L8",
      "content": "手把文书口称敕，回车叱牛牵向北。",
      "imagery": [
        "手",
        "文书",
        "口",
        "敕",
        "车",
        "牛",
        "北"
      ],
      "emotion": [
        "蛮横",
        "专横",
        "强制"
      ],
      "translation": "他们手里拿着文书，嘴里声称是皇帝的命令，然后转动车头，呵斥着老牛往北边拉去。",
      "translation_keywords": [
        "手把",
        "文书",
        "口称",
        "敕",
        "回车",
        "叱牛",
        "牵向北"
      ],
      "explanation": "描写了宦官仗势欺人的行径，以“文书”“敕”为幌子，强行征收卖炭翁的炭，体现了封建官僚的蛮横无理。"
    },
    {
      "line_id": "TANG_048_L9",
      "content": "一车炭，千余斤，宫使驱将惜不得。",
      "imagery": [
        "一车炭",
        "千余斤",
        "宫使"
      ],
      "emotion": [
        "无奈",
        "不舍",
        "愤怒"
      ],
      "translation": "一车的炭，足有一千多斤，宫里的使者直接就拉走了，卖炭翁想吝惜都舍不得。",
      "translation_keywords": [
        "一车炭",
        "千余斤",
        "宫使",
        "驱将",
        "惜不得"
      ],
      "explanation": "进一步强调了被强征的炭的数量之大，以及卖炭翁的无奈与心痛，揭露了宫使的贪婪和剥削的本质。"
    },
    {
      "line_id": "TANG_048_L10",
      "content": "半匹红绡一丈绫，系向牛头充炭值。",
      "imagery": [
        "半匹红绡",
        "一丈绫",
        "牛头",
        "炭值"
      ],
      "emotion": [
        "讽刺",
        "不公",
        "愤慨"
      ],
      "translation": "只给了半匹红色的薄绸和一丈长的白绫，绑在牛头上，充作炭的价钱。",
      "translation_keywords": [
        "半匹红绡",
        "一丈绫",
        "系向",
        "牛头",
        "充",
        "炭值"
      ],
      "explanation": "描绘了宫使以极其廉价的丝绸抵作炭钱，这种象征性的支付实则是赤裸裸的掠夺，极具讽刺意味，深刻揭示了封建社会官僚对劳动人民的残酷剥削。"
    }
  ]
}