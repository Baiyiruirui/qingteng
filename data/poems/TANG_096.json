  "lines": [
    {
      "line_id": "TANG_096_L1",
      "content": "鸣筝金粟柱",
      "imagery": [
        "鸣筝",
        "金粟柱"
      ],
      "emotion": [
        "优雅",
        "专注"
      ],
      "translation": "铮铮作响的古筝，装饰着金色的粟状琴柱。",
      "translation_keywords": [
        "鸣筝",
        "金粟柱",
        "古筝"
      ],
      "explanation": "描绘了女子所弹奏的古筝，琴柱精美，声音清亮，为下文的女子形象和心境作铺垫。"
    },
    {
      "line_id": "TANG_096_L2",
      "content": "素手玉房前",
      "imagery": [
        "素手",
        "玉房"
      ],
      "emotion": [
        "优美",
        "含蓄"
      ],
      "translation": "（弹筝的）是纤纤素手，在精致的闺房前面。",
      "translation_keywords": [
        "素手",
        "玉房",
        "闺房"
      ],
      "explanation": "勾勒出弹筝女子的美丽形象：她伸出洁白的手指，在闺房前弹奏，场景典雅。"
    },
    {
      "line_id": "TANG_096_L3",
      "content": "欲得周郎顾",
      "imagery": [
        "周郎"
      ],
      "emotion": [
        "思慕",
        "期待",
        "娇羞"
      ],
      "translation": "她渴望得到周瑜的注意和赞许。",
      "translation_keywords": [
        "欲得",
        "周郎",
        "注意",
        "欣赏"
      ],
      "explanation": "典故“周郎顾”。周瑜精通音律，听曲时若有误，他会回头看一眼。这里指女子希望得到自己心仪之人的关注和赞赏。"
    },
    {
      "line_id": "TANG_096_L4",
      "content": "时时误拂弦",
      "imagery": [],
      "emotion": [
        "假装",
        "心机",
        "娇俏",
        "期待"
      ],
      "translation": "因此，她会时不时地故意拨错琴弦。",
      "translation_keywords": [
        "时时",
        "误",
        "拂弦",
        "故意"
      ],
      "explanation": "揭示了女子内心的娇羞与心机。为了吸引心上人（“周郎”）的注意，她故意时不时地拨错琴弦，以此引起对方的回眸一瞥。这表现了少女含蓄而又大胆的求爱心理。"
    }
  ]
}