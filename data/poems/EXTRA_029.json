{
  "poem_id": "EXTRA_029",
  "title": "饮湖上初晴后雨",
  "author": "苏轼",
  "dynasty": "宋",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "山水",
    "西湖"
  ],
  "imagery": [
    "水光",
    "山色",
    "西湖"
  ],
  "rhetoric": [
    "比喻",
    "对偶"
  ],
  "lines": [
    {
      "line_id": "EXTRA_029_L1",
      "content": "水光潋滟晴方好",
      "imagery": [
        "水光",
        "山色",
        "西湖"
      ],
      "emotion": [
        "山水",
        "西湖"
      ],
      "translation": "在晴朗的日子里，西湖水波荡漾，波光闪闪，景色非常美好。",
      "translation_keywords": [
        "水光",
        "潋滟",
        "晴",
        "方好"
      ],
      "explanation": "这句写晴天西湖的景色。“潋滟”形容水波闪动的样子，诗人用这个词生动地描绘出阳光照耀下湖面波光粼粼的美景，表达了对晴天西湖的喜爱。"
    },
    {
      "line_id": "EXTRA_029_L2",
      "content": "山色空蒙雨亦奇",
      "imagery": [
        "水光",
        "山色",
        "西湖"
      ],
      "emotion": [
        "山水",
        "西湖"
      ],
      "translation": "在雨天里，远处的山色云雾迷蒙，景色也很奇妙。",
      "translation_keywords": [
        "山色",
        "空蒙",
        "雨",
        "亦奇"
      ],
      "explanation": "这句写雨天西湖的景色。“空蒙”形容云雾迷茫的样子，诗人用这个词描绘出雨中青山若隐若现的朦胧美，与上句的晴天形成对比，突出西湖无论晴雨都美。"
    },
    {
      "line_id": "EXTRA_029_L3",
      "content": "欲把西湖比西子",
      "imagery": [
        "水光",
        "山色",
        "西湖"
      ],
      "emotion": [
        "山水",
        "西湖"
      ],
      "translation": "我想把西湖比作古代的美女西施。",
      "translation_keywords": [
        "欲",
        "西湖",
        "比",
        "西子"
      ],
      "explanation": "这句是诗人奇妙的联想，用比喻手法将西湖比作西施。西施是古代著名的美女，诗人用她来比喻西湖，既形象又富有诗意，为下句做铺垫。"
    },
    {
      "line_id": "EXTRA_029_L4",
      "content": "淡妆浓抹总相宜",
      "imagery": [
        "水光",
        "山色",
        "西湖"
      ],
      "emotion": [
        "山水",
        "西湖"
      ],
      "translation": "无论是淡雅的妆饰还是浓艳的打扮，西施都很合适；就像西湖无论晴天还是雨天，都同样美丽动人。",
      "translation_keywords": [
        "淡妆",
        "浓抹",
        "总相宜"
      ],
      "explanation": "这句是比喻的深化。“淡妆浓抹”既指西施的妆容，也暗指西湖的晴雨景色。“总相宜”强调西湖在任何天气下都美得恰到好处，表达了诗人对西湖的由衷赞美。"
    }
  ]
}
