  ],
  "lines": [
    {
      "line_id": "TANG_065_L1",
      "content": "闺中少妇不知愁",
      "imagery": [],
      "emotion": [
        "无忧",
        "娇憨"
      ],
      "translation": "深闺中的年轻少妇，本应不知愁苦。",
      "translation_keywords": [
        "闺中",
        "少妇",
        "不知愁"
      ],
      "explanation": "以反语开篇，说少妇“不知愁”，为下文的突然醒悟和深沉愁绪埋下伏笔，制造了心理落差。"
    },
    {
      "line_id": "TANG_065_L2",
      "content": "春日凝妆上翠楼",
      "imagery": [
        "凝妆",
        "翠楼"
      ],
      "emotion": [
        "闲适",
        "爱美",
        "期待"
      ],
      "translation": "在春日里精心打扮，登上高高的翠楼。",
      "translation_keywords": [
        "春日",
        "凝妆",
        "翠楼"
      ],
      "explanation": "描绘了少妇妆容精致、登上高楼远眺的场景，衬托了其年轻美貌，也暗示了她对美好生活的向往。"
    },
    {
      "line_id": "TANG_065_L3",
      "content": "忽见陌头杨柳色",
      "imagery": [
        "陌头杨柳"
      ],
      "emotion": [
        "触景生情",
        "惊醒",
        "顿悟"
      ],
      "translation": "忽然望见路边杨柳青翠的颜色。",
      "translation_keywords": [
        "忽见",
        "陌头",
        "杨柳色"
      ],
      "explanation": "“忽见”二字是转折点，青翠的杨柳是春天和生机的象征，但在古诗中也常与离别联系，此处触景生情，引发了少妇的愁绪。"
    },
    {
      "line_id": "TANG_065_L4",
      "content": "悔教夫婿觅封侯",
      "imagery": [],
      "emotion": [
        "悔恨",
        "悲伤",
        "幽怨"
      ],
      "translation": "后悔当初劝夫君去边疆建功立业，追求功名。",
      "translation_keywords": [
        "悔教",
        "夫婿",
        "觅封侯"
      ],
      "explanation": "点明了少妇的“愁”之所在，是因为丈夫远征未归，自己思念深重，悔恨当初鼓励丈夫追求功名，表达了对安稳团聚生活的渴望，也含蓄地批判了战争对家庭的破坏。"
    }
  ]
}