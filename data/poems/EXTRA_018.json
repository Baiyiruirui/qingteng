{
  "poem_id": "EXTRA_018",
  "title": "赋得古原草送别",
  "author": "白居易",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "古诗",
  "themes": [
    "送别",
    "生命"
  ],
  "imagery": [
    "古原",
    "野草",
    "春风"
  ],
  "rhetoric": [
    "拟人",
    "借景抒情",
    "对比",
    "象征"
  ],
  "lines": [
    {
      "line_id": "EXTRA_018_L1",
      "content": "离离原上草",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "原野上长满了茂盛的青草。",
      "translation_keywords": [
        "原野",
        "茂盛",
        "青草"
      ],
      "explanation": "首句写草的长势，“离离”形容草叶茂密、分开的样子，让人看到一片生机勃勃的草原景象。"
    },
    {
      "line_id": "EXTRA_018_L2",
      "content": "一岁一枯荣",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "每年都会经历一次枯萎和一次茂盛。",
      "translation_keywords": [
        "每年",
        "枯萎",
        "茂盛"
      ],
      "explanation": "这句点出草的生命规律：秋冬枯萎，春夏又绿。用“一岁一枯荣”概括了自然循环，也暗示人生有起有落。"
    },
    {
      "line_id": "EXTRA_018_L3",
      "content": "野火烧不尽",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "野火也无法把它完全烧尽。",
      "translation_keywords": [
        "野火",
        "烧不尽",
        "顽强"
      ],
      "explanation": "用“野火”的猛烈反衬草的坚韧，即使烈火燎原，草根依然深埋地下，生命力极其顽强。"
    },
    {
      "line_id": "EXTRA_018_L4",
      "content": "春风吹又生",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "等到春风吹来，它又会重新生长出来。",
      "translation_keywords": [
        "春风",
        "吹",
        "又生"
      ],
      "explanation": "“吹又生”写出草在春风中复苏，与上一句形成强烈对比。这里用了拟人手法，让草像有生命一样主动再生。"
    },
    {
      "line_id": "EXTRA_018_L5",
      "content": "远芳侵古道",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "远处的芳草蔓延到古老的道路上。",
      "translation_keywords": [
        "远方",
        "芳草",
        "古道"
      ],
      "explanation": "“远芳”写草香飘远，“侵”字用拟人手法，写出青草主动覆盖古道的动态，暗示离别之路漫长。"
    },
    {
      "line_id": "EXTRA_018_L6",
      "content": "晴翠接荒城",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "晴日下翠绿的草色连接着荒凉的城池。",
      "translation_keywords": [
        "晴天",
        "翠绿",
        "荒城"
      ],
      "explanation": "“晴翠”写阳光下草色鲜亮，“接”字写出草与荒城相连，景色开阔中带着荒凉，烘托送别的氛围。"
    },
    {
      "line_id": "EXTRA_018_L7",
      "content": "又送王孙去",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "又要送别远行的友人离去。",
      "translation_keywords": [
        "送别",
        "友人",
        "离去"
      ],
      "explanation": "“王孙”借指远行的朋友，直接点出送别主题。这句由写景转入抒情，自然引出别情。"
    },
    {
      "line_id": "EXTRA_018_L8",
      "content": "萋萋满别情",
      "imagery": [
        "古原",
        "野草",
        "春风"
      ],
      "emotion": [
        "送别",
        "生命"
      ],
      "translation": "茂盛的春草仿佛也充满了惜别的情意。",
      "translation_keywords": [
        "茂盛",
        "春草",
        "别情"
      ],
      "explanation": "“萋萋”形容草茂盛，这里用拟人手法，让草也懂得离情，把无形的别情化为有形的青草，情景交融。"
    }
  ]
}
