{
  "poem_id": "TANG_009",
  "title": "早发白帝城",
  "author": "李白",
  "dynasty": "唐",
  "grade": "初中",
  "text_type": "七言绝句",
  "themes": [
    "旅途的愉悦与畅快",
    "对大自然的赞美",
    "摆脱困境后的轻松与喜悦"
  ],
  "imagery": [
    "白帝城",
    "彩云",
    "江陵",
    "猿声",
    "轻舟",
    "万重山"
  ],
  "rhetoric": [
    "夸张",
    "听觉描写",
    "动静结合",
    "衬托"
  ],
  "lines": [
    {
      "line_id": "TANG_009_L1",
      "content": "朝辞白帝彩云间",
      "imagery": [
        "白帝城",
        "彩云"
      ],
      "emotion": [
        "开阔",
        "明朗"
      ],
      "translation": "清晨，我告别了笼罩在绚丽彩云之间的白帝城。",
      "translation_keywords": [
        "清晨",
        "告别",
        "白帝城",
        "彩云"
      ],
      "explanation": "诗歌开篇点明了出发的时间（朝）和地点（白帝城），“彩云间”则描绘了白帝城在彩云环绕中的壮丽景色，为整个旅程奠定了一个明快、开阔而又浪漫的基调。"
    },
    {
      "line_id": "TANG_009_L2",
      "content": "千里江陵一日还",
      "imagery": [
        "江陵"
      ],
      "emotion": [
        "豪迈",
        "惊喜",
        "迅速"
      ],
      "translation": "千里迢迢的江陵，竟然一天之内就到达了。",
      "translation_keywords": [
        "千里",
        "江陵",
        "一日",
        "返回/到达"
      ],
      "explanation": "此句运用夸张手法，写出了乘船顺流而下速度之快，一千里路程一日即达，表达了诗人解除流放后返乡的极度喜悦与轻松心情，同时也展现了长江水流的湍急。"
    },
    {
      "line_id": "TANG_009_L3",
      "content": "两岸猿声啼不住",
      "imagery": [
        "猿声",
        "两岸"
      ],
      "emotion": [
        "衬托",
        "急促"
      ],
      "translation": "两岸猿猴的啼叫声还在耳边回荡，一声接着一声不停歇。",
      "translation_keywords": [
        "两岸",
        "猿声",
        "啼叫",
        "不住"
      ],
      "explanation": "猿声在传统诗歌中常引人愁绪，但在这里，急促的猿声反而衬托出船行之快，让人不及细品猿啼之愁，反而更觉旅途的生动与飞速，为诗人的喜悦心情做了侧面烘托。"
    },
    {
      "line_id": "TANG_009_L4",
      "content": "轻舟已过万重山",
      "imagery": [
        "轻舟",
        "万重山"
      ],
      "emotion": [
        "畅快",
        "豪迈",
        "轻盈"
      ],
      "translation": "轻快的小船早已穿过了层层叠叠的万重高山。",
      "translation_keywords": [
        "轻舟",
        "穿过",
        "万重山"
      ],
      "explanation": "此句与第二句呼应，再次用夸张手法强调船行之迅猛，仿佛瞬息之间就越过了重重山峦。一个“轻”字，不仅指船的轻快，更暗含诗人摆脱困境后的轻松愉快心情。整句诗将速度感、空间感和诗人超脱的乐观情绪完美结合，达到了高潮。"
    }
  ]
}