{
  "poem_id": "EXTRA_013",
  "title": "别董大",
  "author": "高适",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "送别",
    "鼓励"
  ],
  "imagery": [
    "黄云",
    "北风",
    "飞雁"
  ],
  "rhetoric": [
    "夸张",
    "反问"
  ],
  "lines": [
    {
      "line_id": "EXTRA_013_L1",
      "content": "千里黄云白日曛",
      "imagery": [
        "黄云",
        "北风",
        "飞雁"
      ],
      "emotion": [
        "送别",
        "鼓励"
      ],
      "translation": "千里之外，黄云漫天，太阳也变得昏暗无光。",
      "translation_keywords": [
        "千里",
        "黄云",
        "白日",
        "曛"
      ],
      "explanation": "这句写送别时的天气，用“黄云”“白日曛”渲染出阴沉、苍茫的氛围，暗示离别的沉重和不舍。"
    },
    {
      "line_id": "EXTRA_013_L2",
      "content": "北风吹雁雪纷纷",
      "imagery": [
        "黄云",
        "北风",
        "飞雁"
      ],
      "emotion": [
        "送别",
        "鼓励"
      ],
      "translation": "北风呼啸，吹着大雁南飞，大雪纷纷扬扬。",
      "translation_keywords": [
        "北风",
        "吹",
        "雁",
        "雪纷纷"
      ],
      "explanation": "继续写景，用“北风”“雁”“雪”等意象，突出寒冷、萧瑟的冬日景象，也暗含对友人旅途艰辛的担忧。"
    },
    {
      "line_id": "EXTRA_013_L3",
      "content": "莫愁前路无知己",
      "imagery": [
        "黄云",
        "北风",
        "飞雁"
      ],
      "emotion": [
        "送别",
        "鼓励"
      ],
      "translation": "不要担心前方的路上没有知心朋友。",
      "translation_keywords": [
        "莫愁",
        "前路",
        "无知己"
      ],
      "explanation": "诗人直接劝慰友人，语气坚定有力，“莫愁”二字一扫前面的阴郁，表现出豪迈和自信。"
    },
    {
      "line_id": "EXTRA_013_L4",
      "content": "天下谁人不识君",
      "imagery": [
        "黄云",
        "北风",
        "飞雁"
      ],
      "emotion": [
        "送别",
        "鼓励"
      ],
      "translation": "普天之下，有谁不认识您呢？",
      "translation_keywords": [
        "天下",
        "谁人",
        "不识君"
      ],
      "explanation": "用反问句强调友人的名声和才华，语气夸张而真诚，既是对友人的赞美，也是深情的鼓励。"
    }
  ]
}
