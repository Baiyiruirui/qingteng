{
  "poem_id": "TANG_025",
  "title": "登乐游原",
  "author": "李商隐",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "壮丽景色",
    "人生感慨",
    "晚景",
    "时光流逝"
  ],
  "imagery": [
    "乐游原",
    "夕阳",
    "黄昏",
    "古原"
  ],
  "rhetoric": [
    "对比",
    "转折",
    "寓情于景",
    "警句"
  ],
  "lines": [
    {
      "line_id": "TANG_025_L1",
      "content": "向晚意不适，",
      "imagery": [
        "向晚 (傍晚)"
      ],
      "emotion": [
        "惆怅",
        "烦闷",
        "低沉"
      ],
      "translation": "临近傍晚时分，心情感到不适，",
      "translation_keywords": [
        "临近",
        "傍晚",
        "心情",
        "不适"
      ],
      "explanation": "傍晚时分，诗人感到心情郁闷不适，为全诗定下忧伤的基调。"
    },
    {
      "line_id": "TANG_025_L2",
      "content": "驱车登古原。",
      "imagery": [
        "驱车 (驾车)",
        "古原 (乐游原, 高地)"
      ],
      "emotion": [
        "寻求排解",
        "登高望远"
      ],
      "translation": "于是驾车登上乐游原。",
      "translation_keywords": [
        "驾车",
        "登上",
        "古原"
      ],
      "explanation": "为了排遣心中的烦闷，诗人驾车登上高高的乐游原，希望登高望远能开阔心胸。"
    },
    {
      "line_id": "TANG_025_L3",
      "content": "夕阳无限好，",
      "imagery": [
        "夕阳",
        "无限好 (极美)"
      ],
      "emotion": [
        "赞美",
        "壮丽"
      ],
      "translation": "傍晚的夕阳景色是那样美好，",
      "translation_keywords": [
        "夕阳",
        "无限",
        "美好"
      ],
      "explanation": "登上乐游原，诗人看到了壮丽无比的夕阳景色，发出由衷的赞叹。"
    },
    {
      "line_id": "TANG_025_L4",
      "content": "只是近黄昏。",
      "imagery": [
        "黄昏 (日落时分)"
      ],
      "emotion": [
        "惋惜",
        "惆怅",
        "岁月流逝"
      ],
      "translation": "只是它已经临近黄昏了。",
      "translation_keywords": [
        "只是",
        "临近",
        "黄昏"
      ],
      "explanation": "然而，这无限美好的夕阳终究将逝去，带给诗人无限的惋惜和对美好事物短暂、人生迟暮的感慨。"
    }
  ]
}