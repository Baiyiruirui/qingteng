  ],
  "lines": [
    {
      "line_id": "EXTRA_037_L1",
      "content": "千锤万凿出深山",
      "imagery": [
        "石灰",
        "烈火",
        "清白"
      ],
      "emotion": [
        "咏物",
        "气节"
      ],
      "translation": "石灰石经过千万次锤打和开凿，才从深山里被开采出来。",
      "translation_keywords": [
        "千锤万凿",
        "出",
        "深山"
      ],
      "explanation": "这句写石灰石的开采过程。“千锤万凿”用夸张的手法，强调石灰石经历了无数次的敲打和挖掘，才从深山中出来。这为后文写石灰的坚强品格做了铺垫。"
    },
    {
      "line_id": "EXTRA_037_L2",
      "content": "烈火焚烧若等闲",
      "imagery": [
        "石灰",
        "烈火",
        "清白"
      ],
      "emotion": [
        "咏物",
        "气节"
      ],
      "translation": "面对烈火的焚烧，它却看得像平常事一样。",
      "translation_keywords": [
        "烈火焚烧",
        "若等闲"
      ],
      "explanation": "这句写石灰石被烧成石灰的过程。“烈火焚烧”写出环境的严酷，“若等闲”用拟人手法，把石灰石当作人来写，表现出它面对巨大考验时的从容和镇定。"
    },
    {
      "line_id": "EXTRA_037_L3",
      "content": "粉骨碎身浑不怕",
      "imagery": [
        "石灰",
        "烈火",
        "清白"
      ],
      "emotion": [
        "咏物",
        "气节"
      ],
      "translation": "即使身体被粉碎，也完全不怕。",
      "translation_keywords": [
        "粉骨碎身",
        "浑不怕"
      ],
      "explanation": "这句进一步写石灰的牺牲精神。“粉骨碎身”是夸张的说法，指石灰石被彻底粉碎，“浑不怕”语气坚定，表现出为了理想甘愿付出一切的勇气。"
    },
    {
      "line_id": "EXTRA_037_L4",
      "content": "要留清白在人间",
      "imagery": [
        "石灰",
        "烈火",
        "清白"
      ],
      "emotion": [
        "咏物",
        "气节"
      ],
      "translation": "只想要把清白高洁的品格留在人世间。",
      "translation_keywords": [
        "要留",
        "清白",
        "人间"
      ],
      "explanation": "这句是全诗的主旨，点明石灰的志向。“清白”一语双关，既指石灰洁白的颜色，也象征诗人高尚的品格和正直的节操。诗人借石灰表达自己不畏艰难、坚守清白的人生追求。"
    }
  ]
}
