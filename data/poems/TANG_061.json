  "lines": [
    {
      "line_id": "TANG_061_L1",
      "content": "前不见古人，后不见来者。",
      "imagery": [
        "古人",
        "来者"
      ],
      "emotion": [
        "孤独",
        "苍凉",
        "感慨"
      ],
      "translation": "向前看不到古代的贤君明主，向后也看不到未来的英才俊杰。",
      "translation_keywords": [
        "前不见",
        "古人",
        "后不见",
        "来者"
      ],
      "explanation": "诗人站在幽州台上，放眼四望，时间维度上感叹前不见古之贤人，后不见来之英杰。这是一种极度的孤独感，为全诗奠定了悲凉苍茫的基调。"
    },
    {
      "line_id": "TANG_061_L2",
      "content": "念天地之悠悠，独怆然而涕下。",
      "imagery": [
        "天地",
        "悠悠"
      ],
      "emotion": [
        "悲伤",
        "绝望",
        "孤独",
        "感慨"
      ],
      "translation": "想到天地是如此的广阔和永恒，我独自一人悲伤得眼泪直流。",
      "translation_keywords": [
        "念",
        "天地",
        "悠悠",
        "独",
        "怆然",
        "涕下"
      ],
      "explanation": "面对永恒广阔的天地，诗人感到自身的渺小和人生的短暂，以及怀才不遇的孤独和悲愤。这种深沉的孤独感和悲伤之情，通过“独怆然而涕下”直接表达出来，震撼人心。"
    }
  ]
}