  "lines": [
    {
      "line_id": "TANG_042_L1",
      "content": "风急天高猿啸哀",
      "imagery": [
        "风",
        "天",
        "猿啸"
      ],
      "emotion": [
        "悲凉",
        "高远",
        "凄厉"
      ],
      "translation": "秋风急劲，天空高远，猿猴的哀鸣声声入耳，更添悲凉气氛。",
      "translation_keywords": [
        "风",
        "急促",
        "天",
        "高远",
        "猿",
        "啼叫",
        "悲哀"
      ],
      "explanation": "秋风呼啸，天空显得格外高远，阵阵猿猴的悲鸣更增添了凄凉之感。"
    },
    {
      "line_id": "TANG_042_L2",
      "content": "渚清沙白鸟飞回",
      "imagery": [
        "水渚",
        "沙滩",
        "飞鸟"
      ],
      "emotion": [
        "清新",
        "孤寂",
        "动感"
      ],
      "translation": "江中沙洲清澈，沙滩洁白，水鸟在空中盘旋飞翔。",
      "translation_keywords": [
        "水渚",
        "清澈",
        "沙滩",
        "洁白",
        "鸟",
        "飞回"
      ],
      "explanation": "江中沙洲清澈可见，沙滩洁白耀眼，水鸟在空中盘旋飞翔，却更显出环境的孤寂。"
    },
    {
      "line_id": "TANG_042_L3",
      "content": "无边落木萧萧下",
      "imagery": [
        "落木",
        "萧萧"
      ],
      "emotion": [
        "凋零",
        "衰败",
        "深广"
      ],
      "translation": "望不到边际的树木，枯叶纷纷落下，发出萧萧的声响。",
      "translation_keywords": [
        "无边",
        "落木",
        "萧萧",
        "落下"
      ],
      "explanation": "漫无边际的树木，叶子萧萧而落，一片凋零的景象，渲染了深远的悲凉气氛。"
    },
    {
      "line_id": "TANG_042_L4",
      "content": "不尽长江滚滚来",
      "imagery": [
        "长江",
        "滚滚"
      ],
      "emotion": [
        "浩荡",
        "不息",
        "逝去"
      ],
      "translation": "滔滔不绝的长江之水，滚滚而来，仿佛时间一去不复返。",
      "translation_keywords": [
        "不尽",
        "长江",
        "滚滚",
        "而来"
      ],
      "explanation": "无休无止的长江水，滚滚而来，喻指时光流逝，生命无常。"
    },
    {
      "line_id": "TANG_042_L5",
      "content": "万里悲秋常作客",
      "imagery": [
        "秋",
        "客"
      ],
      "emotion": [
        "悲凉",
        "漂泊",
        "遥远"
      ],
      "translation": "在万里之内，每逢悲凉的秋天，我总是漂泊异乡，身不由己。",
      "translation_keywords": [
        "万里",
        "悲秋",
        "作客",
        "漂泊"
      ],
      "explanation": "万里之内，悲苦的秋天，我却常常漂泊他乡，有家不能回。"
    },
    {
      "line_id": "TANG_042_L6",
      "content": "百年多病独登台",
      "imagery": [
        "登台"
      ],
      "emotion": [
        "衰老",
        "孤独",
        "感慨"
      ],
      "translation": "我一生体弱多病，如今又独自一人登上这高台。",
      "translation_keywords": [
        "百年",
        "多病",
        "独自",
        "登台"
      ],
      "explanation": "一生多病，如今独自登上高台，更觉孤寂无依，感慨万千。"
    },
    {
      "line_id": "TANG_042_L7",
      "content": "艰难苦恨繁霜鬓",
      "imagery": [
        "霜鬓"
      ],
      "emotion": [
        "愁苦",
        "衰老",
        "辛酸"
      ],
      "translation": "困顿的生活，满腔的愁苦和怨恨，让我的两鬓白发增添了许多。",
      "translation_keywords": [
        "艰难",
        "苦恨",
        "繁多",
        "霜鬓",
        "白发"
      ],
      "explanation": "艰难困苦的生活，深重的愁恨，使我的两鬓白发更加繁多。"
    },
    {
      "line_id": "TANG_042_L8",
      "content": "潦倒新停浊酒杯",
      "imagery": [
        "浊酒杯"
      ],
      "emotion": [
        "落魄",
        "无奈",
        "借酒消愁"
      ],
      "translation": "穷困潦倒，生活困顿，就连杯中的浊酒也因病痛而不得不停饮了。",
      "translation_keywords": [
        "潦倒",
        "停",
        "浊酒",
        "借酒消愁"
      ],
      "explanation": "生活潦倒困顿，刚刚又因病停止饮酒，面对浊酒杯更显无奈与悲凉。"
    }
  ]
}