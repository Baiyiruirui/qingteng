{
  "poem_id": "EXTRA_014",
  "title": "枫桥夜泊",
  "author": "张继",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "羁旅",
    "秋夜"
  ],
  "imagery": [
    "月落",
    "江枫",
    "钟声"
  ],
  "rhetoric": [
    "借景抒情",
    "以动衬静",
    "对仗"
  ],
  "lines": [
    {
      "line_id": "EXTRA_014_L1",
      "content": "月落乌啼霜满天",
      "imagery": [
        "月落",
        "江枫",
        "钟声"
      ],
      "emotion": [
        "羁旅",
        "秋夜"
      ],
      "translation": "月亮落下去了，乌鸦啼叫，秋霜布满了天空。",
      "translation_keywords": [
        "月落",
        "乌啼",
        "霜满天"
      ],
      "explanation": "这句诗描写了深夜的景色：月亮西沉，乌鸦啼叫，寒气弥漫，霜气仿佛充满了天地。诗人用“月落”“乌啼”“霜满天”三个意象，营造出一种清冷、寂静的氛围，为全诗奠定了孤寂的基调。"
    },
    {
      "line_id": "EXTRA_014_L2",
      "content": "江枫渔火对愁眠",
      "imagery": [
        "月落",
        "江枫",
        "钟声"
      ],
      "emotion": [
        "羁旅",
        "秋夜"
      ],
      "translation": "江边的枫树和渔船上的灯火，陪伴着愁苦而眠的我。",
      "translation_keywords": [
        "江枫",
        "渔火",
        "对愁眠"
      ],
      "explanation": "诗人对着江边的枫树和渔船上的灯火，满怀愁绪，难以入眠。“江枫”和“渔火”是眼前景物，一个静一个动，相互映衬。“对愁眠”三字直接点出诗人的心情，将景物与情感融为一体，表达出漂泊在外的孤独与忧愁。"
    },
    {
      "line_id": "EXTRA_014_L3",
      "content": "姑苏城外寒山寺",
      "imagery": [
        "月落",
        "江枫",
        "钟声"
      ],
      "emotion": [
        "羁旅",
        "秋夜"
      ],
      "translation": "苏州城外的寒山寺，",
      "translation_keywords": [
        "姑苏城外",
        "寒山寺"
      ],
      "explanation": "这句点明了地点——姑苏（苏州）城外的寒山寺。寒山寺是一座古寺，名字本身就带有清冷、幽静的感觉，为下一句的钟声做了铺垫。"
    },
    {
      "line_id": "EXTRA_014_L4",
      "content": "夜半钟声到客船",
      "imagery": [
        "月落",
        "江枫",
        "钟声"
      ],
      "emotion": [
        "羁旅",
        "秋夜"
      ],
      "translation": "半夜里敲响的钟声传到了我乘坐的客船上。",
      "translation_keywords": [
        "夜半",
        "钟声",
        "客船"
      ],
      "explanation": "半夜时分，寒山寺的钟声悠悠传来，打破了夜的寂静，也传到了诗人所在的客船上。这句以动衬静，用钟声反衬出深夜的宁静，同时也让诗人的愁绪更加深沉。钟声仿佛敲在心上，让孤独的旅人倍感凄凉。"
    }
  ]
}
