  "lines": [
    {
      "line_id": "TANG_056_L1",
      "content": "一封朝奏九重天，夕贬潮州路八千。",
      "imagery": [
        "九重天",
        "潮州",
        "路八千"
      ],
      "emotion": [
        "愤慨",
        "无奈",
        "迅速"
      ],
      "translation": "早晨写了一封奏章呈给皇帝，晚上就被贬到八千里外的潮州。",
      "translation_keywords": [
        "一封",
        "朝奏",
        "九重天",
        "夕贬",
        "潮州",
        "路八千"
      ],
      "explanation": "首联以极度夸张的手法，突出贬官速度之快、距离之远，表现了诗人内心的愤懑与无奈。"
    },
    {
      "line_id": "TANG_056_L2",
      "content": "欲为圣明除弊事，肯将衰朽惜残年！",
      "imagery": [
        "圣明",
        "弊事",
        "衰朽",
        "残年"
      ],
      "emotion": [
        "忠贞",
        "无悔",
        "奉献"
      ],
      "translation": "我本想为英明的君主清除弊政，难道会因为年老体衰就爱惜自己的余生吗？",
      "translation_keywords": [
        "欲为",
        "圣明",
        "除弊事",
        "肯将",
        "衰朽",
        "惜残年"
      ],
      "explanation": "颔联直抒胸臆，表明自己冒死上奏是为了国家，虽被贬仍无悔意，展现了忠君报国的坚定信念。"
    },
    {
      "line_id": "TANG_056_L3",
      "content": "云横秦岭家何在？雪拥蓝关马不前。",
      "imagery": [
        "云横秦岭",
        "家",
        "雪拥蓝关",
        "马"
      ],
      "emotion": [
        "迷茫",
        "困顿",
        "思家"
      ],
      "translation": "白云横亘在秦岭之上，我的家在哪里？大雪堵塞了蓝关，马也无法前行。",
      "translation_keywords": [
        "云横",
        "秦岭",
        "家何在",
        "雪拥",
        "蓝关",
        "马不前"
      ],
      "explanation": "颈联以实景描写衬托内心的凄凉与困境。秦岭横亘，家乡遥远；大雪封关，前路受阻，诗人身心俱疲。"
    },
    {
      "line_id": "TANG_056_L4",
      "content": "知汝远来应有意，好收吾骨瘴江边。",
      "imagery": [
        "骨",
        "瘴江"
      ],
      "emotion": [
        "托付",
        "悲壮",
        "赴死"
      ],
      "translation": "知道你从远方赶来应该是有情有义，就好好地把我的尸骨收敛在瘴气弥漫的潮州江边吧。",
      "translation_keywords": [
        "知汝",
        "远来",
        "应有意",
        "好收",
        "吾骨",
        "瘴江边"
      ],
      "explanation": "尾联转向侄孙韩湘，交代后事，语气沉重悲壮，表达了对前途的绝望和对亲情的依赖，也暗示了南方环境的恶劣和此行凶多吉少。"
    }
  ]
