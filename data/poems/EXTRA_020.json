{
  "poem_id": "EXTRA_020",
  "title": "悯农其一",
  "author": "李绅",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "劳动",
    "民生"
  ],
  "imagery": [
    "春种",
    "秋收",
    "农夫"
  ],
  "rhetoric": [
    "对比",
    "夸张"
  ],
  "lines": [
    {
      "line_id": "EXTRA_020_L1",
      "content": "春种一粒粟",
      "imagery": [
        "春种",
        "秋收",
        "农夫"
      ],
      "emotion": [
        "劳动",
        "民生"
      ],
      "translation": "春天种下一粒种子。",
      "translation_keywords": [
        "春天",
        "种下",
        "一粒",
        "种子"
      ],
      "explanation": "这句写农民在春天播种，用“一粒”和后面的“万颗”形成对比，突出收获的丰硕，也暗示了劳动的艰辛。"
    },
    {
      "line_id": "EXTRA_020_L2",
      "content": "秋收万颗子",
      "imagery": [
        "春种",
        "秋收",
        "农夫"
      ],
      "emotion": [
        "劳动",
        "民生"
      ],
      "translation": "秋天收获万颗粮食。",
      "translation_keywords": [
        "秋天",
        "收获",
        "万颗",
        "粮食"
      ],
      "explanation": "这句写秋天的大丰收，“万颗”是夸张手法，形容收成极好，与第一句的“一粒”形成强烈对比，表现劳动成果的丰硕。"
    },
    {
      "line_id": "EXTRA_020_L3",
      "content": "四海无闲田",
      "imagery": [
        "春种",
        "秋收",
        "农夫"
      ],
      "emotion": [
        "劳动",
        "民生"
      ],
      "translation": "天下没有荒废的田地。",
      "translation_keywords": [
        "天下",
        "没有",
        "荒废",
        "田地"
      ],
      "explanation": "这句写全国的土地都被耕种，没有闲置，“四海”指天下，强调农民辛勤劳作，土地利用率高，为下一句的悲剧做铺垫。"
    },
    {
      "line_id": "EXTRA_020_L4",
      "content": "农夫犹饿死",
      "imagery": [
        "春种",
        "秋收",
        "农夫"
      ],
      "emotion": [
        "劳动",
        "民生"
      ],
      "translation": "农民却还是饿死了。",
      "translation_keywords": [
        "农民",
        "仍然",
        "饿死"
      ],
      "explanation": "这句是诗的核心，用“犹”字转折，前面写丰收和遍地良田，这里却写农民饿死，形成强烈对比，揭露了社会的不公，表达对农民的同情。"
    }
  ]
}
