{
  "poem_id": "TANG_023",
  "title": "九月九日忆山东兄弟",
  "author": "王维",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "思乡",
    "亲情",
    "重阳节",
    "节日思念"
  ],
  "imagery": [
    "异乡",
    "佳节",
    "兄弟",
    "茱萸",
    "登高"
  ],
  "rhetoric": [
    "借景抒情",
    "设问",
    "对比",
    "直抒胸臆"
  ],
  "lines": [
    {
      "line_id": "TANG_023_L1",
      "content": "独在异乡为异客，",
      "imagery": [
        "异乡",
        "异客 (他乡的客人)"
      ],
      "emotion": [
        "孤独",
        "漂泊",
        "悲凉"
      ],
      "translation": "我独自一人在他乡作异地的客人，",
      "translation_keywords": [
        "独自",
        "异乡",
        "异客"
      ],
      "explanation": "诗人独自一人漂泊在外地，作他乡的客人，点明了背景，基调略显孤寂。"
    },
    {
      "line_id": "TANG_023_L2",
      "content": "每逢佳节倍思亲。",
      "imagery": [
        "佳节 (美好的节日)",
        "亲 (亲人)"
      ],
      "emotion": [
        "思念",
        "伤感",
        "亲情"
      ],
      "translation": "每当遇到美好的节日，思念亲人的心情就加倍强烈。",
      "translation_keywords": [
        "每逢",
        "佳节",
        "倍加",
        "思念",
        "亲人"
      ],
      "explanation": "每到佳节，诗人对亲人的思念之情就更加浓烈，表达了普遍的情感。"
    },
    {
      "line_id": "TANG_023_L3",
      "content": "遥知兄弟登高处，",
      "imagery": [
        "兄弟",
        "登高 (重阳节习俗)",
        "茱萸 (传统节日佩戴的植物)"
      ],
      "emotion": [
        "想象",
        "遗憾",
        "牵挂"
      ],
      "translation": "遥想兄弟们在登高的地方，",
      "translation_keywords": [
        "遥想",
        "兄弟",
        "登高之处"
      ],
      "explanation": "诗人遥远地想象兄弟们在重阳节登高饮宴的情景。"
    },
    {
      "line_id": "TANG_023_L4",
      "content": "遍插茱萸少一人。",
      "imagery": [
        "茱萸",
        "少一人 (缺少我)"
      ],
      "emotion": [
        "惆怅",
        "孤寂",
        "遗憾"
      ],
      "translation": "大家头上都插满了茱萸，却唯独少了我一人。",
      "translation_keywords": [
        "遍插",
        "茱萸",
        "缺少",
        "一人"
      ],
      "explanation": "诗人想象家人都佩戴茱萸，唯独少了自己，更增添了思乡的愁绪和对不能团聚的遗憾。"
    }
  ]
}