    "年华",
    "庄生梦蝶",
    "望帝春心",
    "沧海月明珠有泪",
    "蓝田日暖玉生烟",
    "惘然"
  ],
  "rhetoric": [
    "比喻",
    "典故",
    "象征",
    "对偶",
    "意象叠加",
    "疑问"
  ],
  "lines": [
    {
      "line_id": "TANG_027_L1",
      "content": "锦瑟无端五十弦，",
      "imagery": [
        "锦瑟 (华美的瑟)",
        "五十弦"
      ],
      "emotion": [
        "迷惘",
        "愁绪"
      ],
      "translation": "华美的锦瑟为何平白无故有五十根弦，",
      "translation_keywords": [
        "锦瑟",
        "为何",
        "五十弦"
      ],
      "explanation": "开篇即用疑问句，引出锦瑟的弦数过多，暗示生命中的烦恼和无法解开的谜团，为全诗的迷离奠定基调。"
    },
    {
      "line_id": "TANG_027_L2",
      "content": "一弦一柱思华年。",
      "imagery": [
        "弦",
        "柱",
        "华年 (美好青春)"
      ],
      "emotion": [
        "追忆",
        "惆怅",
        "惋惜"
      ],
      "translation": "每一根弦、每一根柱都勾起我对美好青春年华的思念。",
      "translation_keywords": [
        "每一根弦",
        "每一根柱",
        "思念",
        "华年"
      ],
      "explanation": "每一弦每一柱都引发诗人对美好青春年华的追忆与伤感。"
    },
    {
      "line_id": "TANG_027_L3",
      "content": "庄生晓梦迷蝴蝶，",
      "imagery": [
        "庄生 (庄子)",
        "晓梦 (清晨的梦)",
        "蝴蝶"
      ],
      "emotion": [
        "虚幻",
        "迷惘",
        "人生如梦"
      ],
      "translation": "庄周在清晨的梦中，梦见了自己变成了蝴蝶，",
      "translation_keywords": [
        "庄子",
        "清晨",
        "梦",
        "迷",
        "蝴蝶"
      ],
      "explanation": "引用庄周梦蝶的典故，比喻人生的虚幻与迷惘，真假难辨，亦喻指对逝去爱情的追忆如梦幻泡影。"
    },
    {
      "line_id": "TANG_027_L4",
      "content": "望帝春心托杜鹃。",
      "imagery": [
        "望帝 (古蜀帝王)",
        "春心",
        "杜鹃 (鸟, 啼血)"
      ],
      "emotion": [
        "愁苦",
        "哀怨",
        "忠贞"
      ],
      "translation": "望帝的春心寄托在杜鹃鸟身上，它啼血哀鸣。",
      "translation_keywords": [
        "望帝",
        "春心",
        "寄托",
        "杜鹃"
      ],
      "explanation": "引用望帝化杜鹃的典故，杜鹃啼血，哀怨凄苦，象征着诗人对逝去爱情的深沉哀伤与执着。"
    },
    {
      "line_id": "TANG_027_L5",
      "content": "沧海月明珠有泪，",
      "imagery": [
        "沧海 (大海)",
        "月明 (月光皎洁)",
        "珠 (珍珠)",
        "泪 (泪水)"
      ],
      "emotion": [
        "悲凉",
        "晶莹",
        "难以言说"
      ],
      "translation": "大海上明月皎洁，鲛人流下的珍珠晶莹如泪。",
      "translation_keywords": [
        "大海",
        "月明",
        "珍珠",
        "泪"
      ],
      "explanation": "引用鲛人泣珠的典故，比喻珍贵美好的事物都伴随着忧伤，或指逝去的爱情留下的晶莹却悲伤的回忆。"
    },
    {
      "line_id": "TANG_027_L6",
      "content": "蓝田日暖玉生烟。",
      "imagery": [
        "蓝田 (地名, 产玉)",
        "日暖 (阳光温暖)",
        "玉生烟 (玉石生烟)"
      ],
      "emotion": [
        "美好",
        "朦胧",
        "虚无"
      ],
      "translation": "蓝田山在阳光温暖下，美玉仿佛生出缕缕轻烟。",
      "translation_keywords": [
        "蓝田",
        "日暖",
        "玉",
        "生",
        "烟"
      ],
      "explanation": "引用蓝田生玉的典故，比喻美好的事物带着一种朦胧虚幻之美，可望而不可即，难以把握。"
    },
    {
      "line_id": "TANG_027_L7",
      "content": "此情可待成追忆，",
      "imagery": [
        "情 (感情)",
        "追忆 (回忆)"
      ],
      "emotion": [
        "惋惜",
        "无奈",
        "徒劳"
      ],
      "translation": "这段感情只能等到将来成为追忆，",
      "translation_keywords": [
        "这份情",
        "只能",
        "等到",
        "成为",
        "追忆"
      ],
      "explanation": "诗人发出疑问，难道所有的感情都只能等到将来再去追忆吗？暗示对当下感情的珍视和对未来失去的担忧。"
    },
    {
      "line_id": "TANG_027_L8",
      "content": "只是当时已惘然。",
      "imagery": [
        "当时",
        "惘然 (迷茫失落)"
      ],
      "emotion": [
        "迷惘",
        "怅然",
        "困惑"
      ],
      "translation": "只是在当时就感到迷茫和失落了。",
      "translation_keywords": [
        "只是",
        "当时",
        "已经",
        "迷茫"
      ],
      "explanation": "最是点睛之笔，道出诗人在感情发生时就已感到迷惘不解，如今追忆更是徒增怅惘，表达了深沉的人生感慨和情感困惑。"
    }
  ]
}