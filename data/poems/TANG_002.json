  "lines": [
    {
      "line_id": "TANG_002_L1",
      "content": "春眠不觉晓",
      "imagery": [
        "春眠"
      ],
      "emotion": [
        "闲适",
        "慵懒",
        "舒适"
      ],
      "translation": "春天的夜晚睡得很香甜，不知不觉天已亮了。",
      "translation_keywords": [
        "春眠",
        "香甜",
        "不觉",
        "天亮"
      ],
      "explanation": "首句点明时节“春”，写诗人酣睡之态，一觉醒来已是天光大亮。一个“不觉”字，形象地表现出春夜的宁静与温暖，也烘托了诗人此时身心的放松与闲适。"
    },
    {
      "line_id": "TANG_002_L2",
      "content": "处处闻啼鸟",
      "imagery": [
        "啼鸟"
      ],
      "emotion": [
        "生机",
        "喜悦",
        "自然"
      ],
      "translation": "醒来之后，耳边传来的是到处都有鸟儿的啼叫声。",
      "translation_keywords": [
        "醒来",
        "耳边",
        "到处",
        "鸟啼声"
      ],
      "explanation": "诗人从沉睡中醒来，首先映入耳帘的是此起彼伏的鸟叫声。这鸟鸣不仅打破了清晨的寂静，更渲染出春天的勃勃生机，使人感受到春天的清新与活力。一个“处处”表明鸟儿欢快的叫声充满整个空间。"
    },
    {
      "line_id": "TANG_002_L3",
      "content": "夜来风雨声",
      "imagery": [
        "风雨声"
      ],
      "emotion": [
        "回忆",
        "隐忧"
      ],
      "translation": "回想起昨夜，似乎听到了风声雨声。",
      "translation_keywords": [
        "回想",
        "昨夜",
        "风声",
        "雨声"
      ],
      "explanation": "诗人从清晨的美景和鸟语中，联想到昨夜的情形。虽然“不觉晓”说明昨夜睡得沉，但清醒后，隐约回忆起风雨声，这为下一句的惜春之情埋下伏笔。"
    },
    {
      "line_id": "TANG_002_L4",
      "content": "花落知多少",
      "imagery": [
        "落花"
      ],
      "emotion": [
        "惜春",
        "怜惜",
        "惆怅",
        "疑问"
      ],
      "translation": "不知道有多少花儿被风雨打落了呢？",
      "translation_keywords": [
        "不知道",
        "多少",
        "花儿",
        "打落"
      ],
      "explanation": "结句以设问的形式，表达了诗人对春花的怜惜和对春光流逝的怅惘。“知多少”是明知故问，暗示了诗人对春色逝去的担忧和感叹，将惜春之情推向高潮，含蓄而深远，余韵无穷。"
    }
  ]
}