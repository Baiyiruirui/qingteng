{
  "poem_id": "EXTRA_028",
  "title": "元日",
  "author": "王安石",
  "dynasty": "宋",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "节日",
    "新年"
  ],
  "imagery": [
    "爆竹",
    "春风",
    "桃符"
  ],
  "rhetoric": [
    "借代",
    "象征"
  ],
  "lines": [
    {
      "line_id": "EXTRA_028_L1",
      "content": "爆竹声中一岁除",
      "imagery": [
        "爆竹",
        "春风",
        "桃符"
      ],
      "emotion": [
        "节日",
        "新年"
      ],
      "translation": "在噼里啪啦的爆竹声中，旧的一年过去了。",
      "translation_keywords": [
        "爆竹声",
        "一岁",
        "除"
      ],
      "explanation": "这句写新年到来的热闹场景。用“爆竹声”点明春节，以声音烘托喜庆气氛。“一岁除”直接点出辞旧，让人感受到时间更替的欢快。"
    },
    {
      "line_id": "EXTRA_028_L2",
      "content": "春风送暖入屠苏",
      "imagery": [
        "爆竹",
        "春风",
        "桃符"
      ],
      "emotion": [
        "节日",
        "新年"
      ],
      "translation": "温暖的春风吹来了，人们开怀畅饮屠苏酒。",
      "translation_keywords": [
        "春风",
        "送暖",
        "屠苏"
      ],
      "explanation": "春风和屠苏酒都是春节的典型意象。春风带来暖意，象征新一年的生机；饮屠苏酒是古人过年驱邪祈福的习俗，这句写出人们享受节日温暖与欢乐。"
    },
    {
      "line_id": "EXTRA_028_L3",
      "content": "千门万户曈曈日",
      "imagery": [
        "爆竹",
        "春风",
        "桃符"
      ],
      "emotion": [
        "节日",
        "新年"
      ],
      "translation": "初升的太阳照耀着千家万户，到处亮堂堂的。",
      "translation_keywords": [
        "千门万户",
        "曈曈日"
      ],
      "explanation": "“曈曈日”形容太阳初升时光明灿烂的样子，照遍千家万户，展现新年早晨的明亮与希望。这句从家庭扩展到整个社会，写出普天同庆的节日氛围。"
    },
    {
      "line_id": "EXTRA_028_L4",
      "content": "总把新桃换旧符",
      "imagery": [
        "爆竹",
        "春风",
        "桃符"
      ],
      "emotion": [
        "节日",
        "新年"
      ],
      "translation": "家家户户都忙着把旧桃符换成新的桃符。",
      "translation_keywords": [
        "新桃",
        "旧符",
        "换"
      ],
      "explanation": "“桃符”是古人挂在门上的木板，用来驱邪，过年时换新。这句用“新桃换旧符”象征除旧布新，表达人们对新年的美好期盼，也点出春节最重要的习俗之一。"
    }
  ]
}
