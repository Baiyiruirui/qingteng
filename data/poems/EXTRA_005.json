{
  "poem_id": "EXTRA_005",
  "title": "风",
  "author": "李峤",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "自然",
    "物候"
  ],
  "imagery": [
    "秋叶",
    "春花",
    "江浪",
    "竹林"
  ],
  "rhetoric": [
    "对仗",
    "夸张",
    "拟人"
  ],
  "lines": [
    {
      "line_id": "EXTRA_005_L1",
      "content": "解落三秋叶",
      "imagery": [
        "秋叶",
        "春花",
        "江浪",
        "竹林"
      ],
      "emotion": [
        "自然",
        "物候"
      ],
      "translation": "风吹落了秋天的树叶。",
      "translation_keywords": [
        "吹落",
        "秋天",
        "树叶"
      ],
      "explanation": "这句写风能使秋天的叶子飘落，用“解落”一词把风拟人化，好像风有意识、有力量，突出了风在秋天的萧瑟作用。"
    },
    {
      "line_id": "EXTRA_005_L2",
      "content": "能开二月花",
      "imagery": [
        "秋叶",
        "春花",
        "江浪",
        "竹林"
      ],
      "emotion": [
        "自然",
        "物候"
      ],
      "translation": "风能吹开二月的鲜花。",
      "translation_keywords": [
        "吹开",
        "二月",
        "鲜花"
      ],
      "explanation": "这句写风又能让春天的花朵绽放，与上一句形成对比，一落一开，展现了风既能带来凋零也能带来生机的两面性。"
    },
    {
      "line_id": "EXTRA_005_L3",
      "content": "过江千尺浪",
      "imagery": [
        "秋叶",
        "春花",
        "江浪",
        "竹林"
      ],
      "emotion": [
        "自然",
        "物候"
      ],
      "translation": "风吹过江面，掀起千尺高的巨浪。",
      "translation_keywords": [
        "过江",
        "千尺",
        "浪"
      ],
      "explanation": "用“千尺”夸张地描写风在水上的威力，让读者想象出江涛汹涌的画面，突出风的强劲。"
    },
    {
      "line_id": "EXTRA_005_L4",
      "content": "入竹万竿斜",
      "imagery": [
        "秋叶",
        "春花",
        "江浪",
        "竹林"
      ],
      "emotion": [
        "自然",
        "物候"
      ],
      "translation": "风吹进竹林，使万竿竹子都倾斜了。",
      "translation_keywords": [
        "入竹",
        "万竿",
        "斜"
      ],
      "explanation": "“万竿”极言竹子之多，“斜”字生动写出风过时竹子一齐倾斜的动态，画面感强，再次表现风的力量。"
    }
  ]
}
