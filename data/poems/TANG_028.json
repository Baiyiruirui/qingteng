{
  "poem_id": "TANG_028",
  "title": "题破山寺后禅院",
  "author": "常建",
  "dynasty": "唐",
  "grade": "中学",
  "text_type": "律诗",
  "themes": [
    "隐逸",
    "禅意",
    "宁静",
    "幽深",
    "探幽"
  ],
  "imagery": [
    "清晨",
    "古寺",
    "曲径",
    "禅房",
    "竹",
    "树",
    "山光",
    "鸟",
    "潭影",
    "钟磬"
  ],
  "rhetoric": [
    "借景抒情",
    "白描",
    "动静结合",
    "拟人",
    "对比"
  ],
  "lines": [
    {
      "line_id": "TANG_028_L1",
      "content": "清晨入古寺，",
      "imagery": [
        "清晨",
        "古寺"
      ],
      "emotion": [
        "肃穆",
        "探访",
        "宁静"
      ],
      "translation": "清晨时分，我走进这座古老的寺庙，",
      "translation_keywords": [
        "清晨",
        "进入",
        "古老",
        "寺庙"
      ],
      "explanation": "诗人清晨走进古寺，点明时间和地点，营造出一种清幽肃穆的氛围。"
    },
    {
      "line_id": "TANG_028_L2",
      "content": "初日照高林。",
      "imagery": [
        "初日 (初升的太阳)",
        "高林 (高大的树林)"
      ],
      "emotion": [
        "明亮",
        "希望",
        "生机"
      ],
      "translation": "旭日初升，阳光照耀着高大的树林。",
      "translation_keywords": [
        "初升",
        "太阳",
        "照耀",
        "高大",
        "树林"
      ],
      "explanation": "初升的阳光透过高大的树林，景色明朗，富有生机。"
    },
    {
      "line_id": "TANG_028_L3",
      "content": "曲径通幽处，",
      "imagery": [
        "曲径 (弯曲的小路)",
        "幽处 (幽深的地方)"
      ],
      "emotion": [
        "探寻",
        "神秘",
        "幽静"
      ],
      "translation": "弯曲的小路通向幽静之处，",
      "translation_keywords": [
        "弯曲",
        "小路",
        "通向",
        "幽静",
        "地方"
      ],
      "explanation": "弯曲的小路蜿蜒伸向幽深之处，引人入胜，暗示诗人将深入探访。"
    },
    {
      "line_id": "TANG_028_L4",
      "content": "禅房花木深。",
      "imagery": [
        "禅房 (僧人修行的居所)",
        "花木深 (花草树木茂盛)"
      ],
      "emotion": [
        "隐秘",
        "清雅",
        "寂静"
      ],
      "translation": "禅房掩映在茂密的花草树木深处。",
      "translation_keywords": [
        "禅房",
        "花草树木",
        "茂密",
        "深处"
      ],
      "explanation": "禅房被茂密的花草树木掩映，更显其幽静与隐秘，透露出禅意。"
    },
    {
      "line_id": "TANG_028_L5",
      "content": "山光悦鸟性，",
      "imagery": [
        "山光 (山景)",
        "鸟性 (鸟儿的天性)"
      ],
      "emotion": [
        "喜悦",
        "自由",
        "自然和谐"
      ],
      "translation": "山中的景色使鸟儿感到欢悦自在，",
      "translation_keywords": [
        "山景",
        "使",
        "鸟儿",
        "欢悦",
        "自在"
      ],
      "explanation": "山中的美景让鸟儿自由自在地飞翔鸣叫，体现了自然的和谐与生机。"
    },
    {
      "line_id": "TANG_028_L6",
      "content": "潭影空人心。",
      "imagery": [
        "潭影 (潭水的倒影)",
        "人心 (人的内心)"
      ],
      "emotion": [
        "澄澈",
        "宁静",
        "空灵",
        "超脱"
      ],
      "translation": "潭水的倒影使人的内心变得空明澄澈。",
      "translation_keywords": [
        "潭水",
        "倒影",
        "使",
        "人",
        "内心",
        "空明"
      ],
      "explanation": "潭水清澈见底，倒影映照，使人内心澄净，达到空灵超脱的境界，富有禅意。"
    },
    {
      "line_id": "TANG_028_L7",
      "content": "万籁此都寂，",
      "imagery": [
        "万籁 (大自然各种声音)",
        "寂 (寂静)"
      ],
      "emotion": [
        "极致宁静",
        "肃穆"
      ],
      "translation": "所有的声音都在这里归于沉寂，",
      "translation_keywords": [
        "所有",
        "声音",
        "都",
        "这里",
        "寂静"
      ],
      "explanation": "周遭的一切声音都归于沉寂，突出了禅院的极致宁静。"
    },
    {
      "line_id": "TANG_028_L8",
      "content": "惟闻钟磬音。",
      "imagery": [
        "钟磬 (寺庙的乐器)"
      ],
      "emotion": [
        "庄严",
        "悠远",
        "神圣"
      ],
      "translation": "只有听到钟磬的声响。",
      "translation_keywords": [
        "只有",
        "听到",
        "钟磬",
        "声音"
      ],
      "explanation": "只有悠扬的钟磬之声回荡，反而衬托出环境的更加寂静和寺院的庄严，将禅意推向高潮。"
    }
  ]
}