{
  "poem_id": "EXTRA_030",
  "title": "题西林壁",
  "author": "苏轼",
  "dynasty": "宋",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "哲理",
    "山水"
  ],
  "imagery": [
    "庐山",
    "山峰"
  ],
  "rhetoric": [
    "比喻",
    "对偶"
  ],
  "lines": [
    {
      "line_id": "EXTRA_030_L1",
      "content": "横看成岭侧成峰",
      "imagery": [
        "庐山",
        "山峰"
      ],
      "emotion": [
        "哲理",
        "山水"
      ],
      "translation": "从正面看，庐山是连绵的山岭；从侧面看，它又变成了陡峭的山峰。",
      "translation_keywords": [
        "横看",
        "岭",
        "侧看",
        "峰"
      ],
      "explanation": "这句诗写出了观察庐山时，因为角度不同，看到的景象也完全不同。诗人用“岭”和“峰”两个具体的形象，生动地表现了山形的变化，也暗示了看问题要换角度。"
    },
    {
      "line_id": "EXTRA_030_L2",
      "content": "远近高低各不同",
      "imagery": [
        "庐山",
        "山峰"
      ],
      "emotion": [
        "哲理",
        "山水"
      ],
      "translation": "从远处、近处、高处、低处看，庐山的景色都各不相同。",
      "translation_keywords": [
        "远近",
        "高低",
        "不同"
      ],
      "explanation": "这句进一步说明，不仅左右看不同，远近高低看也各有特色。诗人用“各不同”三个字，强调了观察位置的变化会带来完全不同的感受，为后面的哲理做铺垫。"
    },
    {
      "line_id": "EXTRA_030_L3",
      "content": "不识庐山真面目",
      "imagery": [
        "庐山",
        "山峰"
      ],
      "emotion": [
        "哲理",
        "山水"
      ],
      "translation": "我之所以认不清庐山真正的样子，",
      "translation_keywords": [
        "不识",
        "真面目"
      ],
      "explanation": "这句诗提出了一个疑问：为什么看不清庐山的全貌？诗人用“真面目”一词，既指山的真实样貌，也暗指事物的本质。语气中带着困惑和思考。"
    },
    {
      "line_id": "EXTRA_030_L4",
      "content": "只缘身在此山中",
      "imagery": [
        "庐山",
        "山峰"
      ],
      "emotion": [
        "哲理",
        "山水"
      ],
      "translation": "只因为我正身处在庐山之中。",
      "translation_keywords": [
        "只缘",
        "身",
        "此山中"
      ],
      "explanation": "这句诗回答了前面的疑问：因为自己就在山里面，所以看不到山的全貌。诗人用“只缘”一词点明原因，揭示了一个深刻的道理：当局者迷，旁观者清。整首诗由写景上升到哲理，启发我们要跳出局限，全面看问题。"
    }
  ]
}
