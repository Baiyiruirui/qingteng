  "imagery": [
    "飞花",
    "东风",
    "御柳",
    "蜡烛",
    "轻烟",
    "汉宫",
    "五侯家"
  ],
  "rhetoric": [
    "借代",
    "对比",
    "烘托"
  ],
  "lines": [
    {
      "line_id": "TANG_099_L1",
      "content": "春城无处不飞花，",
      "imagery": [
        "春城",
        "飞花"
      ],
      "emotion": [
        "春意盎然",
        "纷乱"
      ],
      "translation": "春天的京城里到处都是飘飞的落花。",
      "translation_keywords": [
        "春城",
        "无处不飞花"
      ],
      "explanation": "描绘了寒食节时长安城内繁盛却又带着一丝飘零感的春景，为节日气氛奠定背景。"
    },
    {
      "line_id": "TANG_099_L2",
      "content": "寒食东风御柳斜。",
      "imagery": [
        "寒食",
        "东风",
        "御柳"
      ],
      "emotion": [
        "节日的宁静",
        "柳枝摇曳"
      ],
      "translation": "寒食节的春风中，皇宫里的垂柳摇曳生姿。",
      "translation_keywords": [
        "寒食",
        "东风",
        "御柳斜"
      ],
      "explanation": "点明了节日名称“寒食”，并借由春风中摇曳的皇宫柳树，进一步描绘京城特有的春日景象。"
    },
    {
      "line_id": "TANG_099_L3",
      "content": "日暮汉宫传蜡烛，",
      "imagery": [
        "日暮",
        "汉宫",
        "蜡烛"
      ],
      "emotion": [
        "特权",
        "宫廷生活"
      ],
      "translation": "傍晚时分，皇宫中特许点燃的蜡烛被传递出来。",
      "translation_keywords": [
        "日暮",
        "汉宫",
        "传蜡烛"
      ],
      "explanation": "寒食节禁火，但皇帝可以特赐火焰，这里指傍晚时分皇宫特许点火，并把烛火传递出去，彰显皇权。"
    },
    {
      "line_id": "TANG_099_L4",
      "content": "轻烟散入五侯家。",
      "imagery": [
        "轻烟",
        "五侯家"
      ],
      "emotion": [
        "特权",
        "不公",
        "奢华"
      ],
      "translation": "那些轻柔的烛烟，散入了五侯贵族的家中。",
      "translation_keywords": [
        "轻烟",
        "散入",
        "五侯家"
      ],
      "explanation": "那些从宫中传出的火种，最终流向了贵族豪门之家，讽刺了寒食节禁火规定的不公，以及贵族特权和奢靡的生活。"
    }
  ]
}