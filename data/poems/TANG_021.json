  "imagery": [
    "渭城朝雨",
    "客舍青青柳色",
    "酒",
    "阳关"
  ],
  "rhetoric": [
    "借景抒情",
    "虚实结合",
    "对比",
    "烘托",
    "渲染"
  ],
  "lines": [
    {
      "line_id": "TANG_021_L1",
      "content": "渭城朝雨浥轻尘",
      "imagery": [
        "渭城",
        "朝雨",
        "轻尘"
      ],
      "emotion": [
        "清冷",
        "惆怅"
      ],
      "translation": "渭城的清晨，细雨沾湿了地面的轻尘。",
      "translation_keywords": [
        "渭城",
        "朝雨",
        "沾湿",
        "轻尘"
      ],
      "explanation": "首句交代了送别的时间、地点和环境。清晨的雨水润湿了尘土，使空气清新，却也带有一丝清冷和朦胧的离愁，为离别烘托了气氛。"
    },
    {
      "line_id": "TANG_021_L2",
      "content": "客舍青青柳色新",
      "imagery": [
        "客舍",
        "青青柳色"
      ],
      "emotion": [
        "惜别",
        "依恋"
      ],
      "translation": "客栈旁的柳树在雨水洗涤后，显得格外青翠鲜亮。",
      "translation_keywords": [
        "客舍",
        "青青",
        "柳色",
        "新"
      ],
      "explanation": "“柳”与“留”谐音，自古就是送别的象征。雨后柳色更新，虽有生机盎然之美，却也反衬了离人的哀伤，暗示了依依不舍的惜别之情。"
    },
    {
      "line_id": "TANG_021_L3",
      "content": "劝君更尽一杯酒",
      "imagery": [
        "酒"
      ],
      "emotion": [
        "珍重",
        "不舍",
        "深情"
      ],
      "translation": "我劝你再喝干这一杯酒吧！",
      "translation_keywords": [
        "劝",
        "君",
        "更尽",
        "一杯酒"
      ],
      "explanation": "诗人直抒胸臆，以深情劝酒，这杯酒中凝聚着对友人深厚的惜别之情和无限的祝愿，是对即将远行朋友的体贴与关怀。"
    },
    {
      "line_id": "TANG_021_L4",
      "content": "西出阳关无故人",
      "imagery": [
        "阳关",
        "故人"
      ],
      "emotion": [
        "孤寂",
        "担忧",
        "惆怅"
      ],
      "translation": "因为你往西出了阳关，就再也没有老朋友与你相伴了。",
      "translation_keywords": [
        "西出",
        "阳关",
        "无",
        "故人"
      ],
      "explanation": "“阳关”是通往边塞的关隘，一出阳关便意味着进入荒凉、人烟稀少的异域。这句诗点明了送别的地理边界和友人未来处境的艰难与孤独，使劝酒的深情达到高潮，成为千古传诵的名句，饱含了对友人的深切关怀与不舍。"
    }
  ]
}