{
  "poem_id": "EXTRA_038",
  "title": "竹石",
  "author": "郑燮",
  "dynasty": "清",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "咏物",
    "坚韧"
  ],
  "imagery": [
    "竹",
    "青山",
    "岩石"
  ],
  "rhetoric": [
    "拟人",
    "象征",
    "对比"
  ],
  "lines": [
    {
      "line_id": "EXTRA_038_L1",
      "content": "咬定青山不放松",
      "imagery": [
        "竹",
        "青山",
        "岩石"
      ],
      "emotion": [
        "咏物",
        "坚韧"
      ],
      "translation": "竹子紧紧咬住青山，一点也不放松。",
      "translation_keywords": [
        "咬定",
        "青山",
        "不放松"
      ],
      "explanation": "用“咬定”这个拟人化的动词，生动写出竹子牢牢扎根在青山上的姿态，表现出它坚定、执着的品格。"
    },
    {
      "line_id": "EXTRA_038_L2",
      "content": "立根原在破岩中",
      "imagery": [
        "竹",
        "青山",
        "岩石"
      ],
      "emotion": [
        "咏物",
        "坚韧"
      ],
      "translation": "它的根原来就长在破裂的岩石当中。",
      "translation_keywords": [
        "立根",
        "破岩",
        "中"
      ],
      "explanation": "点明竹子生长环境的恶劣——在破碎的岩石缝里扎根，反衬出它生命力的顽强。"
    },
    {
      "line_id": "EXTRA_038_L3",
      "content": "千磨万击还坚劲",
      "imagery": [
        "竹",
        "青山",
        "岩石"
      ],
      "emotion": [
        "咏物",
        "坚韧"
      ],
      "translation": "经历千万次的折磨和打击，它依然坚韧有力。",
      "translation_keywords": [
        "千磨万击",
        "还",
        "坚劲"
      ],
      "explanation": "“千磨万击”用夸张手法写磨难之多，“还坚劲”突出竹子始终不屈服，象征坚韧不拔的精神。"
    },
    {
      "line_id": "EXTRA_038_L4",
      "content": "任尔东西南北风",
      "imagery": [
        "竹",
        "青山",
        "岩石"
      ],
      "emotion": [
        "咏物",
        "坚韧"
      ],
      "translation": "任凭你刮东西南北风，它都毫不动摇。",
      "translation_keywords": [
        "任",
        "东西南北风"
      ],
      "explanation": "“任”字写出竹子的从容与无畏，“东西南北风”代表来自四面八方的打击，进一步强化竹子坚定不移的品格。"
    }
  ]
}
