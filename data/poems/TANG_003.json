  "lines": [
    {
      "line_id": "TANG_003_L1",
      "content": "日照香炉生紫烟",
      "imagery": [
        "日照",
        "香炉峰",
        "紫烟"
      ],
      "emotion": [
        "壮丽",
        "神秘",
        "宏大"
      ],
      "translation": "太阳照耀着香炉峰，升腾起一片紫色烟霞。",
      "translation_keywords": [
        "日照",
        "香炉",
        "紫烟",
        "升腾"
      ],
      "explanation": "开篇点题，写庐山香炉峰在阳光下云雾缭绕、色彩斑斓的壮丽景象。一个“生”字，赋予了烟霞生命力，为瀑布的出现烘托出神秘而雄奇的背景。"
    },
    {
      "line_id": "TANG_003_L2",
      "content": "遥看瀑布挂前川",
      "imagery": [
        "瀑布",
        "前川",
        "挂"
      ],
      "emotion": [
        "惊叹",
        "震撼",
        "视觉冲击"
      ],
      "translation": "远远望去，瀑布仿佛高悬在山前的河流之上。",
      "translation_keywords": [
        "遥看",
        "瀑布",
        "挂",
        "前川"
      ],
      "explanation": "“遥看”表明观赏距离。“挂”字是这句的精髓，将高耸的瀑布形象地比喻成一条巨大的白练，高悬在天地之间，极具动态美和视觉冲击力，为下文的夸张蓄势。"
    },
    {
      "line_id": "TANG_003_L3",
      "content": "飞流直下三千尺",
      "imagery": [
        "飞流",
        "直下",
        "三千尺"
      ],
      "emotion": [
        "雄伟",
        "磅礴",
        "力量感"
      ],
      "translation": "奔腾的激流笔直地倾泻而下，仿佛有三千尺高。",
      "translation_keywords": [
        "飞流",
        "直下",
        "三千尺",
        "倾泻"
      ],
      "explanation": "“飞流直下”强调了瀑布的湍急和垂直落差。“三千尺”是典型的夸张手法，极言瀑布之高、水势之猛，赋予瀑布以排山倒海的气势，使人感受到强大的视觉和听觉冲击。"
    },
    {
      "line_id": "TANG_003_L4",
      "content": "疑是银河落九天",
      "imagery": [
        "银河",
        "九天"
      ],
      "emotion": [
        "浪漫",
        "奇幻",
        "崇高",
        "想象"
      ],
      "translation": "让人怀疑是天上的银河从九重天外坠落人间。",
      "translation_keywords": [
        "疑是",
        "银河",
        "落",
        "九天"
      ],
      "explanation": "诗人由瀑布的壮丽联想到浩瀚的宇宙，将瀑布比作“银河”，将人间与“九天”相连，这种奇特的想象和浪漫的联想，将瀑布的雄伟推向了极致，充满了浪漫主义色彩，也展现了诗人广阔的胸襟和超凡的想象力。"
    }
  ]
}