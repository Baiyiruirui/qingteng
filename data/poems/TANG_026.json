    "象征",
    "借景抒情"
  ],
  "lines": [
    {
      "line_id": "TANG_026_L1",
      "content": "相见时难别亦难，",
      "imagery": [
        "相见",
        "别 (离别)"
      ],
      "emotion": [
        "痛苦",
        "纠结",
        "无奈"
      ],
      "translation": "相见艰难，离别也同样艰难，",
      "translation_keywords": [
        "相见",
        "困难",
        "离别",
        "也",
        "困难"
      ],
      "explanation": "诗人开篇即点明主题，点出与心爱之人相见不易，离别更是痛苦万分，情感深沉。"
    },
    {
      "line_id": "TANG_026_L2",
      "content": "东风无力百花残。",
      "imagery": [
        "东风 (春风)",
        "百花残 (花凋谢)"
      ],
      "emotion": [
        "颓败",
        "伤感",
        "时光流逝"
      ],
      "translation": "春风已显无力，百花也已凋残。",
      "translation_keywords": [
        "东风",
        "无力",
        "百花",
        "凋残"
      ],
      "explanation": "借景抒情，用“东风无力百花残”比喻爱情的衰败和青春的逝去，烘托离别的悲凉。"
    },
    {
      "line_id": "TANG_026_L3",
      "content": "春蚕到死丝方尽，",
      "imagery": [
        "春蚕",
        "丝 (蚕丝)"
      ],
      "emotion": [
        "执着",
        "忠贞",
        "奉献"
      ],
      "translation": "春蚕到死，它的丝才吐尽，",
      "translation_keywords": [
        "春蚕",
        "到死",
        "丝",
        "才",
        "尽"
      ],
      "explanation": "用春蚕吐丝的意象，比喻对爱情的坚贞不渝，至死方休的深情。"
    },
    {
      "line_id": "TANG_026_L4",
      "content": "蜡炬成灰泪始干。",
      "imagery": [
        "蜡炬",
        "灰",
        "泪 (烛泪)"
      ],
      "emotion": [
        "痛苦",
        "煎熬",
        "燃烧自己"
      ],
      "translation": "蜡烛燃烧成灰，它的烛泪才流干。",
      "translation_keywords": [
        "蜡烛",
        "成为",
        "灰烬",
        "泪水",
        "才",
        "干"
      ],
      "explanation": "用蜡烛燃烧的意象，比喻为爱付出一切，泪水流尽才停止痛苦。与上句构成经典的对仗，表达爱情的忠贞与相思的痛苦。"
    },
    {
      "line_id": "TANG_026_L5",
      "content": "晓镜但愁云鬓改，",
      "imagery": [
        "晓镜 (清晨的镜子)",
        "云鬓改 (头发变白)"
      ],
      "emotion": [
        "容颜衰老",
        "青春流逝",
        "愁苦"
      ],
      "translation": "清晨对镜梳妆，只是发愁鬓发已改，",
      "translation_keywords": [
        "清晨",
        "镜子",
        "只是",
        "发愁",
        "鬓发",
        "改变"
      ],
      "explanation": "清晨对镜，只为思念而发愁容颜易老，青春不再。"
    },
    {
      "line_id": "TANG_026_L6",
      "content": "夜吟应觉月光寒。",
      "imagery": [
        "夜吟 (夜晚独吟)",
        "月光寒 (清冷的月光)"
      ],
      "emotion": [
        "孤寂",
        "凄清",
        "彻骨相思"
      ],
      "translation": "夜晚独自吟诗，应该觉得月光也格外清冷吧。",
      "translation_keywords": [
        "夜晚",
        "吟诗",
        "应该",
        "觉得",
        "月光",
        "清冷"
      ],
      "explanation": "晚上独自吟诗，感到月光清冷，更显心境的孤寂与凄凉，相思之情渗透于景物。"
    },
    {
      "line_id": "TANG_026_L7",
      "content": "蓬山此去无多路，",
      "imagery": [
        "蓬山 (仙山, 借指爱人居所)"
      ],
      "emotion": [
        "距离",
        "渴望",
        "渺茫"
      ],
      "translation": "蓬莱仙山离这里并没有多少路，",
      "translation_keywords": [
        "蓬莱山",
        "距离",
        "这里",
        "没有",
        "多少",
        "路"
      ],
      "explanation": "诗人用“蓬山”比喻恋人所在之处，距离不远却难以到达，表达咫尺天涯的无奈。"
    },
    {
      "line_id": "TANG_026_L8",
      "content": "青鸟殷勤为探看。",
      "imagery": [
        "青鸟 (传说中西王母的使者, 传递信息)"
      ],
      "emotion": [
        "渴望沟通",
        "无力",
        "徒劳"
      ],
      "translation": "希望有青鸟殷勤地替我探望你。",
      "translation_keywords": [
        "希望",
        "青鸟",
        "殷勤",
        "替我",
        "探望"
      ],
      "explanation": "诗人寄托于神话中的青鸟，表达了对恋人深切的思念和渴望传递心意的愿望，也透出人世间沟通的无力和遗憾。"
    }
  ]
}