{
  "poem_id": "TANG_029",
  "title": "渡汉江",
  "author": "宋之问",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "思乡",
    "归乡心切",
    "漂泊",
    "近乡情怯"
  ],
  "imagery": [
    "岭外",
    "故园",
    "汉江",
    "冬",
    "春",
    "行人"
  ],
  "rhetoric": [
    "问答",
    "心理描写",
    "直抒胸臆"
  ],
  "lines": [
    {
      "line_id": "TANG_029_L1",
      "content": "岭外音书断，",
      "imagery": [
        "岭外 (五岭之外)",
        "音书 (音信, 书信)"
      ],
      "emotion": [
        "隔绝",
        "孤独",
        "困顿"
      ],
      "translation": "我被贬谪到岭南，与家乡的音信完全隔绝了，",
      "translation_keywords": [
        "岭南",
        "音信",
        "书信",
        "断绝"
      ],
      "explanation": "诗人因故被贬岭南，与家乡音信断绝，表达了漂泊异乡的孤独与困境。"
    },
    {
      "line_id": "TANG_029_L2",
      "content": "经冬复历春。",
      "imagery": [
        "冬",
        "春"
      ],
      "emotion": [
        "时光流逝",
        "漫长",
        "归期未定"
      ],
      "translation": "经过了一个冬天，又迎来了春天。",
      "translation_keywords": [
        "经过",
        "冬天",
        "又",
        "经历",
        "春天"
      ],
      "explanation": "诗人从冬天到春天，度过了漫长而艰难的时光，归乡遥遥无期。"
    },
    {
      "line_id": "TANG_029_L3",
      "content": "近乡情更怯，",
      "imagery": [
        "乡 (故乡)",
        "怯 (胆怯, 不安)"
      ],
      "emotion": [
        "忐忑",
        "不安",
        "矛盾"
      ],
      "translation": "越是接近故乡，心情反而越是胆怯不安，",
      "translation_keywords": [
        "接近",
        "故乡",
        "心情",
        "更加",
        "胆怯"
      ],
      "explanation": "越是接近家乡，越是害怕家乡的变化，害怕亲人的情况，心情反而变得不安和忐忑。"
    },
    {
      "line_id": "TANG_029_L4",
      "content": "不敢问来人。",
      "imagery": [
        "来人 (从家乡来的人)"
      ],
      "emotion": [
        "恐惧",
        "担忧",
        "矛盾"
      ],
      "translation": "不敢向从家乡来的人询问情况。",
      "translation_keywords": [
        "不敢",
        "问",
        "从家乡来的人"
      ],
      "explanation": "这种复杂的心情让他甚至不敢直接询问从家乡来的人，深怕听到不好的消息。"
    }
  ]
}