{
  "poem_id": "TANG_030",
  "title": "送杜少府之任蜀州",
  "author": "王勃",
  "dynasty": "唐",
  "grade": "中学",
  "text_type": "律诗",
  "themes": [
    "离别",
    "友情",
    "豁达",
    "壮志",
    "乐观"
  ],
  "imagery": [
    "城阙",
    "三秦",
    "风烟",
    "五津",
    "海内",
    "天涯",
    "比邻",
    "歧路",
    "儿女"
  ],
  "rhetoric": [
    "对偶",
    "衬托",
    "警句",
    "借景抒情",
    "对比"
  ],
  "lines": [
    {
      "line_id": "TANG_030_L1",
      "content": "城阙辅三秦，",
      "imagery": [
        "城阙 (高大的城楼)",
        "三秦 (长安附近地区)"
      ],
      "emotion": [
        "壮丽",
        "雄伟"
      ],
      "translation": "长安城高大的城楼，拱卫着三秦大地，",
      "translation_keywords": [
        "长安城",
        "城楼",
        "辅佐",
        "三秦"
      ],
      "explanation": "描绘长安城的宏伟气势，三秦拱卫京都，凸显送别地点的重要性。"
    },
    {
      "line_id": "TANG_030_L2",
      "content": "风烟望五津。",
      "imagery": [
        "风烟 (风尘, 迷蒙)",
        "五津 (蜀州五津渡口)"
      ],
      "emotion": [
        "遥远",
        "壮阔"
      ],
      "translation": "远望蜀州五津，只见一片风尘烟雾。",
      "translation_keywords": [
        "远望",
        "风尘",
        "烟雾",
        "五津"
      ],
      "explanation": "遥望杜少府将要去往的蜀州，路途遥远，烟雾迷蒙，与长安形成对照，增添了离别的距离感。"
    },
    {
      "line_id": "TANG_030_L3",
      "content": "与君离别意，",
      "imagery": [
        "君 (友人)",
        "离别"
      ],
      "emotion": [
        "离愁"
      ],
      "translation": "和你分别的心情，",
      "translation_keywords": [
        "和你",
        "离别",
        "心情"
      ],
      "explanation": "诗人点明是与友人杜少府的离别。"
    },
    {
      "line_id": "TANG_030_L4",
      "content": "同是宦游人。",
      "imagery": [
        "宦游人 (在外为官的人)"
      ],
      "emotion": [
        "同病相怜",
        "惺惺相惜"
      ],
      "translation": "我们都是在外为官的游子。",
      "translation_keywords": [
        "都是",
        "在外为官",
        "游子"
      ],
      "explanation": "强调两人同是宦游之人，相互理解，使得离别之情更加深厚。"
    },
    {
      "line_id": "TANG_030_L5",
      "content": "海内存知己，",
      "imagery": [
        "海内 (天下)",
        "知己 (知心朋友)"
      ],
      "emotion": [
        "豁达",
        "友谊",
        "宽慰"
      ],
      "translation": "只要四海之内有知心朋友，",
      "translation_keywords": [
        "四海之内",
        "有",
        "知己"
      ],
      "explanation": "著名的警句，表达了诗人宽广的胸襟和对友谊的深刻理解。"
    },
    {
      "line_id": "TANG_030_L6",
      "content": "天涯若比邻。",
      "imagery": [
        "天涯 (遥远的地方)",
        "比邻 (近邻)"
      ],
      "emotion": [
        "豁达",
        "慰藉",
        "超越距离"
      ],
      "translation": "即使远在天涯，也如同近邻一样。",
      "translation_keywords": [
        "天涯海角",
        "就像",
        "近邻"
      ],
      "explanation": "另一句警句，即使相隔遥远，只要心意相通，也如同近邻一般亲近，以此宽慰友人，化解离愁。"
    },
    {
      "line_id": "TANG_030_L7",
      "content": "无为在歧路，",
      "imagery": [
        "歧路 (岔路口)"
      ],
      "emotion": [
        "劝慰",
        "振作",
        "勉励"
      ],
      "translation": "请不要在岔路口，",
      "translation_keywords": [
        "不要",
        "在",
        "岔路口"
      ],
      "explanation": "劝慰友人不要在离别的路口，因短暂的分别而感伤。"
    },
    {
      "line_id": "TANG_030_L8",
      "content": "儿女共沾巾。",
      "imagery": [
        "儿女 (小儿女情态)",
        "沾巾 (泪湿衣巾)"
      ],
      "emotion": [
        "豪迈",
        "不屑",
        "劝勉"
      ],
      "translation": "像小儿女一样地流泪沾湿衣巾。",
      "translation_keywords": [
        "像",
        "小儿女",
        "一样",
        "流泪",
        "湿",
        "衣巾"
      ],
      "explanation": "不要像小儿女一样哭哭啼啼，要表现出大丈夫的豪迈气概。全诗以景开篇，以情作结，用豁达乐观的情怀冲淡了离别的愁绪。"
    }
  ]
}