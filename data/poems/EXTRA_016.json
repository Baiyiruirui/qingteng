{
  "poem_id": "EXTRA_016",
  "title": "早春呈水部张十八员外",
  "author": "韩愈",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "春景",
    "自然"
  ],
  "imagery": [
    "小雨",
    "草色",
    "烟柳"
  ],
  "rhetoric": [
    "比喻",
    "对比"
  ],
  "lines": [
    {
      "line_id": "EXTRA_016_L1",
      "content": "天街小雨润如酥",
      "imagery": [
        "小雨",
        "草色",
        "烟柳"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "京城街道上落下的细雨，像酥油一样滋润细腻。",
      "translation_keywords": [
        "天街",
        "小雨",
        "润如酥"
      ],
      "explanation": "首句写春雨之细、之润。用“润如酥”比喻小雨，写出春雨滋润万物的特点，让人感到柔和舒适。"
    },
    {
      "line_id": "EXTRA_016_L2",
      "content": "草色遥看近却无",
      "imagery": [
        "小雨",
        "草色",
        "烟柳"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "远远望去，草色青青一片，走近看却好像没有了。",
      "translation_keywords": [
        "草色",
        "遥看",
        "近却无"
      ],
      "explanation": "这句写早春草色若有若无的特点。“遥看”与“近却无”形成对比，写出早春草芽初生、稀疏朦胧的美感，体现诗人观察的细致。"
    },
    {
      "line_id": "EXTRA_016_L3",
      "content": "最是一年春好处",
      "imagery": [
        "小雨",
        "草色",
        "烟柳"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "这是一年中春天最好的时候。",
      "translation_keywords": [
        "最是",
        "一年春",
        "好处"
      ],
      "explanation": "诗人直接赞美早春，认为此时是春天最美的时刻。语气肯定，表达对早春的偏爱。"
    },
    {
      "line_id": "EXTRA_016_L4",
      "content": "绝胜烟柳满皇都",
      "imagery": [
        "小雨",
        "草色",
        "烟柳"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "远远胜过满城杨柳如烟的晚春景色。",
      "translation_keywords": [
        "绝胜",
        "烟柳",
        "满皇都"
      ],
      "explanation": "用“绝胜”对比早春与晚春，强调早春的清新、生机远胜于晚春的浓艳。烟柳是晚春的典型意象，这里反衬早春的独特之美。"
    }
  ]
}
