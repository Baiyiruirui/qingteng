  "lines": [
    {
      "line_id": "EXTRA_035_L1",
      "content": "绿遍山原白满川",
      "imagery": [
        "山原",
        "子规",
        "蚕桑"
      ],
      "emotion": [
        "田园",
        "劳动"
      ],
      "translation": "山坡田野间草木茂盛，一片碧绿，而稻田里的水色与天光相映，白茫茫一片。",
      "translation_keywords": [
        "绿遍",
        "山原",
        "白满川"
      ],
      "explanation": "这句诗用“绿”和“白”两种鲜明的颜色，写出了初夏时节山野和稻田的美丽景色。“遍”和“满”两个字，让人感觉绿色和白色到处都是，画面非常开阔。"
    },
    {
      "line_id": "EXTRA_035_L2",
      "content": "子规声里雨如烟",
      "imagery": [
        "山原",
        "子规",
        "蚕桑"
      ],
      "emotion": [
        "田园",
        "劳动"
      ],
      "translation": "在杜鹃鸟的啼叫声中，细雨如烟似雾，迷迷蒙蒙。",
      "translation_keywords": [
        "子规声",
        "雨如烟"
      ],
      "explanation": "这句诗从听觉（子规声）和视觉（雨如烟）两个角度来写。“雨如烟”是一个比喻，把细雨比作烟雾，写出了春雨细密、朦胧的特点。子规的叫声给画面增添了生机。"
    },
    {
      "line_id": "EXTRA_035_L3",
      "content": "乡村四月闲人少",
      "imagery": [
        "山原",
        "子规",
        "蚕桑"
      ],
      "emotion": [
        "田园",
        "劳动"
      ],
      "translation": "乡村的四月里，人们很少有空闲的时候。",
      "translation_keywords": [
        "乡村",
        "四月",
        "闲人少"
      ],
      "explanation": "这句诗直接点出乡村四月农忙的特点。“闲人少”三个字，为下一句具体写农忙做了铺垫。"
    },
    {
      "line_id": "EXTRA_035_L4",
      "content": "才了蚕桑又插田",
      "imagery": [
        "山原",
        "子规",
        "蚕桑"
      ],
      "emotion": [
        "田园",
        "劳动"
      ],
      "translation": "刚刚结束了采桑养蚕的活儿，又要忙着去田里插秧了。",
      "translation_keywords": [
        "才了",
        "蚕桑",
        "又",
        "插田"
      ],
      "explanation": "这句诗用“才了……又……”的句式，写出了农活一个接一个，非常紧张忙碌。蚕桑和插田是江南乡村四月最重要的农事，诗人选取这两个典型场景，生动地表现了农民的勤劳。"
    }
  ]
}
