  "lines": [
    {
      "line_id": "TANG_058_L1",
      "content": "山不在高，有仙则名。水不在深，有龙则灵。",
      "imagery": [
        "山",
        "仙",
        "水",
        "龙"
      ],
      "emotion": [
        "哲理",
        "借物言志"
      ],
      "translation": "山不在于高，有仙人居住就出名；水不在于深，有蛟龙盘踞就显得神灵。",
      "translation_keywords": [
        "山",
        "仙",
        "水",
        "龙",
        "名",
        "灵"
      ],
      "explanation": "以山水为例，提出事物价值不在于外在条件，而在于其内在的精髓或品格。为“陋室”立论，引出下文对陋室不陋的阐述。"
    },
    {
      "line_id": "TANG_058_L2",
      "content": "斯是陋室，惟吾德馨。",
      "imagery": [
        "陋室"
      ],
      "emotion": [
        "自豪",
        "淡泊"
      ],
      "translation": "这虽然是一间简陋的屋子，但只要我的品德高尚，就不觉得简陋了。",
      "translation_keywords": [
        "斯",
        "陋室",
        "惟",
        "吾",
        "德馨"
      ],
      "explanation": "承接上文，点明陋室的主题，提出“德馨”是陋室价值的根源，明确了主人的品德是提升陋室格调的关键。"
    },
    {
      "line_id": "TANG_058_L3",
      "content": "苔痕上阶绿，草色入帘青。",
      "imagery": [
        "苔痕",
        "阶",
        "草色",
        "帘"
      ],
      "emotion": [
        "雅致",
        "宁静"
      ],
      "translation": "苔藓的痕迹爬上台阶，翠绿一片；草地的颜色映入帘内，一片青葱。",
      "translation_keywords": [
        "苔痕",
        "阶",
        "绿",
        "草色",
        "帘",
        "青"
      ],
      "explanation": "描绘陋室周围宁静、自然的景色，用简单的色彩和动态表现了环境的雅致和生机，衬托主人不慕奢华、亲近自然的志趣。"
    },
    {
      "line_id": "TANG_058_L4",
      "content": "谈笑有鸿儒，往来无白丁。",
      "imagery": [
        "鸿儒",
        "白丁"
      ],
      "emotion": [
        "高雅",
        "志同道合"
      ],
      "translation": "与我谈笑的都是博学之士，到我这里来的没有一个是没有学问的粗人。",
      "translation_keywords": [
        "谈笑",
        "鸿儒",
        "往来",
        "白丁"
      ],
      "explanation": "从交友层面描写陋室“不陋”，强调主人与高雅之士交往，排斥无学之人，凸显了主人高洁的志趣和品位。"
    },
    {
      "line_id": "TANG_058_L5",
      "content": "可以调素琴，阅金经。无丝竹之乱耳，无案牍之劳形。",
      "imagery": [
        "素琴",
        "金经",
        "丝竹",
        "案牍"
      ],
      "emotion": [
        "清雅",
        "自得",
        "闲适"
      ],
      "translation": "可以弹奏不加装饰的琴，阅读佛经。没有世俗音乐的喧扰，也没有官府公文的劳累。",
      "translation_keywords": [
        "素琴",
        "金经",
        "丝竹",
        "乱耳",
        "案牍",
        "劳形"
      ],
      "explanation": "具体描述陋室中的雅事，表现主人闲适自得的生活和精神享受，厌弃世俗喧嚣和官场劳累，进一步强调了陋室的超脱和主人的高雅。"
    },
    {
      "line_id": "TANG_058_L6",
      "content": "南阳诸葛庐，西蜀子云亭。孔子云：何陋之有？",
      "imagery": [
        "诸葛庐",
        "子云亭",
        "孔子"
      ],
      "emotion": [
        "崇敬",
        "自豪",
        "反问"
      ],
      "translation": "南阳有诸葛亮的草庐，西蜀有扬子云的亭子。孔子说：有什么简陋的呢？",
      "translation_keywords": [
        "诸葛庐",
        "子云亭",
        "孔子",
        "何陋之有"
      ],
      "explanation": "引用历史名人的居所和孔子的话，以典故为自己的陋室作证，表明陋室与这些名士的居所一样，因主人的品德和才华而不显简陋，有力地升华了主题，以反问作结，更显理直气壮。"
    }
  ]
}