{
  "poem_id": "TANG_041",
  "title": "茅屋为秋风所破歌",
  "author": "杜甫",
  "dynasty": "唐",
  "grade": "中学",
  "text_type": "歌行",
  "themes": [
    "忧国忧民",
    "个人苦难",
    "推己及人",
    "博爱精神",
    "理想主义",
    "民生疾苦"
  ],
  "imagery": [
    "八月秋高",
    "风怒号",
    "三重茅",
    "茅飞渡江",
    "长林梢",
    "塘坳",
    "南村群童",
    "竹",
    "布衾",
    "铁",
    "娇儿",
    "床头屋漏",
    "雨脚如麻",
    "广厦千万间",
    "寒士",
    "山"
  ],
  "rhetoric": [
    "叙事",
    "抒情",
    "细节描写",
    "夸张",
    "对比",
    "设问",
    "转折",
    "借景抒情",
    "直抒胸臆"
  ],
  "lines": [
    {
      "line_id": "TANG_041_L1",
      "content": "八月秋高风怒号，",
      "imagery": [
        "八月秋高",
        "风怒号"
      ],
      "emotion": [
        "凄厉",
        "悲凉"
      ],
      "translation": "八月秋高气爽，狂风怒吼着，",
      "translation_keywords": [
        "八月",
        "秋高",
        "风怒号"
      ],
      "explanation": "开篇点明时间是秋天，环境是狂风大作，为全诗奠定了凄苦悲凉的基调。"
    },
    {
      "line_id": "TANG_041_L2",
      "content": "卷我屋上三重茅。",
      "imagery": [
        "茅屋",
        "三重茅"
      ],
      "emotion": [
        "无奈",
        "困苦"
      ],
      "translation": "把我家屋顶上的几层茅草都卷走了。",
      "translation_keywords": [
        "卷我",
        "屋上",
        "三重茅"
      ],
      "explanation": "直接描写茅屋受损的惨状，是诗人自身困境的直观体现。"
    },
    {
      "line_id": "TANG_041_L3",
      "content": "茅飞渡江洒江郊，",
      "imagery": [
        "茅飞",
        "渡江",
        "江郊"
      ],
      "emotion": [
        "散乱",
        "无助"
      ],
      "translation": "茅草飞过江面，撒落在对岸的江边荒野上，",
      "translation_keywords": [
        "茅飞",
        "渡江",
        "洒江郊"
      ],
      "explanation": "夸张描写茅草被风卷走之远，可见风力之大，也暗示了诗人处境的无力与茅草的不可追回。"
    },
    {
      "line_id": "TANG_041_L4",
      "content": "高者挂罥长林梢，",
      "imagery": [
        "高者",
        "长林梢"
      ],
      "emotion": [
        "凄惨",
        "飘零"
      ],
      "translation": "高处的挂在长长的树林梢头，",
      "translation_keywords": [
        "高者",
        "挂罥",
        "长林梢"
      ],
      "explanation": "细致描写茅草的散落情况，更加烘托了风的狂暴和诗人住处破败的景象。"
    },
    {
      "line_id": "TANG_041_L5",
      "content": "下者飘转沉塘坳。",
      "imagery": [
        "下者",
        "塘坳"
      ],
      "emotion": [
        "凄惨",
        "飘零"
      ],
      "translation": "低处的则在空中飘转着沉入水塘低洼处。",
      "translation_keywords": [
        "下者",
        "飘转",
        "沉塘坳"
      ],
      "explanation": "与上句形成对比，生动展现了茅草被风吹散的狼狈景象，也象征了诗人生活的飘摇不定。"
    },
    {
      "line_id": "TANG_041_L6",
      "content": "南村群童欺我老无力，",
      "imagery": [
        "南村群童"
      ],
      "emotion": [
        "愤怒",
        "悲哀"
      ],
      "translation": "南村的一群顽童欺负我年老体弱无力，",
      "translation_keywords": [
        "南村群童",
        "欺我老无力"
      ],
      "explanation": "诗人遭遇天灾后又遇人祸，顽童的无知与诗人的困境形成鲜明对比，更显诗人处境的凄凉与无助。"
    },
    {
      "line_id": "TANG_041_L7",
      "content": "忍能对面前头盗贼。",
      "imagery": [
        "盗贼"
      ],
      "emotion": [
        "愤怒",
        "无可奈何"
      ],
      "translation": "竟然当着我的面把茅草偷走了。",
      "translation_keywords": [
        "忍能",
        "对面前头",
        "盗贼"
      ],
      "explanation": "“忍能”二字表达了诗人极大的愤慨和无可奈何，也反映了战乱年代民生艰难、道德沦丧的一面。"
    },
    {
      "line_id": "TANG_041_L8",
      "content": "公然抱茅入竹去，",
      "imagery": [
        "抱茅",
        "入竹"
      ],
      "emotion": [
        "气愤",
        "无奈"
      ],
      "translation": "他们竟然公然抱着茅草跑进了竹林，",
      "translation_keywords": [
        "公然",
        "抱茅",
        "入竹去"
      ],
      "explanation": "进一步描写顽童的嚣张，加剧了诗人的无奈感和生活的困苦。"
    },
    {
      "line_id": "TANG_041_L9",
      "content": "唇焦口燥呼不得，",
      "imagery": [
        "唇焦口燥"
      ],
      "emotion": [
        "焦急",
        "气恼",
        "无力"
      ],
      "translation": "我急得嘴唇焦干，口舌发燥，却怎么也喊不住他们。",
      "translation_keywords": [
        "唇焦口燥",
        "呼不得"
      ],
      "explanation": "诗人身心俱疲，声音嘶哑，无法制止，表现了他的身心困乏和内心的焦灼。"
    },
    {
      "line_id": "TANG_041_L10",
      "content": "归来倚杖自叹息。",
      "imagery": [
        "倚杖"
      ],
      "emotion": [
        "悲叹",
        "无助",
        "绝望"
      ],
      "translation": "回到家里，我只能拄着拐杖独自叹息。",
      "translation_keywords": [
        "归来",
        "倚杖",
        "自叹息"
      ],
      "explanation": "诗人面对困境，无可奈何，只能独自悲叹，将内心的绝望与无力表现得淋漓尽致。"
    },
    {
      "line_id": "TANG_041_L11",
      "content": "俄顷风定云墨色，",
      "imagery": [
        "风定",
        "云墨色"
      ],
      "emotion": [
        "阴沉",
        "压抑"
      ],
      "translation": "不一会儿风停了，乌云密布，天空漆黑如墨，",
      "translation_keywords": [
        "俄顷",
        "风定",
        "云墨色"
      ],
      "explanation": "风停雨至，天空由风狂转为阴沉，预示着更大的灾难即将降临，氛围更加压抑。"
    },
    {
      "line_id": "TANG_041_L12",
      "content": "秋天漠漠向昏黑。",
      "imagery": [
        "秋天",
        "昏黑"
      ],
      "emotion": [
        "阴沉",
        "绝望"
      ],
      "translation": "茫茫秋夜，逐渐走向昏暗。",
      "translation_keywords": [
        "秋天",
        "漠漠",
        "向昏黑"
      ],
      "explanation": "环境的昏暗与诗人心中的绝望相呼应，暗示了其处境的艰难和未来的不明。"
    },
    {
      "line_id": "TANG_041_L13",
      "content": "布衾多年冷似铁，",
      "imagery": [
        "布衾",
        "铁"
      ],
      "emotion": [
        "寒冷",
        "凄苦"
      ],
      "translation": "我那用了多年的布被子，冷得像铁一样冰凉，",
      "translation_keywords": [
        "布衾",
        "多年",
        "冷似铁"
      ],
      "explanation": "侧面描写诗人生活的贫困和身体的寒冷，为接下来的雨夜做铺垫。"
    },
    {
      "line_id": "TANG_041_L14",
      "content": "娇儿恶卧踏里裂。",
      "imagery": [
        "娇儿"
      ],
      "emotion": [
        "怜爱",
        "无奈"
      ],
      "translation": "而调皮的儿子睡觉不老实，把被里都蹬破了。",
      "translation_keywords": [
        "娇儿",
        "恶卧",
        "踏里裂"
      ],
      "explanation": "生活细节描写，反映出家庭的贫困和孩子天真无邪的行为在困境中更显无奈。"
    },
    {
      "line_id": "TANG_041_L15",
      "content": "床头屋漏无干处，",
      "imagery": [
        "床头屋漏"
      ],
      "emotion": [
        "潮湿",
        "无望"
      ],
      "translation": "床头屋顶漏雨，没有一处是干燥的，",
      "translation_keywords": [
        "床头",
        "屋漏",
        "无干处"
      ],
      "explanation": "直接描写屋内漏雨的惨状，诗人无处可避，困境加剧。"
    },
    {
      "line_id": "TANG_041_L16",
      "content": "雨脚如麻未断绝。",
      "imagery": [
        "雨脚如麻"
      ],
      "emotion": [
        "持续",
        "绝望"
      ],
      "translation": "密集的雨点像麻线一样，一直下个不停。",
      "translation_keywords": [
        "雨脚如麻",
        "未断绝"
      ],
      "explanation": "以“雨脚如麻”比喻雨势之大、时间之长，进一步渲染了诗人处境的凄惨和无助。"
    },
    {
      "line_id": "TANG_041_L17",
      "content": "自经丧乱少睡眠，",
      "imagery": [],
      "emotion": [
        "疲惫",
        "忧虑"
      ],
      "translation": "自从经历战乱，我夜里就很少能安稳入睡，",
      "translation_keywords": [
        "丧乱",
        "少睡眠"
      ],
      "explanation": "承接前面的叙述，点明诗人长期以来的身心疲惫和对战乱的忧虑。"
    },
    {
      "line_id": "TANG_041_L18",
      "content": "长夜沾湿何由彻！",
      "imagery": [
        "长夜",
        "沾湿"
      ],
      "emotion": [
        "悲叹",
        "无尽的苦楚"
      ],
      "translation": "漫漫长夜，又被雨水沾湿，如何才能熬到天亮呢！",
      "translation_keywords": [
        "长夜",
        "沾湿",
        "何由彻"
      ],
      "explanation": "诗人面对无尽的长夜和湿冷的床铺，发出绝望的叹息，表达了身处困境的煎熬。"
    },
    {
      "line_id": "TANG_041_L19",
      "content": "安得广厦千万间，",
      "imagery": [
        "广厦千万间"
      ],
      "emotion": [
        "渴望",
        "宏大理想"
      ],
      "translation": "如何才能得到千万间宽敞的大屋，",
      "translation_keywords": [
        "安得",
        "广厦千万间"
      ],
      "explanation": "情感在此处发生转折，诗人从个人苦难中抽离，升华到对天下苍生的关怀，表达了其宏大的理想。"
    },
    {
      "line_id": "TANG_041_L20",
      "content": "大庇天下寒士俱欢颜，",
      "imagery": [
        "寒士"
      ],
      "emotion": [
        "博爱",
        "悲悯"
      ],
      "translation": "普遍地庇护天下所有贫寒的读书人，让他们都能开心地生活，",
      "translation_keywords": [
        "大庇",
        "天下寒士",
        "俱欢颜"
      ],
      "explanation": "展现了诗人推己及人、兼济天下的博大胸怀，希望天下寒士都能摆脱苦难。"
    },
    {
      "line_id": "TANG_041_L21",
      "content": "风雨不动安如山！",
      "imagery": [
        "风雨",
        "山"
      ],
      "emotion": [
        "坚固",
        "安宁"
      ],
      "translation": "即使遇到风雨，也能安稳如山，坚固不动！",
      "translation_keywords": [
        "风雨不动",
        "安如山"
      ],
      "explanation": "描绘了诗人理想中的居所，坚固而能抵御一切灾难，寄托了对天下百姓安居乐业的深切愿望。"
    },
    {
      "line_id": "TANG_041_L22",
      "content": "呜呼！何时眼前突兀见此屋，",
      "imagery": [
        "此屋"
      ],
      "emotion": [
        "渴望",
        "期盼"
      ],
      "translation": "唉！什么时候我的眼前能突然出现这样的房屋呢？",
      "translation_keywords": [
        "呜呼",
        "何时",
        "眼前突兀",
        "见此屋"
      ],
      "explanation": "诗人发出由衷的呼唤，对理想的实现充满殷切的期盼和深情的向往。"
    },
    {
      "line_id": "TANG_041_L23",
      "content": "吾庐独破受冻死亦足！",
      "imagery": [
        "吾庐独破",
        "冻死骨"
      ],
      "emotion": [
        "牺牲",
        "奉献",
        "释然"
      ],
      "translation": "即使我自己的茅屋独自破败，忍受冻死也心满意足了！",
      "translation_keywords": [
        "吾庐独破",
        "受冻死",
        "亦足"
      ],
      "explanation": "诗人将个人的生死置之度外，宁愿自己受苦甚至牺牲，也要实现天下百姓安居的理想，展现了崇高的牺牲精神和仁爱之心。"
    }
  ]
}