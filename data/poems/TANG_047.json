  ],
  "imagery": [
    "潼关",
    "吏",
    "胡骑",
    "烽火",
    "长安",
    "咸阳",
    "未央宫",
    "狐狸",
    "行人",
    "老幼",
    "道路",
    "尘土"
  ],
  "rhetoric": [
    "白描",
    "叙事",
    "对比",
    "借景抒情",
    "设问",
    "反复"
  ],
  "lines": [
    {
      "line_id": "TANG_047_L1",
      "content": "士卒何所闻，人言潼关吏。",
      "imagery": [
        "士卒",
        "潼关吏"
      ],
      "emotion": [
        "疑问",
        "忧虑"
      ],
      "translation": "士兵们听到了什么？人们都在议论潼关的官吏。",
      "translation_keywords": [
        "士兵",
        "听闻",
        "人们",
        "议论",
        "潼关吏"
      ],
      "explanation": "诗歌开篇，以士卒的疑问引入，点明了诗歌的主题人物——潼关的官吏，引发读者对时局的关注。"
    },
    {
      "line_id": "TANG_047_L2",
      "content": "胡骑入关中，边烽直照长安地。",
      "imagery": [
        "胡骑",
        "关中",
        "边烽",
        "长安"
      ],
      "emotion": [
        "紧张",
        "危急",
        "恐慌"
      ],
      "translation": "胡人的骑兵已经攻入关中，边境的烽火直接照亮了长安城。",
      "translation_keywords": [
        "胡骑",
        "攻入",
        "关中",
        "烽火",
        "照亮",
        "长安"
      ],
      "explanation": "描绘了战事紧急、国家危亡的景象，胡人军队已深入腹地，京城告急，局势极其危殆。"
    },
    {
      "line_id": "TANG_047_L3",
      "content": "行人皆惊散，老幼哭别离。",
      "imagery": [
        "行人",
        "老幼",
        "哭泣"
      ],
      "emotion": [
        "恐惧",
        "悲伤",
        "离乱"
      ],
      "translation": "行人全都惊慌失措地四散奔逃，老人和小孩哭泣着生离死别。",
      "translation_keywords": [
        "行人",
        "惊散",
        "老幼",
        "哭泣",
        "别离"
      ],
      "explanation": "描写了战争给百姓带来的巨大灾难，人们四散奔逃，骨肉分离，一片悲惨凄凉的景象。"
    },
    {
      "line_id": "TANG_047_L4",
      "content": "我军收咸阳，未央宫殿多狐狸。",
      "imagery": [
        "我军",
        "咸阳",
        "未央宫",
        "狐狸"
      ],
      "emotion": [
        "讽刺",
        "荒凉",
        "衰败",
        "无奈"
      ],
      "translation": "我军虽然收复了咸阳，然而昔日辉煌的未央宫殿里却已是狐狸出没的荒凉景象。",
      "translation_keywords": [
        "我军",
        "收复",
        "咸阳",
        "未央宫",
        "狐狸",
        "荒凉"
      ],
      "explanation": "表面上说收复了咸阳，实则讽刺朝廷的无能，连昔日皇宫都成了废墟，暗喻国家衰败，尽管收复失地，但已是千疮百孔。"
    },
    {
      "line_id": "TANG_047_L5",
      "content": "问君胡不归？君言道路长。",
      "imagery": [
        "君",
        "道路"
      ],
      "emotion": [
        "关切",
        "无奈",
        "艰辛"
      ],
      "translation": "我问你为何还不回家？你回答说道路遥远漫长，难以归返。",
      "translation_keywords": [
        "问",
        "君",
        "为何",
        "不归",
        "道路",
        "遥远"
      ],
      "explanation": "诗人设问“君”（代指流离失所的百姓），“君”的回答道出了路途艰险、无法归家的无奈，暗示了战乱造成的交通阻隔和民生困苦。"
    },
    {
      "line_id": "TANG_047_L6",
      "content": "日夜望君在，不知君何之？",
      "imagery": [
        "君",
        "日夜"
      ],
      "emotion": [
        "思念",
        "迷茫",
        "担忧"
      ],
      "translation": "日日夜夜盼望着你的归来，却不知你身在何方？",
      "translation_keywords": [
        "日夜",
        "盼望",
        "君",
        "不知",
        "何方"
      ],
      "explanation": "进一步表达了对流离失所者的深切思念和对其命运的担忧，前途未卜，生死未明。"
    },
    {
      "line_id": "TANG_047_L7",
      "content": "身是客中人，家在长安城。",
      "imagery": [
        "客中人",
        "长安城"
      ],
      "emotion": [
        "漂泊",
        "思乡",
        "无助"
      ],
      "translation": "我身在异乡，家就在长安城。",
      "translation_keywords": [
        "身",
        "客中人",
        "家",
        "长安城"
      ],
      "explanation": "点明诗中“我”的身份，是身处他乡的游子，家虽在长安，却因战乱有家难回，突出了漂泊无依的悲凉。"
    },
    {
      "line_id": "TANG_047_L8",
      "content": "行路难，行路难，不见潼关吏，但见长安尘。",
      "imagery": [
        "道路",
        "潼关吏",
        "长安",
        "尘土"
      ],
      "emotion": [
        "艰辛",
        "迷惘",
        "绝望",
        "悲凉"
      ],
      "translation": "行路艰难啊，行路艰难，看不见那负责的潼关官吏，只看见漫天飞舞的长安尘土。",
      "translation_keywords": [
        "行路难",
        "看不见",
        "潼关吏",
        "只看见",
        "长安",
        "尘土"
      ],
      "explanation": "连用“行路难”点出路途的艰险和时局的混乱，结尾不见负责的官吏，只有战乱带来的长安城一片狼藉，表达了对现实的失望和对前途的悲观，批判了官吏的失职。"
    }
  ]
}