  "lines": [
    {
      "line_id": "TANG_054_L1",
      "content": "兰叶春葳蕤，桂华秋皎洁。",
      "imagery": [
        "兰叶",
        "春",
        "桂华",
        "秋"
      ],
      "emotion": [
        "生机",
        "高洁"
      ],
      "translation": "春天的兰叶繁茂鲜艳，秋天的桂花洁白晶莹。",
      "translation_keywords": [
        "兰叶",
        "春",
        "葳蕤",
        "桂华",
        "秋",
        "皎洁"
      ],
      "explanation": "首联以兰、桂起兴，描绘它们在不同季节各自展现出的美好姿态，象征君子的高洁品格。"
    },
    {
      "line_id": "TANG_054_L2",
      "content": "欣欣此生意，自尔为佳节。",
      "imagery": [
        "生意",
        "佳节"
      ],
      "emotion": [
        "喜悦",
        "自得"
      ],
      "translation": "这蓬勃生长的意趣令人欣喜，它们自然而然地成为美好的节令风景。",
      "translation_keywords": [
        "欣欣",
        "生意",
        "自尔",
        "佳节"
      ],
      "explanation": "颔联承接上文，点出兰桂的勃勃生机和它们在自然中的独特价值，隐喻君子之才华与品德。"
    },
    {
      "line_id": "TANG_054_L3",
      "content": "谁知林栖者，闻风坐相悦。",
      "imagery": [
        "林栖者",
        "风"
      ],
      "emotion": [
        "相悦",
        "欣赏"
      ],
      "translation": "谁知道那隐居山林的人，听到它们的芳香就心生喜悦呢？",
      "translation_keywords": [
        "谁知",
        "林栖者",
        "闻风",
        "坐相悦"
      ],
      "explanation": "颈联提出设问，引出“林栖者”（隐士或君子）对兰桂的欣赏，暗示有德之人互相引为知己。"
    },
    {
      "line_id": "TANG_054_L4",
      "content": "草木有本心，何求美人折。",
      "imagery": [
        "草木",
        "美人"
      ],
      "emotion": [
        "坚守",
        "不求",
        "高洁"
      ],
      "translation": "草木都有自己本来的品性，何必非要寻求美人的攀折呢？",
      "translation_keywords": [
        "草木",
        "本心",
        "何求",
        "美人折"
      ],
      "explanation": "尾联点明主旨，借草木的“本心”自立，表达了君子不趋炎附势、坚守气节的崇高品格，不求世俗的赏识与宠幸。"
    }
  ]
}