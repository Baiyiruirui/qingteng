{
  "poem_id": "EXTRA_021",
  "title": "悯农其二",
  "author": "李绅",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "劳动",
    "节俭"
  ],
  "imagery": [
    "禾苗",
    "汗水",
    "粮食"
  ],
  "rhetoric": [
    "设问",
    "对比",
    "夸张"
  ],
  "lines": [
    {
      "line_id": "EXTRA_021_L1",
      "content": "锄禾日当午",
      "imagery": [
        "禾苗",
        "汗水",
        "粮食"
      ],
      "emotion": [
        "劳动",
        "节俭"
      ],
      "translation": "农民在正午的烈日下给禾苗锄草松土。",
      "translation_keywords": [
        "锄禾",
        "正午",
        "烈日",
        "劳动"
      ],
      "explanation": "这句写农民在一天中最热的时候还在田里干活。“锄禾”指给庄稼松土除草，“日当午”点明时间是正午，太阳最毒辣的时候，突出了劳动的辛苦。"
    },
    {
      "line_id": "EXTRA_021_L2",
      "content": "汗滴禾下土",
      "imagery": [
        "禾苗",
        "汗水",
        "粮食"
      ],
      "emotion": [
        "劳动",
        "节俭"
      ],
      "translation": "汗水一滴一滴地掉进禾苗下的泥土里。",
      "translation_keywords": [
        "汗水",
        "滴落",
        "禾下土",
        "辛苦"
      ],
      "explanation": "这句承接上句，用“汗滴”这个细节，生动地写出农民累得满头大汗，汗水都流到了地上。一个“滴”字，让人仿佛看到汗珠一颗颗落下的样子，非常形象。"
    },
    {
      "line_id": "EXTRA_021_L3",
      "content": "谁知盘中餐",
      "imagery": [
        "禾苗",
        "汗水",
        "粮食"
      ],
      "emotion": [
        "劳动",
        "节俭"
      ],
      "translation": "有谁知道碗里的每一粒米饭，",
      "translation_keywords": [
        "谁知",
        "盘中餐",
        "米饭",
        "疑问"
      ],
      "explanation": "这句用反问的语气，提醒人们注意碗里的饭。“谁知”二字，带有一种感慨和责备，意思是很多人不知道粮食来得不容易。"
    },
    {
      "line_id": "EXTRA_021_L4",
      "content": "粒粒皆辛苦",
      "imagery": [
        "禾苗",
        "汗水",
        "粮食"
      ],
      "emotion": [
        "劳动",
        "节俭"
      ],
      "translation": "每一粒都饱含着农民辛苦的汗水啊！",
      "translation_keywords": [
        "粒粒",
        "辛苦",
        "汗水",
        "来之不易"
      ],
      "explanation": "这句点明主题，说明每一粒米都来之不易，都是农民用汗水换来的。“粒粒”重复，强调每一粒都很珍贵，“皆辛苦”直接说出劳动的艰辛。"
    }
  ]
}
