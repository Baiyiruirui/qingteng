  "lines": [
    {
      "line_id": "TANG_074_L1",
      "content": "谁在台城旧苑中，杨花飞尽绿阴空。",
      "imagery": [
        "台城",
        "旧苑",
        "杨花",
        "绿阴"
      ],
      "emotion": [
        "荒凉",
        "寂寥",
        "感伤"
      ],
      "translation": "曾经的台城旧苑如今还有谁居住呢？杨花已经飞尽，只有一片空荡荡的绿阴。",
      "translation_keywords": [
        "谁",
        "台城",
        "旧苑",
        "杨花",
        "飞尽",
        "绿阴",
        "空"
      ],
      "explanation": "诗人问，在金陵台城昔日的宫苑中，如今还有谁居住呢？杨花已经飘飞殆尽，只剩下空荡荡的绿色树荫，一片荒凉景象。"
    },
    {
      "line_id": "TANG_074_L2",
      "content": "台城日暮草萋萋，何处清歌拂楚衣。",
      "imagery": [
        "台城",
        "日暮",
        "草萋萋",
        "清歌",
        "楚衣"
      ],
      "emotion": [
        "怀古",
        "凄凉",
        "怅惘"
      ],
      "translation": "日暮时分，台城一片野草萋萋，不知何处传来清丽的歌声，似乎要拂动楚宫佳人的衣袂。",
      "translation_keywords": [
        "台城",
        "日暮",
        "草萋萋",
        "何处",
        "清歌",
        "拂",
        "楚衣"
      ],
      "explanation": "夕阳西下，台城旧址一片荒草丛生。何处还能听到清丽的歌声，像昔日楚宫佳人的歌舞声，拂动她们的衣袂？这既是对昔日繁华的追忆，也反衬了今日的萧条，表达了对历史变迁的感慨。"
    }
  ]
}