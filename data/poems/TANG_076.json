  "lines": [
    {
      "line_id": "TANG_076_L1",
      "content": "楚江微雨入寒烟，波浪兼天暗且连。",
      "imagery": [
        "楚江",
        "微雨",
        "寒烟",
        "波浪",
        "天"
      ],
      "emotion": [
        "离愁",
        "萧瑟",
        "苍茫"
      ],
      "translation": "楚江上飘着蒙蒙细雨，融入清冷的烟雾中，江水波浪滔天，与天空连接，显得昏暗而广阔。",
      "translation_keywords": [
        "楚江",
        "细雨",
        "融入",
        "寒烟",
        "波浪",
        "天空",
        "昏暗",
        "连接"
      ],
      "explanation": "诗人在楚江边送别友人，细雨蒙蒙，融入了清冷的江面烟雾中。江水波涛汹涌，与铅灰色的天空连成一片，显得苍茫昏暗，渲染了离别的萧瑟气氛。"
    },
    {
      "line_id": "TANG_076_L2",
      "content": "今夜扁舟来不来？得与明月伴君还。",
      "imagery": [
        "扁舟",
        "明月"
      ],
      "emotion": [
        "担忧",
        "关切",
        "期盼"
      ],
      "translation": "今晚你乘坐的小船能顺利回来吗？我多么希望明月能陪伴你平安归来。",
      "translation_keywords": [
        "今夜",
        "小船",
        "来不来",
        "明月",
        "陪伴",
        "君",
        "回来"
      ],
      "explanation": "面对这迷蒙的雨景和波涛汹涌的江面，诗人不禁担忧起来，发出疑问：今夜你的小船能顺利回来吗？希望有明月相伴，能够护送你平安归来。这既是对友人的深切关怀，也表现了依依不舍的惜别之情。"
    }
  ]
}