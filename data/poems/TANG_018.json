  "lines": [
    {
      "line_id": "TANG_018_L1",
      "content": "秦时明月汉时关",
      "imagery": [
        "明月",
        "关"
      ],
      "emotion": [
        "苍凉",
        "历史感"
      ],
      "translation": "秦朝时期的明月依然高悬，汉朝时期的边关依旧屹立。",
      "translation_keywords": [
        "秦时",
        "明月",
        "汉时",
        "关"
      ],
      "explanation": "首句点明了边塞特有的风物——明月和关塞，并通过“秦时”、“汉时”这两个时间状语，将历史的沧桑感赋予普通的景物，暗示了边塞战事的绵延不绝，营造出一种雄浑苍凉的氛围。"
    },
    {
      "line_id": "TANG_018_L2",
      "content": "万里长征人未还",
      "imagery": [],
      "emotion": [
        "悲壮",
        "伤感",
        "无奈"
      ],
      "translation": "长途远征的将士们啊，有多少人一去不复返！",
      "translation_keywords": [
        "万里",
        "长征",
        "人未还"
      ],
      "explanation": "这一句用夸张的手法写出了边塞征战的残酷性，无数将士离家万里，却再也未能归来。与上一句的历史感相呼应，将个体命运融入到宏大的历史背景中，深化了边塞战争的悲剧色彩。"
    },
    {
      "line_id": "TANG_018_L3",
      "content": "但使龙城飞将在",
      "imagery": [
        "龙城"
      ],
      "emotion": [
        "期盼",
        "豪迈"
      ],
      "translation": "只要有像当年飞将军李广那样的良将镇守边塞（龙城），",
      "translation_keywords": [
        "但使",
        "龙城",
        "飞将"
      ],
      "explanation": "诗人笔锋一转，转入对良将的渴望。用典“飞将”（指汉代名将李广），借李广在龙城外奇袭匈奴的典故，表达了对边防主帅的殷切期望和对国家安宁的深切关怀。这一句由悲壮转为慷慨激昂。"
    },
    {
      "line_id": "TANG_018_L4",
      "content": "不教胡马度阴山",
      "imagery": [
        "胡马",
        "阴山"
      ],
      "emotion": [
        "自信",
        "决心",
        "豪迈"
      ],
      "translation": "就绝不会让匈奴的战马越过阴山一步！",
      "translation_keywords": [
        "不教",
        "胡马",
        "度",
        "阴山"
      ],
      "explanation": "与上一句紧密相连，是诗人期望达成的结果。表达了只要有优秀将领，就能彻底抵御外敌入侵的决心和信心。全诗由历史的苍凉、战争的残酷，最终升华为对国家命运的关切和对边疆安定的强烈愿望，体现了盛唐时期昂扬自信的时代精神。"
    }
  ]
}