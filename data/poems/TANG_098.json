    "漂泊之苦"
  ],
  "imagery": [
    "岐王宅",
    "崔九堂",
    "江南好风景",
    "落花"
  ],
  "rhetoric": [
    "对比",
    "追忆",
    "烘托"
  ],
  "lines": [
    {
      "line_id": "TANG_098_L1",
      "content": "岐王宅里寻常见，",
      "imagery": [
        "岐王宅"
      ],
      "emotion": [
        "回忆",
        "怀念盛世"
      ],
      "translation": "在岐王的府邸里，我们常常相见。",
      "translation_keywords": [
        "岐王宅",
        "寻常见"
      ],
      "explanation": "回忆起安史之乱前，在唐玄宗的兄弟岐王的豪华府邸中，经常见到李龟年表演的繁盛景象。"
    },
    {
      "line_id": "TANG_098_L2",
      "content": "崔九堂前几度闻。",
      "imagery": [
        "崔九堂"
      ],
      "emotion": [
        "回忆",
        "怀念盛世"
      ],
      "translation": "在崔九的厅堂上，我不知多少次听到你的歌声。",
      "translation_keywords": [
        "崔九堂",
        "几度闻"
      ],
      "explanation": "进一步回忆在贵族崔九的家中，多次聆听李龟年美妙歌声的过往，表现出当年贵族生活的奢华与太平。"
    },
    {
      "line_id": "TANG_098_L3",
      "content": "正是江南好风景，",
      "imagery": [
        "江南好风景"
      ],
      "emotion": [
        "眼前景象",
        "触景生情"
      ],
      "translation": "如今正是江南风光美好的时节。",
      "translation_keywords": [
        "正是",
        "江南好风景"
      ],
      "explanation": "将思绪拉回当下，点明两人相逢的地点——江南，此时江南风景如画，却与诗人内心的悲凉形成对比。"
    },
    {
      "line_id": "TANG_098_L4",
      "content": "落花时节又逢君。",
      "imagery": [
        "落花"
      ],
      "emotion": [
        "悲凉",
        "沧桑",
        "伤感"
      ],
      "translation": "却偏偏在落英缤纷的时节，又一次遇见了你。",
      "translation_keywords": [
        "落花时节",
        "又逢君"
      ],
      "explanation": "在“落花时节”这个暗示衰败、伤感的背景下，与故人重逢，更添物是人非、国运衰微的悲凉与感慨。"
    }
  ]
}