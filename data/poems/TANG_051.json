  "lines": [
    {
      "line_id": "TANG_051_L1",
      "content": "江南好，风景旧曾谙。",
      "imagery": [
        "江南",
        "风景"
      ],
      "emotion": [
        "赞美",
        "熟悉",
        "喜爱"
      ],
      "translation": "江南真是个好地方，那里的风景我曾经非常熟悉。",
      "translation_keywords": [
        "江南",
        "好",
        "风景",
        "旧曾谙"
      ],
      "explanation": "开篇点题，直接表达了对江南的赞美和对曾经熟悉的江南风景的深情回忆，奠定全词的感情基调。"
    },
    {
      "line_id": "TANG_051_L2",
      "content": "日出江花红胜火，春来江水绿如蓝。",
      "imagery": [
        "日出",
        "江花",
        "火",
        "春",
        "江水",
        "蓝"
      ],
      "emotion": [
        "艳丽",
        "生机",
        "明媚",
        "欣喜"
      ],
      "translation": "太阳出来时，江边的花朵红艳得胜过火焰；春天到来时，江水碧绿得比蓝草还要深。",
      "translation_keywords": [
        "日出",
        "江花",
        "红胜火",
        "春来",
        "江水",
        "绿如蓝"
      ],
      "explanation": "色彩鲜明地描绘了江南春天的两个典型景物：红艳的江花和碧绿的江水，运用比喻，表现了江南春色的绚烂与生机勃勃。"
    },
    {
      "line_id": "TANG_051_L3",
      "content": "能不忆江南？",
      "imagery": [
        "江南"
      ],
      "emotion": [
        "强烈思念",
        "反问"
      ],
      "translation": "怎能不怀念江南呢？",
      "translation_keywords": [
        "能不",
        "忆江南"
      ],
      "explanation": "以反问句结尾，强调了诗人对江南的深切思念和难以忘怀的情感，深化了主题。"
    }
