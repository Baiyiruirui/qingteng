  ],
  "lines": [
    {
      "line_id": "EXTRA_036_L1",
      "content": "我家洗砚池头树",
      "imagery": [
        "墨梅",
        "清气"
      ],
      "emotion": [
        "咏物",
        "品格"
      ],
      "translation": "我家洗砚池边有一棵梅树。",
      "translation_keywords": [
        "我家",
        "洗砚池",
        "树"
      ],
      "explanation": "这句交代了梅树的位置——洗砚池边。洗砚池是王冕学画练字的地方，暗示这棵梅树与他的艺术生活紧密相连，为下文写墨梅的“淡墨痕”埋下伏笔。"
    },
    {
      "line_id": "EXTRA_036_L2",
      "content": "朵朵花开淡墨痕",
      "imagery": [
        "墨梅",
        "清气"
      ],
      "emotion": [
        "咏物",
        "品格"
      ],
      "translation": "每一朵梅花都带着淡淡的墨色痕迹。",
      "translation_keywords": [
        "朵朵",
        "花开",
        "淡墨痕"
      ],
      "explanation": "这句描写梅花的颜色——不是鲜艳的红色或白色，而是像用淡墨点染而成。一个“淡”字写出墨梅素雅、不张扬的特点，也暗含诗人对朴素之美的欣赏。"
    },
    {
      "line_id": "EXTRA_036_L3",
      "content": "不要人夸好颜色",
      "imagery": [
        "墨梅",
        "清气"
      ],
      "emotion": [
        "咏物",
        "品格"
      ],
      "translation": "不需要别人夸赞它的颜色好看。",
      "translation_keywords": [
        "不要",
        "人夸",
        "好颜色"
      ],
      "explanation": "这句直接表达墨梅的态度：它不在意别人的赞美。诗人用“不要”二字，强调墨梅不追求外在的艳丽，与世俗的审美形成对比，凸显其超脱、自信的品格。"
    },
    {
      "line_id": "EXTRA_036_L4",
      "content": "只留清气满乾坤",
      "imagery": [
        "墨梅",
        "清气"
      ],
      "emotion": [
        "咏物",
        "品格"
      ],
      "translation": "只愿留下清香的气味充满天地之间。",
      "translation_keywords": [
        "只留",
        "清气",
        "满乾坤"
      ],
      "explanation": "这句点明墨梅的真正追求：留下“清气”——既指梅花的清香，也象征高洁的品格和正气。“满乾坤”写出这种精神弥漫天地，影响深远。诗人借墨梅表达自己不愿随波逐流、只愿保持高尚情操的志向。"
    }
  ]
}
