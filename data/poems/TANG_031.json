  "lines": [
    {
      "line_id": "TANG_031_L1",
      "content": "客路青山外，",
      "imagery": [
        "客路 (旅途)",
        "青山"
      ],
      "emotion": [
        "旅途",
        "远望",
        "开阔"
      ],
      "translation": "行客的路途在青山之外，",
      "translation_keywords": [
        "旅客",
        "路途",
        "青山",
        "之外"
      ],
      "explanation": "诗人在旅途中，眼前是连绵的青山，点明了行旅的背景。"
    },
    {
      "line_id": "TANG_031_L2",
      "content": "行舟绿水前。",
      "imagery": [
        "行舟 (行驶的船)",
        "绿水"
      ],
      "emotion": [
        "动态",
        "顺畅",
        "广阔"
      ],
      "translation": "船只行驶在碧绿的江水之上。",
      "translation_keywords": [
        "行驶",
        "船只",
        "碧绿",
        "江水",
        "前"
      ],
      "explanation": "行船于碧绿江水之上，描绘出一幅广阔的江行图。"
    },
    {
      "line_id": "TANG_031_L3",
      "content": "潮平两岸阔，",
      "imagery": [
        "潮平 (潮水上涨)",
        "两岸阔 (两岸显得宽阔)"
      ],
      "emotion": [
        "平稳",
        "宽广",
        "舒畅"
      ],
      "translation": "潮水上涨，江面开阔，两岸显得更加宽广，",
      "translation_keywords": [
        "潮水",
        "平稳",
        "两岸",
        "宽阔"
      ],
      "explanation": "潮水上涨，江面变得平坦宽阔，两岸也显得更加开阔，视野辽远。"
    },
    {
      "line_id": "TANG_031_L4",
      "content": "风正一帆悬。",
      "imagery": [
        "风正 (顺风)",
        "一帆悬 (船帆高悬)"
      ],
      "emotion": [
        "顺畅",
        "顺利",
        "壮阔"
      ],
      "translation": "顺风鼓满船帆，船只高悬着一面帆快速前进。",
      "translation_keywords": [
        "风",
        "正",
        "一面帆",
        "高悬"
      ],
      "explanation": "顺风而行，船帆高悬，船只平稳快速前进，景象壮阔。这联写景富有动态美和哲理意蕴。"
    },
    {
      "line_id": "TANG_031_L5",
      "content": "海日生残夜，",
      "imagery": [
        "海日 (海上的日出)",
        "残夜 (夜色未尽)"
      ],
      "emotion": [
        "新生",
        "哲理",
        "循环",
        "壮丽"
      ],
      "translation": "旭日从海上升起，残余的夜色还未散尽，",
      "translation_keywords": [
        "海上",
        "日出",
        "产生",
        "残留",
        "夜晚"
      ],
      "explanation": "著名的警句。写海上日出，在夜色未尽时，太阳已经从海上升起，描绘了自然景物的循环变迁，富有哲理意味。"
    },
    {
      "line_id": "TANG_031_L6",
      "content": "江春入旧年。",
      "imagery": [
        "江春 (江南的春色)",
        "旧年 (旧岁)"
      ],
      "emotion": [
        "哲理",
        "时光流逝",
        "循环"
      ],
      "translation": "江南的春色已悄然来到，但旧年尚未完全过去。",
      "translation_keywords": [
        "江南",
        "春天",
        "进入",
        "旧年"
      ],
      "explanation": "另一句警句。江南的春色已到，但旧年尚未完全过去，展现了季节更迭的自然规律，时间与空间的交织。"
    },
    {
      "line_id": "TANG_031_L7",
      "content": "乡书何处达？",
      "imagery": [
        "乡书 (家书)"
      ],
      "emotion": [
        "思乡",
        "愁苦",
        "牵挂"
      ],
      "translation": "写给家乡的书信，要通过什么途径才能送达呢？",
      "translation_keywords": [
        "家书",
        "如何",
        "送达"
      ],
      "explanation": "诗人由景生情，发出对家乡的思念，担忧家书难以送达。"
    },
    {
      "line_id": "TANG_031_L8",
      "content": "归雁洛阳边。",
      "imagery": [
        "归雁 (北归的大雁)",
        "洛阳 (诗人故乡)"
      ],
      "emotion": [
        "寄托",
        "乡愁"
      ],
      "translation": "只有那北归的大雁，能飞到我的故乡洛阳边。",
      "translation_keywords": [
        "归来",
        "大雁",
        "洛阳",
        "旁边"
      ],
      "explanation": "诗人寄希望于北归的大雁能将家书带回故乡洛阳，表达了浓浓的乡愁。"
    }
  ]
}