{
  "poem_id": "EXTRA_015",
  "title": "滁州西涧",
  "author": "韦应物",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "山水",
    "闲适"
  ],
  "imagery": [
    "幽草",
    "黄鹂",
    "野渡"
  ],
  "rhetoric": [
    "以动衬静",
    "借景抒情",
    "对仗"
  ],
  "lines": [
    {
      "line_id": "EXTRA_015_L1",
      "content": "独怜幽草涧边生",
      "imagery": [
        "幽草",
        "黄鹂",
        "野渡"
      ],
      "emotion": [
        "山水",
        "闲适"
      ],
      "translation": "我特别喜爱那生长在涧边的幽静小草。",
      "translation_keywords": [
        "独",
        "怜",
        "幽草",
        "涧边",
        "生"
      ],
      "explanation": "首句写诗人独爱涧边幽草，一个“怜”字直接表达喜爱之情，“幽”字突出草之安静、不张扬，为全诗定下恬淡的基调。"
    },
    {
      "line_id": "EXTRA_015_L2",
      "content": "上有黄鹂深树鸣",
      "imagery": [
        "幽草",
        "黄鹂",
        "野渡"
      ],
      "emotion": [
        "山水",
        "闲适"
      ],
      "translation": "岸上茂密的树林深处，有黄鹂在婉转啼鸣。",
      "translation_keywords": [
        "上",
        "黄鹂",
        "深树",
        "鸣"
      ],
      "explanation": "第二句写高处深树中黄鹂的鸣叫，以动衬静，更显涧边幽静。黄鹂的清脆叫声与幽草的安静形成对比，画面有层次感。"
    },
    {
      "line_id": "EXTRA_015_L3",
      "content": "春潮带雨晚来急",
      "imagery": [
        "幽草",
        "黄鹂",
        "野渡"
      ],
      "emotion": [
        "山水",
        "闲适"
      ],
      "translation": "傍晚时分，春潮上涨，又加上急雨，水流更加湍急。",
      "translation_keywords": [
        "春潮",
        "带雨",
        "晚",
        "急"
      ],
      "explanation": "第三句写傍晚春潮和急雨，一个“急”字写出雨势和潮水的迅猛，为画面增添动态和紧张感，与前后句的静形成对比。"
    },
    {
      "line_id": "EXTRA_015_L4",
      "content": "野渡无人舟自横",
      "imagery": [
        "幽草",
        "黄鹂",
        "野渡"
      ],
      "emotion": [
        "山水",
        "闲适"
      ],
      "translation": "荒野渡口空无一人，只有小船独自横在水面上。",
      "translation_keywords": [
        "野渡",
        "无人",
        "舟",
        "自横"
      ],
      "explanation": "末句写野渡无人，小船自横。“自”字写出小船的悠闲自在，与上句的“急”形成对比，体现诗人对自然、自由状态的向往。"
    }
  ]
}
