  ],
  "rhetoric": [
    "衬托",
    "动静结合",
    "画面感",
    "烘托气氛"
  ],
  "lines": [
    {
      "line_id": "TANG_094_L1",
      "content": "月黑雁飞高",
      "imagery": [
        "月",
        "雁"
      ],
      "emotion": [
        "紧张",
        "深沉",
        "肃杀"
      ],
      "translation": "夜色深沉，月亮被乌云遮蔽，大雁在高空中惊飞。",
      "translation_keywords": [
        "月黑",
        "雁飞",
        "夜色"
      ],
      "explanation": "描绘了一个漆黑的夜晚，连大雁都因受到惊扰而高飞。这暗示了不同寻常的事件正在发生，营造出一种紧张而肃杀的边塞气氛。"
    },
    {
      "line_id": "TANG_094_L2",
      "content": "单于夜遁逃",
      "imagery": [
        "单于"
      ],
      "emotion": [
        "警觉",
        "发现",
        "激动"
      ],
      "translation": "敌方首领单于趁着夜色偷偷逃跑了。",
      "translation_keywords": [
        "单于",
        "夜遁",
        "逃跑"
      ],
      "explanation": "接上句的暗示，点明了敌方首领单于在夜色掩护下仓皇逃窜，说明我方边防将士的警觉和敌人的慌乱。"
    },
    {
      "line_id": "TANG_094_L3",
      "content": "欲将轻骑逐",
      "imagery": [
        "轻骑"
      ],
      "emotion": [
        "决心",
        "勇敢",
        "追击"
      ],
      "translation": "我方将士准备派出轻骑兵，趁势追击敌人。",
      "translation_keywords": [
        "欲将",
        "轻骑",
        "追逐"
      ],
      "explanation": "描述了我方将士发现敌情后，立即决定派精锐的轻骑兵去追击敌军，展现了将士们的英勇和果断。"
    },
    {
      "line_id": "TANG_094_L4",
      "content": "大雪满弓刀",
      "imagery": [
        "大雪",
        "弓",
        "刀"
      ],
      "emotion": [
        "严峻",
        "无畏",
        "壮烈"
      ],
      "translation": "然而，边塞大雪纷飞，弓箭和战刀上都积满了雪。",
      "translation_keywords": [
        "大雪",
        "弓刀",
        "严寒"
      ],
      "explanation": "画面一转，点出边塞环境的恶劣，大雪覆盖了弓刀，既是对环境的写实，也衬托了将士们在极端困难下仍坚持战斗的无畏精神，充满力量感和悲壮色彩。"
    }
  ]
}