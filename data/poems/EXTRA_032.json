{
  "poem_id": "EXTRA_032",
  "title": "夏日绝句",
  "author": "李清照",
  "dynasty": "宋",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "家国",
    "气节"
  ],
  "imagery": [
    "项羽",
    "江东"
  ],
  "rhetoric": [
    "对比",
    "用典",
    "直抒胸臆"
  ],
  "lines": [
    {
      "line_id": "EXTRA_032_L1",
      "content": "生当作人杰",
      "imagery": [
        "项羽",
        "江东"
      ],
      "emotion": [
        "家国",
        "气节"
      ],
      "translation": "活着的时候应当做人中的豪杰。",
      "translation_keywords": [
        "活着",
        "应当",
        "人中的豪杰"
      ],
      "explanation": "这句诗直接表达了诗人对人生价值的看法，认为人活着就要有担当、有作为，做顶天立地的英雄。语气坚定，充满力量。"
    },
    {
      "line_id": "EXTRA_032_L2",
      "content": "死亦为鬼雄",
      "imagery": [
        "项羽",
        "江东"
      ],
      "emotion": [
        "家国",
        "气节"
      ],
      "translation": "死了也要成为鬼中的英雄。",
      "translation_keywords": [
        "死了",
        "也要",
        "鬼中的英雄"
      ],
      "explanation": "这句与上一句形成对比，强调无论生死都要保持英雄气概。诗人用“鬼雄”一词，突出即使死后也不屈服的精神，情感悲壮。"
    },
    {
      "line_id": "EXTRA_032_L3",
      "content": "至今思项羽",
      "imagery": [
        "项羽",
        "江东"
      ],
      "emotion": [
        "家国",
        "气节"
      ],
      "translation": "到今天人们还在思念项羽。",
      "translation_keywords": [
        "到今天",
        "思念",
        "项羽"
      ],
      "explanation": "诗人引用项羽的典故，表达对这位英雄的敬佩。项羽在乌江自刎，宁死不屈，这种精神让后人怀念。"
    },
    {
      "line_id": "EXTRA_032_L4",
      "content": "不肯过江东",
      "imagery": [
        "项羽",
        "江东"
      ],
      "emotion": [
        "家国",
        "气节"
      ],
      "translation": "因为他宁死也不肯回到江东去。",
      "translation_keywords": [
        "不肯",
        "回到",
        "江东"
      ],
      "explanation": "这句解释了思念项羽的原因：他兵败后无颜见江东父老，选择自杀。诗人借此讽刺南宋朝廷的懦弱，表达对英雄气节的赞美。"
    }
  ]
}
