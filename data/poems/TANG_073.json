  "lines": [
    {
      "line_id": "TANG_073_L1",
      "content": "烟笼寒水月笼沙，夜泊秦淮近酒家。",
      "imagery": [
        "烟",
        "寒水",
        "月",
        "沙",
        "秦淮",
        "酒家"
      ],
      "emotion": [
        "寂寥",
        "清冷"
      ],
      "translation": "暮色苍茫，烟雾笼罩着寒凉的水面，月光轻柔地洒在沙洲上，夜晚我将船停泊在秦淮河边，靠近酒家。",
      "translation_keywords": [
        "烟",
        "笼罩",
        "寒水",
        "月",
        "笼罩",
        "沙",
        "夜晚",
        "停泊",
        "秦淮",
        "靠近",
        "酒家"
      ],
      "explanation": "诗人描绘了秦淮河畔傍晚的清冷景色：烟雾弥漫在寒凉的河水上，月光朦胧地洒在沙滩边。诗人夜宿秦淮河畔，船停在靠近酒家的地方。"
    },
    {
      "line_id": "TANG_073_L2",
      "content": "商女不知亡国恨，隔江犹唱后庭花。",
      "imagery": [
        "商女",
        "亡国恨",
        "后庭花"
      ],
      "emotion": [
        "痛心",
        "批判",
        "讽刺"
      ],
      "translation": "那些歌女不懂得国家灭亡的痛苦，隔着江水还在歌唱着那亡国之音《后庭花》。",
      "translation_keywords": [
        "歌女",
        "不懂",
        "亡国恨",
        "隔江",
        "歌唱",
        "后庭花"
      ],
      "explanation": "诗人听见酒家歌女们依然在高歌《后庭花》，这首曲子正是南朝陈后主沉迷声色导致亡国的象征。诗人借此表达了对当时统治者不思进取、沉湎享乐，国家危亡却浑然不知的痛心与愤慨，充满讽刺意味。"
    }
  ]
