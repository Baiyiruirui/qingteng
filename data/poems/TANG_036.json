  "lines": [
    {
      "line_id": "TANG_036_L1",
      "content": "金樽清酒斗十千，玉盘珍羞直万钱。",
      "imagery": [
        "金樽",
        "清酒",
        "玉盘",
        "珍羞"
      ],
      "emotion": [
        "宴乐",
        "富贵",
        "奢华"
      ],
      "translation": "金杯里盛着名贵的清酒，一斗价值十千钱；玉盘中摆着珍美的菜肴，价值万钱。",
      "translation_keywords": [
        "金樽",
        "清酒",
        "斗十千",
        "玉盘",
        "珍羞",
        "直万钱"
      ],
      "explanation": "开篇描绘了豪奢的宴饮场面，暗示了诗人早期入京时的踌躇满志和被款待的荣耀，为下文的失意作铺垫。"
    },
    {
      "line_id": "TANG_036_L2",
      "content": "停杯投箸不能食，拔剑四顾心茫然。",
      "imagery": [
        "杯",
        "箸",
        "剑"
      ],
      "emotion": [
        "烦闷",
        "迷茫",
        "失意",
        "愤懑"
      ],
      "translation": "我放下酒杯，扔下筷子，无法下咽；拔出宝剑，环顾四周，心中一片茫然。",
      "translation_keywords": [
        "停杯",
        "投箸",
        "不能食",
        "拔剑",
        "四顾",
        "心茫然"
      ],
      "explanation": "诗人面对盛宴却食不下咽，内心充满苦闷和迷茫，与上句形成强烈对比，点出“行路难”的困境和其内心无法排解的忧愤。"
    },
    {
      "line_id": "TANG_036_L3",
      "content": "欲渡黄河冰塞川，将登太行雪满山。",
      "imagery": [
        "黄河",
        "冰",
        "太行",
        "雪"
      ],
      "emotion": [
        "困境",
        "阻碍",
        "绝望",
        "艰难"
      ],
      "translation": "想要渡过黄河，却发现冰雪阻塞了河道；想要攀登太行山，却见大雪覆盖了群山。",
      "translation_keywords": [
        "欲渡黄河",
        "冰塞川",
        "将登太行",
        "雪满山"
      ],
      "explanation": "用黄河冰塞、太行雪满的意象，比喻前途的艰险和重重阻碍，象征诗人政治抱负难以施展的困境，突出“行路难”的深层含义。"
    },
    {
      "line_id": "TANG_036_L4",
      "content": "闲来垂钓碧溪上，忽复乘舟梦日边。",
      "imagery": [
        "碧溪",
        "钓",
        "舟",
        "日边"
      ],
      "emotion": [
        "隐逸",
        "怀才",
        "不甘",
        "抱负"
      ],
      "translation": "闲暇时我曾在碧绿的溪水边垂钓，又忽然梦见自己乘船到了太阳边。",
      "translation_keywords": [
        "闲来",
        "垂钓碧溪",
        "忽复",
        "乘舟",
        "梦日边"
      ],
      "explanation": "用姜太公垂钓和伊尹梦日这两个典故，暗示自己身怀奇才，心怀天下，渴望得到重用，但又不得志的矛盾心理。"
    },
    {
      "line_id": "TANG_036_L5",
      "content": "行路难，行路难，多歧路，今安在？",
      "imagery": [
        "歧路"
      ],
      "emotion": [
        "困惑",
        "迷茫",
        "感叹",
        "彷徨"
      ],
      "translation": "行路难啊，行路难！人生的道路岔口太多，如今我又该何去何从呢？",
      "translation_keywords": [
        "行路难",
        "多歧路",
        "今安在"
      ],
      "explanation": "诗人直接发出“行路难”的感慨，反复强调，表达了在政治上进退维谷的困惑和迷茫，点明诗歌主旨，将内心的痛苦推向极致。"
    },
    {
      "line_id": "TANG_036_L6",
      "content": "长风破浪会有时，直挂云帆济沧海。",
      "imagery": [
        "长风",
        "浪",
        "云帆",
        "沧海"
      ],
      "emotion": [
        "乐观",
        "自信",
        "豪迈",
        "抱负",
        "豁达"
      ],
      "translation": "总有一天会乘长风破万里浪，高高挂起云帆，横渡浩瀚的沧海。",
      "translation_keywords": [
        "长风破浪",
        "会有时",
        "直挂云帆",
        "济沧海"
      ],
      "explanation": "诗歌的结尾一转，表达了诗人坚定的信念和乐观精神，即使前路艰难，也终有实现抱负、乘风破浪济沧海的那一天，充满豪迈气概和对未来的憧憬。"
