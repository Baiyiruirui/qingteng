{
  "poem_id": "EXTRA_027",
  "title": "泊船瓜洲",
  "author": "王安石",
  "dynasty": "宋",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "思乡",
    "春景"
  ],
  "imagery": [
    "春风",
    "江南",
    "明月"
  ],
  "rhetoric": [
    "设问",
    "炼字",
    "借景抒情"
  ],
  "lines": [
    {
      "line_id": "EXTRA_027_L1",
      "content": "京口瓜洲一水间",
      "imagery": [
        "春风",
        "江南",
        "明月"
      ],
      "emotion": [
        "思乡",
        "春景"
      ],
      "translation": "京口和瓜洲之间只隔着一条长江水。",
      "translation_keywords": [
        "京口",
        "瓜洲",
        "一水",
        "间"
      ],
      "explanation": "这句写诗人站在瓜洲渡口，远望对岸的京口，觉得两地只隔着一条江水，距离很近。用“一水间”三个字，既写出空间上的近，也暗示诗人归心似箭，觉得家乡就在眼前。"
    },
    {
      "line_id": "EXTRA_027_L2",
      "content": "钟山只隔数重山",
      "imagery": [
        "春风",
        "江南",
        "明月"
      ],
      "emotion": [
        "思乡",
        "春景"
      ],
      "translation": "我所居住的钟山，也只隔着几座山而已。",
      "translation_keywords": [
        "钟山",
        "只隔",
        "数重山"
      ],
      "explanation": "诗人继续远望，想到自己的家——钟山，也不过被几座山挡住。用“只隔”和“数重山”，强调距离其实不远，但偏偏不能立刻回去，透露出淡淡的无奈和思念。"
    },
    {
      "line_id": "EXTRA_027_L3",
      "content": "春风又绿江南岸",
      "imagery": [
        "春风",
        "江南",
        "明月"
      ],
      "emotion": [
        "思乡",
        "春景"
      ],
      "translation": "春风吹来，又让长江南岸的草木变绿了。",
      "translation_keywords": [
        "春风",
        "又",
        "绿",
        "江南岸"
      ],
      "explanation": "这一句是名句，妙在“绿”字。本来“绿”是形容词，这里用作动词，写出春风一吹，江南岸立刻变得生机勃勃。一个“又”字，点出时间流逝，诗人离家已久，看到春草又绿，更想回家了。"
    },
    {
      "line_id": "EXTRA_027_L4",
      "content": "明月何时照我还",
      "imagery": [
        "春风",
        "江南",
        "明月"
      ],
      "emotion": [
        "思乡",
        "春景"
      ],
      "translation": "天上的明月啊，你什么时候才能照着我回到家乡呢？",
      "translation_keywords": [
        "明月",
        "何时",
        "照",
        "我还"
      ],
      "explanation": "诗人对着明月发问，借明月表达归乡的渴望。明月是古人寄托思念的常见意象，这里用“何时”直接问，情感强烈，把前面积蓄的思乡之情一下子抒发出来。"
    }
  ]
}
