{
  "poem_id": "TANG_022",
  "title": "竹里馆",
  "author": "王维",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "隐逸生活",
    "宁静致远",
    "闲适",
    "孤独"
  ],
  "imagery": [
    "竹林",
    "明月",
    "幽深",
    "独坐",
    "弹琴"
  ],
  "rhetoric": [
    "动静结合",
    "以景衬情",
    "白描"
  ],
  "lines": [
    {
      "line_id": "TANG_022_L1",
      "content": "独坐幽篁里，",
      "imagery": [
        "幽篁 (深邃的竹林)",
        "独坐 (独自一人)"
      ],
      "emotion": [
        "幽静",
        "闲适",
        "略带孤寂"
      ],
      "translation": "独自一人坐在幽深的竹林里，",
      "translation_keywords": [
        "独自",
        "坐",
        "幽深",
        "竹林"
      ],
      "explanation": "诗人独自坐在清幽的竹林深处，营造出一种宁静而略带孤寂的氛围。"
    },
    {
      "line_id": "TANG_022_L2",
      "content": "弹琴复长啸。",
      "imagery": [
        "弹琴",
        "长啸 (高声长吟)"
      ],
      "emotion": [
        "怡然自得",
        "超然物外",
        "闲适"
      ],
      "translation": "又弹琴又高声长啸。",
      "translation_keywords": [
        "弹琴",
        "又",
        "高声长啸"
      ],
      "explanation": "诗人或弹琴自娱，或引吭长啸，表现出超然物外、悠然自得的隐士情怀。"
    },
    {
      "line_id": "TANG_022_L3",
      "content": "深林人不知，",
      "imagery": [
        "深林",
        "人 (他人)"
      ],
      "emotion": [
        "隐逸",
        "不求人知",
        "自我欣赏"
      ],
      "translation": "深深的竹林中没有人知道，",
      "translation_keywords": [
        "深深",
        "竹林",
        "人",
        "不知道"
      ],
      "explanation": "诗人身处深山密林之中，没有人知道他的存在，暗示他远离尘嚣，不求名利。"
    },
    {
      "line_id": "TANG_022_L4",
      "content": "明月来相照。",
      "imagery": [
        "明月",
        "相照"
      ],
      "emotion": [
        "宁静",
        "陪伴",
        "慰藉",
        "天人合一"
      ],
      "translation": "只有明月过来与我相伴。",
      "translation_keywords": [
        "只有",
        "明月",
        "来",
        "相伴"
      ],
      "explanation": "只有皎洁的明月投下清辉，与诗人作伴，更显出环境的幽静和诗人内心的澄澈，达到天人合一的境界。"
    }
  ]
}