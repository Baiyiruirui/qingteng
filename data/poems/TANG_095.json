  "imagery": [
    "琵琶",
    "新声",
    "关山",
    "秋月",
    "长城"
  ],
  "rhetoric": [
    "以乐写哀",
    "反衬",
    "对比",
    "借景抒情",
    "烘托气氛"
  ],
  "lines": [
    {
      "line_id": "TANG_095_L1",
      "content": "琵琶起舞换新声",
      "imagery": [
        "琵琶",
        "新声"
      ],
      "emotion": [
        "欢快"
      ],
      "translation": "琵琶弹奏起欢快的乐曲，换了新的调子，伴随着将士们起舞。",
      "translation_keywords": [
        "琵琶",
        "起舞",
        "新声",
        "乐曲"
      ],
      "explanation": "描绘了边塞宴会上，琵琶奏起新的、或许是轻快的曲调，伴随着歌舞。这是一种表面的热闹，为下句的愁绪做铺垫。"
    },
    {
      "line_id": "TANG_095_L2",
      "content": "总是关山旧别情",
      "imagery": [
        "关山"
      ],
      "emotion": [
        "深沉",
        "无奈",
        "思乡"
      ],
      "translation": "但无论乐声如何变化，演奏的总是那令人心酸的边塞离别之情。",
      "translation_keywords": [
        "总是",
        "关山",
        "旧别情",
        "离愁"
      ],
      "explanation": "琵琶曲调虽新，却无法改变将士们心中那挥之不去的边塞特有的离愁别绪和对故乡的思念，表达了乐景衬哀情的深层含义。"
    },
    {
      "line_id": "TANG_095_L3",
      "content": "撩乱边愁听不尽",
      "imagery": [],
      "emotion": [
        "愁苦",
        "烦乱",
        "无止境"
      ],
      "translation": "缠绕心头的边塞离愁，听着琵琶声，越发觉得无法排遣，听也听不完。",
      "translation_keywords": [
        "撩乱",
        "边愁",
        "听不尽",
        "愁绪"
      ],
      "explanation": "将士们听着琵琶声，内心的边愁被撩拨得更加纷乱，仿佛无穷无尽，无法通过音乐来消解。"
    },
    {
      "line_id": "TANG_095_L4",
      "content": "高高秋月照长城",
      "imagery": [
        "秋月",
        "长城"
      ],
      "emotion": [
        "悲壮",
        "苍凉",
        "永恒",
        "孤寂"
      ],
      "translation": "高悬的秋月依旧寂寞地照耀着雄伟的长城。",
      "translation_keywords": [
        "高高",
        "秋月",
        "照",
        "长城"
      ],
      "explanation": "视野由室内转到室外，将边愁与广阔的边塞景象结合。一轮明月高悬夜空，映照着蜿蜒的长城，显得雄伟而又苍凉，衬托出将士们在宏大背景下的个体悲愁。"
    }
  ]
}