{
  "poem_id": "EXTRA_031",
  "title": "惠崇春江晚景",
  "author": "苏轼",
  "dynasty": "宋",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "春景",
    "自然"
  ],
  "imagery": [
    "桃花",
    "春江",
    "鸭"
  ],
  "rhetoric": [
    "拟人",
    "联想",
    "虚实结合"
  ],
  "lines": [
    {
      "line_id": "EXTRA_031_L1",
      "content": "竹外桃花三两枝",
      "imagery": [
        "桃花",
        "春江",
        "鸭"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "竹林外，两三枝桃花刚刚开放。",
      "translation_keywords": [
        "竹林",
        "外面",
        "桃花",
        "两三枝",
        "开放"
      ],
      "explanation": "这句写早春的景色。用“竹外”点出桃花的位置，用“三两枝”写出桃花刚刚开放，数量不多，却让人感受到春天的气息。竹子的青翠和桃花的粉红相互映衬，色彩鲜明。"
    },
    {
      "line_id": "EXTRA_031_L2",
      "content": "春江水暖鸭先知",
      "imagery": [
        "桃花",
        "春江",
        "鸭"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "春天江水变暖了，鸭子最先知道。",
      "translation_keywords": [
        "春江",
        "水暖",
        "鸭子",
        "最先",
        "知道"
      ],
      "explanation": "这句运用了拟人的手法，说鸭子“先知”水暖，生动地写出鸭子对水温变化的敏感。鸭子在水里嬉戏，让人联想到江水已经回暖，充满生机。"
    },
    {
      "line_id": "EXTRA_031_L3",
      "content": "蒌蒿满地芦芽短",
      "imagery": [
        "桃花",
        "春江",
        "鸭"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "河滩上长满了蒌蒿，芦笋也刚冒出短芽。",
      "translation_keywords": [
        "蒌蒿",
        "满地",
        "芦芽",
        "短",
        "生长"
      ],
      "explanation": "这句写岸边的植物。“蒌蒿满地”说明蒌蒿已经长得很茂盛，“芦芽短”则写出芦笋刚刚破土，还很短小。一盛一嫩，展现了早春植物生长的不同状态。"
    },
    {
      "line_id": "EXTRA_031_L4",
      "content": "正是河豚欲上时",
      "imagery": [
        "桃花",
        "春江",
        "鸭"
      ],
      "emotion": [
        "春景",
        "自然"
      ],
      "translation": "这正是河豚将要逆流而上产卵的时候。",
      "translation_keywords": [
        "正是",
        "河豚",
        "将要",
        "上",
        "时候"
      ],
      "explanation": "这句由眼前景物联想到河豚。诗人看到蒌蒿和芦芽，想到河豚喜欢吃的食物出现了，所以推测河豚快要逆流而上了。这是虚写，让画面从静态变成动态，充满期待。"
    }
  ]
}
