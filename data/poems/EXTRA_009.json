{
  "poem_id": "EXTRA_009",
  "title": "芙蓉楼送辛渐",
  "author": "王昌龄",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "送别",
    "品格"
  ],
  "imagery": [
    "寒雨",
    "楚山",
    "冰心"
  ],
  "rhetoric": [
    "比喻",
    "借景抒情",
    "象征"
  ],
  "lines": [
    {
      "line_id": "EXTRA_009_L1",
      "content": "寒雨连江夜入吴",
      "imagery": [
        "寒雨",
        "楚山",
        "冰心"
      ],
      "emotion": [
        "送别",
        "品格"
      ],
      "translation": "冰冷的秋雨笼罩着江面，在夜里洒遍了吴地。",
      "translation_keywords": [
        "寒雨",
        "连江",
        "夜",
        "吴"
      ],
      "explanation": "这句写送别时的环境。用“寒雨”“连江”渲染出凄冷、迷蒙的氛围，为全诗定下离别的伤感基调。"
    },
    {
      "line_id": "EXTRA_009_L2",
      "content": "平明送客楚山孤",
      "imagery": [
        "寒雨",
        "楚山",
        "冰心"
      ],
      "emotion": [
        "送别",
        "品格"
      ],
      "translation": "天亮时送别朋友，只觉得远处的楚山也显得孤零零的。",
      "translation_keywords": [
        "平明",
        "送客",
        "楚山",
        "孤"
      ],
      "explanation": "“平明”点明送别时间，“楚山孤”既是写山，也是写诗人内心的孤独感，借山的孤寂衬托自己送别后的落寞。"
    },
    {
      "line_id": "EXTRA_009_L3",
      "content": "洛阳亲友如相问",
      "imagery": [
        "寒雨",
        "楚山",
        "冰心"
      ],
      "emotion": [
        "送别",
        "品格"
      ],
      "translation": "如果洛阳的亲友问起我的近况，请你转告他们。",
      "translation_keywords": [
        "洛阳",
        "亲友",
        "相问"
      ],
      "explanation": "这句是诗人对朋友辛渐的嘱托，语气亲切，表达了对家乡亲友的思念，也为下一句的自我表白作铺垫。"
    },
    {
      "line_id": "EXTRA_009_L4",
      "content": "一片冰心在玉壶",
      "imagery": [
        "寒雨",
        "楚山",
        "冰心"
      ],
      "emotion": [
        "送别",
        "品格"
      ],
      "translation": "我的心依然像玉壶里的冰一样纯洁、清白。",
      "translation_keywords": [
        "冰心",
        "玉壶"
      ],
      "explanation": "“冰心”比喻高洁的品格，“玉壶”象征纯净。诗人用这个比喻告诉亲友，自己虽身处逆境，但依然保持高尚的节操。"
    }
  ]
}
