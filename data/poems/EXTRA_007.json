{
  "poem_id": "EXTRA_007",
  "title": "凉州词",
  "author": "王之涣",
  "dynasty": "唐",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "边塞",
    "苍凉"
  ],
  "imagery": [
    "黄河",
    "孤城",
    "羌笛"
  ],
  "rhetoric": [
    "夸张",
    "拟人",
    "双关",
    "对比"
  ],
  "lines": [
    {
      "line_id": "EXTRA_007_L1",
      "content": "黄河远上白云间",
      "imagery": [
        "黄河",
        "孤城",
        "羌笛"
      ],
      "emotion": [
        "边塞",
        "苍凉"
      ],
      "translation": "远远望去，黄河好像一直延伸到天边的白云之间。",
      "translation_keywords": [
        "黄河",
        "远上",
        "白云间",
        "延伸"
      ],
      "explanation": "这句诗用夸张的手法，描绘了黄河的壮阔与遥远。诗人站在高处远望，觉得黄河仿佛与天边的白云连在一起，给人一种苍茫、辽阔的感觉。"
    },
    {
      "line_id": "EXTRA_007_L2",
      "content": "一片孤城万仞山",
      "imagery": [
        "黄河",
        "孤城",
        "羌笛"
      ],
      "emotion": [
        "边塞",
        "苍凉"
      ],
      "translation": "在万丈高山的环抱中，只有一座孤零零的城池。",
      "translation_keywords": [
        "孤城",
        "万仞山",
        "环抱",
        "孤零零"
      ],
      "explanation": "“孤城”和“万仞山”形成强烈对比，突出了边塞的荒凉和孤独。一座小小的城池被重重高山包围，显得格外寂寞，也暗示了戍边将士的艰苦处境。"
    },
    {
      "line_id": "EXTRA_007_L3",
      "content": "羌笛何须怨杨柳",
      "imagery": [
        "黄河",
        "孤城",
        "羌笛"
      ],
      "emotion": [
        "边塞",
        "苍凉"
      ],
      "translation": "羌笛何必吹奏那哀怨的《折杨柳》曲调呢？",
      "translation_keywords": [
        "羌笛",
        "何须",
        "怨",
        "杨柳"
      ],
      "explanation": "“羌笛”是边塞常见的乐器，“杨柳”既指曲名《折杨柳》，也暗指杨柳本身。诗人用拟人手法，说羌笛在“怨”杨柳，其实是表达戍边将士的思乡之情。一个“何须”带着无奈和劝慰的语气。"
    },
    {
      "line_id": "EXTRA_007_L4",
      "content": "春风不度玉门关",
      "imagery": [
        "黄河",
        "孤城",
        "羌笛"
      ],
      "emotion": [
        "边塞",
        "苍凉"
      ],
      "translation": "因为春风是吹不到玉门关外的。",
      "translation_keywords": [
        "春风",
        "不度",
        "玉门关",
        "吹不到"
      ],
      "explanation": "“春风”既指自然界的春风，也暗指朝廷的关怀。玉门关外是苦寒的边塞，春风都吹不到，更别说温暖和恩惠了。这句诗含蓄地表达了戍边将士对朝廷不体恤边关将士的怨愤，也加深了思乡的悲凉。"
    }
  ]
}
