  "lines": [
    {
      "line_id": "TANG_015_L1",
      "content": "清明时节雨纷纷",
      "imagery": [
        "清明时节",
        "雨纷纷"
      ],
      "emotion": [
        "迷蒙",
        "哀愁"
      ],
      "translation": "清明节的时候，细雨纷纷扬扬地下着。",
      "translation_keywords": [
        "清明",
        "时节",
        "雨纷纷"
      ],
      "explanation": "开篇点明特定节气“清明”，并以“雨纷纷”描绘了迷蒙、阴湿的天气景象，营造出一种愁绪弥漫的氛围，为全诗奠定基调。"
    },
    {
      "line_id": "TANG_015_L2",
      "content": "路上行人欲断魂",
      "imagery": [
        "路上行人"
      ],
      "emotion": [
        "悲伤",
        "愁苦",
        "思念"
      ],
      "translation": "路上的行人，心情郁闷得好像魂魄都要断裂了一样。",
      "translation_keywords": [
        "路上行人",
        "欲断魂"
      ],
      "explanation": "承接上句雨景，直接抒发了行人在清明时节的强烈哀愁。“欲断魂”是极度的夸张，生动地表现了行人因思念亲人、感伤身世而产生的愁苦与迷惘，与纷纷细雨形成情感上的呼应。"
    },
    {
      "line_id": "TANG_015_L3",
      "content": "借问酒家何处有",
      "imagery": [
        "酒家"
      ],
      "emotion": [
        "寻求慰藉",
        "迷茫",
        "无助"
      ],
      "translation": "我借问一声，哪里有卖酒的人家呢？",
      "translation_keywords": [
        "借问",
        "酒家",
        "何处有"
      ],
      "explanation": "诗人面对愁苦，希望能借酒浇愁，化解内心的郁闷。这一问，不仅体现了他内心的迷茫和无助，也暗示了当时身处异乡、孤单无依的境况。"
    },
    {
      "line_id": "TANG_015_L4",
      "content": "牧童遥指杏花村",
      "imagery": [
        "牧童",
        "遥指",
        "杏花村"
      ],
      "emotion": [
        "豁然开朗",
        "希望",
        "轻松"
      ],
      "translation": "一位牧童远远地用手指着前方说：那里有座杏花村。",
      "translation_keywords": [
        "牧童",
        "遥指",
        "杏花村"
      ],
      "explanation": "诗歌的高潮和转折点。牧童的出现和“遥指”的动作，为迷途的行人指明了方向，也带来了希望。“杏花村”不仅是酒家的具体地点，更是春意盎然、生机勃勃的象征，冲淡了前文的愁苦，使全诗在略带希望的意境中收束。"
    }
  ]
