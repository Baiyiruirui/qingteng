  "lines": [
    {
      "line_id": "TANG_064_L1",
      "content": "青海长云暗雪山",
      "imagery": [
        "青海",
        "长云",
        "雪山"
      ],
      "emotion": [
        "苍凉",
        "雄浑",
        "压抑"
      ],
      "translation": "青海湖上空弥漫着层层乌云，把远处的雪山都遮蔽得暗淡无光。",
      "translation_keywords": [
        "青海",
        "长云",
        "雪山"
      ],
      "explanation": "描绘了边塞辽阔而苍凉的景象，点明了边塞特有的地理环境，渲染了战争前夕凝重肃穆的气氛。"
    },
    {
      "line_id": "TANG_064_L2",
      "content": "孤城遥望玉门关",
      "imagery": [
        "孤城",
        "玉门关"
      ],
      "emotion": [
        "孤寂",
        "悲壮",
        "遥远"
      ],
      "translation": "从这座孤零零的边城遥望着远方的玉门关。",
      "translation_keywords": [
        "孤城",
        "玉门关"
      ],
      "explanation": "以“孤城”和“玉门关”点出边塞的遥远和环境的恶劣，进一步烘托了将士们身处边疆的孤寂感和使命感。"
    },
    {
      "line_id": "TANG_064_L3",
      "content": "黄沙百战穿金甲",
      "imagery": [
        "黄沙",
        "金甲"
      ],
      "emotion": [
        "艰苦",
        "悲壮",
        "坚韧"
      ],
      "translation": "将士们身经百战，身上的金甲已经被磨穿。",
      "translation_keywords": [
        "黄沙",
        "百战",
        "穿金甲"
      ],
      "explanation": "极言战争的频繁和残酷，将士们长年征战，磨穿金甲，表现了他们饱经风霜、艰苦卓绝的战斗生活。"
    },
    {
      "line_id": "TANG_064_L4",
      "content": "不破楼兰终不还",
      "imagery": [
        "楼兰"
      ],
      "emotion": [
        "决心",
        "豪迈",
        "牺牲"
      ],
      "translation": "誓不攻破楼兰，绝不回还家乡。",
      "translation_keywords": [
        "不破",
        "楼兰",
        "终不还"
      ],
      "explanation": "表达了将士们誓死报国、不惜牺牲的壮志豪情，是全诗的精髓，点明了从军的目的和决心。"
    }
  ]
}