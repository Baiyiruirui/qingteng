{
  "poem_id": "TANG_037",
  "title": "望天门山",
  "author": "李白",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "祖国山河壮丽",
    "自然风光描写",
    "诗人豪迈情怀",
    "人与自然的和谐"
  ],
  "imagery": [
    "天门山",
    "楚江",
    "长江",
    "碧水",
    "两岸青山",
    "一叶孤帆",
    "日边"
  ],
  "rhetoric": [
    "比喻",
    "借代",
    "衬托",
    "动静结合"
  ],
  "lines": [
    {
      "line_id": "TANG_037_L1",
      "content": "天门中断楚江开，",
      "imagery": [
        "天门山",
        "楚江"
      ],
      "emotion": [
        "壮阔",
        "开阔"
      ],
      "translation": "天门山被长江从中截断，江水汹涌奔腾。",
      "translation_keywords": [
        "天门中断",
        "楚江开"
      ],
      "explanation": "描写长江穿过天门山，将原本连绵的山势一分为二，景象极为壮观，气势磅礴。"
    },
    {
      "line_id": "TANG_037_L2",
      "content": "碧水东流至此回。",
      "imagery": [
        "碧水"
      ],
      "emotion": [
        "雄伟",
        "浩荡"
      ],
      "translation": "碧绿的江水东流到这里，却似乎回旋了一下才继续奔涌。",
      "translation_keywords": [
        "碧水东流",
        "至此回"
      ],
      "explanation": "承接上句，进一步描绘了长江水势的浩大，尽管大江东去，但在天门山处，也似乎因山势阻碍而形成回旋，更显力量。"
    },
    {
      "line_id": "TANG_037_L3",
      "content": "两岸青山相对出，",
      "imagery": [
        "两岸青山"
      ],
      "emotion": [
        "对峙",
        "生机勃勃"
      ],
      "translation": "两岸的青山夹江而立，仿佛面对面地从远处涌现出来。",
      "translation_keywords": [
        "两岸青山",
        "相对出"
      ],
      "explanation": "诗人的视线从江水转向两岸，青山相对而立，有一种动态感，仿佛它们随着船行而迎面而来，雄伟而充满生机。"
    },
    {
      "line_id": "TANG_037_L4",
      "content": "孤帆一片日边来。",
      "imagery": [
        "孤帆",
        "日边"
      ],
      "emotion": [
        "辽远",
        "开阔",
        "希望"
      ],
      "translation": "远处一片孤帆，仿佛从太阳升起的地方缓缓而来。",
      "translation_keywords": [
        "孤帆一片",
        "日边来"
      ],
      "explanation": "以“孤帆”和“日边”的遥远意象，进一步烘托出江面的广阔和天地的悠远，也暗示了诗人的渺小与壮阔自然形成对比，同时寄寓了一丝旅途的思绪。"
    }
  ]
}