{
  "poem_id": "EXTRA_039",
  "title": "己亥杂诗",
  "author": "龚自珍",
  "dynasty": "清",
  "grade": "小学/初中",
  "text_type": "绝句",
  "themes": [
    "家国",
    "人才"
  ],
  "imagery": [
    "风雷",
    "天公"
  ],
  "rhetoric": [
    "比喻",
    "拟人",
    "象征"
  ],
  "lines": [
    {
      "line_id": "EXTRA_039_L1",
      "content": "九州生气恃风雷",
      "imagery": [
        "风雷",
        "天公"
      ],
      "emotion": [
        "家国",
        "人才"
      ],
      "translation": "要使中国重新充满生机活力，必须依靠像暴风雷霆一样的巨大变革。",
      "translation_keywords": [
        "九州",
        "生气",
        "恃",
        "风雷"
      ],
      "explanation": "“九州”指中国，“生气”指生机活力，“恃”是依靠的意思。诗人用“风雷”比喻巨大的社会变革，表达只有通过变革才能让国家焕发生机的思想。"
    },
    {
      "line_id": "EXTRA_039_L2",
      "content": "万马齐喑究可哀",
      "imagery": [
        "风雷",
        "天公"
      ],
      "emotion": [
        "家国",
        "人才"
      ],
      "translation": "现在全国像万马齐喑一样死气沉沉，终究是令人悲哀的。",
      "translation_keywords": [
        "万马",
        "齐喑",
        "究",
        "可哀"
      ],
      "explanation": "“万马齐喑”比喻人们都不敢说话、社会毫无生气，“究可哀”表达诗人对这种沉闷局面的痛心和悲哀。"
    },
    {
      "line_id": "EXTRA_039_L3",
      "content": "我劝天公重抖擞",
      "imagery": [
        "风雷",
        "天公"
      ],
      "emotion": [
        "家国",
        "人才"
      ],
      "translation": "我奉劝老天爷重新振作精神。",
      "translation_keywords": [
        "劝",
        "天公",
        "重",
        "抖擞"
      ],
      "explanation": "“天公”表面指老天爷，实际暗指当时的皇帝或统治者。“重抖擞”是重新振作的意思，诗人用拟人手法，表达希望统治者能奋发有为。"
    },
    {
      "line_id": "EXTRA_039_L4",
      "content": "不拘一格降人才",
      "imagery": [
        "风雷",
        "天公"
      ],
      "emotion": [
        "家国",
        "人才"
      ],
      "translation": "不要拘泥于一种规格，把各种有用的人才都降生到人间吧。",
      "translation_keywords": [
        "不拘",
        "一格",
        "降",
        "人才"
      ],
      "explanation": "“不拘一格”指不局限于一种方式或标准，“降人才”是希望上天赐予国家各种优秀人才。诗人呼吁打破旧框框，大胆选拔和使用人才。"
    }
  ]
}
