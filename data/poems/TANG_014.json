  "lines": [
    {
      "line_id": "TANG_014_L1",
      "content": "远上寒山石径斜",
      "imagery": [
        "寒山",
        "石径"
      ],
      "emotion": [
        "登高",
        "深远"
      ],
      "translation": "蜿蜒的石径通向远方那清冷的群山。",
      "translation_keywords": [
        "远上",
        "寒山",
        "石径",
        "斜"
      ],
      "explanation": "诗人以开阔的视角描绘了登山的场景，一条倾斜、曲折的石径通往遥远的寒山，给人一种幽深、清冷而又充满探险意味的感受。"
    },
    {
      "line_id": "TANG_014_L2",
      "content": "白云生处有人家",
      "imagery": [
        "白云",
        "人家"
      ],
      "emotion": [
        "宁静",
        "惊喜",
        "悠然"
      ],
      "translation": "在白云缭绕的深山高处，竟然还隐约有几户人家居住。",
      "translation_keywords": [
        "白云生处",
        "人家"
      ],
      "explanation": "画面从广阔的山景拉近到具体的细节，在飘渺的白云深处，隐现着人间烟火，营造出一种宁静、和谐，如同世外桃源般的意境，令人感到亲切和惊喜。"
    },
    {
      "line_id": "TANG_014_L3",
      "content": "停车坐爱枫林晚",
      "imagery": [
        "枫林",
        "晚"
      ],
      "emotion": [
        "喜爱",
        "沉醉",
        "驻足"
      ],
      "translation": "我停下车来，正是因为喜爱这傍晚时分美丽的枫林景色。",
      "translation_keywords": [
        "停车",
        "坐爱",
        "枫林",
        "晚"
      ],
      "explanation": "这句是诗人情感的转折点，一个“坐爱”直接点明了诗人对眼前景色的由衷喜爱，因美景而情不自禁地驻足，流露出深深的陶醉与欣赏之情。"
    },
    {
      "line_id": "TANG_014_L4",
      "content": "霜叶红于二月花",
      "imagery": [
        "霜叶",
        "二月花"
      ],
      "emotion": [
        "赞美",
        "惊叹",
        "豁达"
      ],
      "translation": "经过霜打的枫叶，比早春二月的鲜花还要鲜艳火红。",
      "translation_keywords": [
        "霜叶",
        "红于",
        "二月花"
      ],
      "explanation": "全诗的点睛之笔。诗人运用夸张和对比的手法，极力赞美了晚秋枫叶的绚烂色彩，打破了传统秋天萧瑟悲凉的意象，表达了对秋色毫不逊于春色的由衷赞美和一种积极乐观、豁达开朗的情怀。"
    }
  ]
}