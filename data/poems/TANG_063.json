  "lines": [
    {
      "line_id": "TANG_063_L1",
      "content": "寒雨连江夜入吴",
      "imagery": [
        "寒雨",
        "江"
      ],
      "emotion": [
        "凄冷",
        "孤寂",
        "离愁"
      ],
      "translation": "蒙蒙细雨笼罩着吴地的长江，寒意袭人，绵延不绝，雨夜中我来到了吴地。",
      "translation_keywords": [
        "寒雨",
        "连江",
        "夜入吴"
      ],
      "explanation": "交代了送别的时间和地点背景，阴冷湿重的“寒雨”渲染了离别的气氛，烘托了作者与友人惜别时的感伤心情。"
    },
    {
      "line_id": "TANG_063_L2",
      "content": "平明送客楚山孤",
      "imagery": [
        "楚山"
      ],
      "emotion": [
        "孤寂",
        "愁绪",
        "惆怅"
      ],
      "translation": "天刚亮，在芙蓉楼送别你，望着你远去的背影，只有楚山显得那么孤寂。",
      "translation_keywords": [
        "平明",
        "送客",
        "楚山孤"
      ],
      "explanation": "进一步点明送别场景，清晨送别，远山孤寂，景与情融为一体，寄托了诗人对友人的不舍和自己的寂寥。"
    },
    {
      "line_id": "TANG_063_L3",
      "content": "洛阳亲友如相问",
      "imagery": [],
      "emotion": [
        "叮嘱",
        "关切",
        "真挚"
      ],
      "translation": "如果洛阳的亲戚朋友问起我的近况。",
      "translation_keywords": [
        "洛阳",
        "亲友",
        "相问"
      ],
      "explanation": "承上启下，转入诗人心声的表达，通过嘱托友人代为转达，表现了对亲友的思念和对自身品格的自白。"
    },
    {
      "line_id": "TANG_063_L4",
      "content": "一片冰心在玉壶",
      "imagery": [
        "冰心",
        "玉壶"
      ],
      "emotion": [
        "高洁",
        "坦荡",
        "纯洁"
      ],
      "translation": "就说我依然像冰那样晶莹、像玉那样洁白无瑕。",
      "translation_keywords": [
        "冰心",
        "玉壶"
      ],
      "explanation": "以“冰心在玉壶”的比喻，表达了诗人高洁的品格、坦荡的胸襟和对友人的真诚，是千古名句，也是诗人品格的写照。"
    }
  ]
}