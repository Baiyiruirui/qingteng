  "lines": [
    {
      "line_id": "TANG_060_L1",
      "content": "朱雀桥边野草花，乌衣巷口夕阳斜。",
      "imagery": [
        "朱雀桥",
        "野草花",
        "乌衣巷",
        "夕阳"
      ],
      "emotion": [
        "凄凉",
        "衰败",
        "沧桑"
      ],
      "translation": "朱雀桥边长满了野草野花，乌衣巷口被西斜的夕阳笼罩。",
      "translation_keywords": [
        "朱雀桥",
        "野草花",
        "乌衣巷",
        "夕阳斜"
      ],
      "explanation": "开篇描绘了南京朱雀桥和乌衣巷的萧条景象。昔日繁华的地点，如今杂草丛生，夕阳西下，更添几分衰败和凄凉，为全诗奠定了感伤的基调。"
    },
    {
      "line_id": "TANG_060_L2",
      "content": "旧时王谢堂前燕，飞入寻常百姓家。",
      "imagery": [
        "燕子",
        "王谢堂前",
        "百姓家"
      ],
      "emotion": [
        "物是人非",
        "历史变迁",
        "沧海桑田"
      ],
      "translation": "过去在王导谢安府邸前筑巢的燕子，如今已飞进了普通老百姓的家中。",
      "translation_keywords": [
        "旧时",
        "王谢",
        "堂前燕",
        "飞入",
        "寻常百姓家"
      ],
      "explanation": "此句是千古名句，以燕子这一不变的意象，反衬出王谢两大家族已衰败，连旧时王谢贵族门前的燕子也飞入了普通百姓家中。通过生动形象的比喻，揭示了历史的变迁和世事无常的深刻哲理，充满了对盛衰兴亡的感慨。"
    }
  ]
