  "lines": [
    {
      "line_id": "EXTRA_022_L1",
      "content": "远上寒山石径斜",
      "imagery": [
        "寒山",
        "白云",
        "枫林"
      ],
      "emotion": [
        "秋景",
        "山水"
      ],
      "translation": "在深秋时节，沿着一条弯弯曲曲的小路，向远处的山上走去。",
      "translation_keywords": [
        "深秋",
        "弯弯曲曲",
        "小路",
        "远处",
        "山上"
      ],
      "explanation": "这句写诗人沿着一条斜斜的小路，向远处的高山上走去。“远上”写出山路很长，“寒山”点明是深秋时节，山色清冷。“石径斜”描绘出小路弯弯曲曲的样子，让人感觉山路崎岖难行。"
    },
    {
      "line_id": "EXTRA_022_L2",
      "content": "白云生处有人家",
      "imagery": [
        "寒山",
        "白云",
        "枫林"
      ],
      "emotion": [
        "秋景",
        "山水"
      ],
      "translation": "在白云升腾缭绕的地方，隐隐约约可以看到几户人家。",
      "translation_keywords": [
        "白云",
        "升腾",
        "缭绕",
        "隐隐约约",
        "人家"
      ],
      "explanation": "这句写诗人抬头远望，看到白云缭绕的山间，隐约有人家居住。“白云生处”写出山很高，云雾缭绕，像仙境一样。“有人家”给清冷的山景增添了生活气息，让人感到温暖。"
    },
    {
      "line_id": "EXTRA_022_L3",
      "content": "停车坐爱枫林晚",
      "imagery": [
        "寒山",
        "白云",
        "枫林"
      ],
      "emotion": [
        "秋景",
        "山水"
      ],
      "translation": "我停下马车，是因为喜爱这傍晚时分的枫林景色。",
      "translation_keywords": [
        "停下",
        "马车",
        "喜爱",
        "傍晚",
        "枫林"
      ],
      "explanation": "这句写诗人因为太喜欢傍晚的枫林，所以停下车来欣赏。“停车”说明诗人被美景吸引，忍不住停下脚步。“坐”在这里是“因为”的意思。“爱”直接表达出诗人对枫林的喜爱之情。“晚”字点出时间是傍晚，夕阳下的枫林更加美丽。"
    },
    {
      "line_id": "EXTRA_022_L4",
      "content": "霜叶红于二月花",
      "imagery": [
        "寒山",
        "白云",
        "枫林"
      ],
      "emotion": [
        "秋景",
        "山水"
      ],
      "translation": "经霜打过的枫叶，比二月春天的花朵还要红艳。",
      "translation_keywords": [
        "经霜",
        "枫叶",
        "比",
        "二月",
        "花朵",
        "红艳"
      ],
      "explanation": "这句是千古名句，诗人用对比和比喻的手法，写出枫叶的红艳。“霜叶”指经过秋霜的枫叶，“红于”是“比……还红”的意思。诗人把枫叶和春天的红花相比，突出枫叶在秋天独有的、比春花更浓烈的红色，表达了对秋景的赞美之情。"
    }
  ]
}
