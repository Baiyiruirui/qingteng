  "lines": [
    {
      "line_id": "EXTRA_040_L1",
      "content": "草长莺飞二月天",
      "imagery": [
        "杨柳",
        "儿童",
        "纸鸢"
      ],
      "emotion": [
        "春景",
        "童趣"
      ],
      "translation": "早春二月，青草生长，黄莺在天空中飞翔。",
      "translation_keywords": [
        "草",
        "生长",
        "黄莺",
        "飞翔",
        "二月",
        "春天"
      ],
      "explanation": "这句诗描写了早春二月的生机勃勃。诗人用“草长”和“莺飞”两个动态画面，展现了春天万物复苏的景象，让人感受到大自然的活力。"
    },
    {
      "line_id": "EXTRA_040_L2",
      "content": "拂堤杨柳醉春烟",
      "imagery": [
        "杨柳",
        "儿童",
        "纸鸢"
      ],
      "emotion": [
        "春景",
        "童趣"
      ],
      "translation": "河堤上的杨柳枝条轻轻拂过堤岸，仿佛陶醉在春天的烟雾里。",
      "translation_keywords": [
        "杨柳",
        "拂堤",
        "春烟",
        "陶醉",
        "轻柔",
        "烟雾"
      ],
      "explanation": "这句诗运用了拟人的手法，写杨柳的枝条在春烟中轻轻摆动，好像喝醉了一样。“醉”字生动地写出了杨柳在春日烟雾中的柔美姿态，也表达了诗人对春天景色的沉醉。"
    },
    {
      "line_id": "EXTRA_040_L3",
      "content": "儿童散学归来早",
      "imagery": [
        "杨柳",
        "儿童",
        "纸鸢"
      ],
      "emotion": [
        "春景",
        "童趣"
      ],
      "translation": "孩子们放学后早早地回到了家。",
      "translation_keywords": [
        "儿童",
        "放学",
        "归来",
        "早",
        "回家",
        "傍晚"
      ],
      "explanation": "这句诗写孩子们放学后的情景。“归来早”三个字，既写出了孩子们放学时间早，也暗示了他们急着回家玩耍的快乐心情，为下一句放风筝做了铺垫。"
    },
    {
      "line_id": "EXTRA_040_L4",
      "content": "忙趁东风放纸鸢",
      "imagery": [
        "杨柳",
        "儿童",
        "纸鸢"
      ],
      "emotion": [
        "春景",
        "童趣"
      ],
      "translation": "他们急忙趁着东风放起了风筝。",
      "translation_keywords": [
        "忙",
        "趁",
        "东风",
        "放",
        "纸鸢",
        "风筝"
      ],
      "explanation": "这句诗是全诗的高潮，写孩子们趁着春风放风筝的欢乐场景。“忙趁”二字生动地写出了孩子们迫不及待的心情，而“东风”和“纸鸢”则点明了放风筝的时节和活动，充满了童真童趣。"
    }
  ]
