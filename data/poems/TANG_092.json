{
  "poem_id": "TANG_092",
  "title": "独坐敬亭山",
  "author": "李白",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "五言绝句",
  "themes": [
    "孤独",
    "隐逸",
    "人与自然和谐",
    "哲思"
  ],
  "imagery": [
    "鸟",
    "云",
    "敬亭山"
  ],
  "rhetoric": [
    "拟人",
    "反衬",
    "对比",
    "白描"
  ],
  "lines": [
    {
      "line_id": "TANG_092_L1",
      "content": "众鸟高飞尽",
      "imagery": [
        "鸟"
      ],
      "emotion": [
        "寂寥",
        "空旷"
      ],
      "translation": "成群的鸟儿都高高地飞走了，消失不见。",
      "translation_keywords": [
        "鸟",
        "高飞",
        "消失"
      ],
      "explanation": "诗人抬头看见天空中成群的鸟儿都飞向远处，最后消失在视线中，营造出一种空旷寂寥的氛围。"
    },
    {
      "line_id": "TANG_092_L2",
      "content": "孤云独去闲",
      "imagery": [
        "云"
      ],
      "emotion": [
        "孤独",
        "悠闲"
      ],
      "translation": "天空中仅剩的一片孤云也独自飘然而去，显得悠闲自在。",
      "translation_keywords": [
        "孤云",
        "独自",
        "悠闲"
      ],
      "explanation": "接着，诗人又看到一朵孤独的云彩也慢慢飘走，进一步加深了画面的宁静和诗人的孤独感，但“闲”字又带出几分超脱。"
    },
    {
      "line_id": "TANG_092_L3",
      "content": "相看两不厌",
      "imagery": [],
      "emotion": [
        "亲近",
        "默契",
        "共鸣"
      ],
      "translation": "（我与敬亭山）彼此相对而视，永远都看不够。",
      "translation_keywords": [
        "相看",
        "不厌",
        "彼此"
      ],
      "explanation": "在鸟飞云散的背景下，诗人与眼前的敬亭山默默相对，似乎达到了心意相通的境界，彼此都不会感到厌倦。"
    },
    {
      "line_id": "TANG_092_L4",
      "content": "只有敬亭山",
      "imagery": [
        "敬亭山"
      ],
      "emotion": [
        "知己",
        "陪伴",
        "深情"
      ],
      "translation": "在这世间，仿佛只剩下敬亭山与我相伴。",
      "translation_keywords": [
        "只有",
        "敬亭山",
        "相伴"
      ],
      "explanation": "诗人将敬亭山视为唯一的知己，表达了自己与大自然融为一体、物我两忘的深情与超然。"
    }
  ]
}