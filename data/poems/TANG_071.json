  "lines": [
    {
      "line_id": "TANG_071_L1",
      "content": "银烛秋光冷画屏，",
      "imagery": [
        "银烛",
        "秋光",
        "画屏"
      ],
      "emotion": [
        "清冷",
        "寂寥"
      ],
      "translation": "银色的烛光在秋夜里显得格外清冷，映照着彩绘的屏风。",
      "translation_keywords": [
        "银烛",
        "秋光",
        "冷画屏"
      ],
      "explanation": "秋夜里，银色的烛光散发出清冷的光芒，映照在绘有图案的屏风上，更添了几分寂寞。"
    },
    {
      "line_id": "TANG_071_L2",
      "content": "轻罗小扇扑流萤。",
      "imagery": [
        "轻罗小扇",
        "流萤"
      ],
      "emotion": [
        "无聊",
        "排遣"
      ],
      "translation": "宫女手持轻巧的罗扇，轻轻扑打着飞舞的流萤。",
      "translation_keywords": [
        "轻罗小扇",
        "扑流萤"
      ],
      "explanation": "寂寞的宫女，手持轻薄的丝绸小扇，漫无目的地扑打着飞舞的萤火虫，以此排遣内心的无聊。"
    },
    {
      "line_id": "TANG_071_L3",
      "content": "天阶夜色凉如水，",
      "imagery": [
        "天阶",
        "夜色",
        "露水"
      ],
      "emotion": [
        "清凉",
        "寒意"
      ],
      "translation": "宫殿的台阶上，夜色清凉如同水一般。",
      "translation_keywords": [
        "天阶",
        "夜色",
        "凉如水"
      ],
      "explanation": "宫殿的台阶上，秋夜的凉意像水一样浸润着，让人感受到深夜的清冷。"
    },
    {
      "line_id": "TANG_071_L4",
      "content": "坐看牵牛织女星。",
      "imagery": [
        "牵牛星",
        "织女星"
      ],
      "emotion": [
        "孤独",
        "思念",
        "羡慕"
      ],
      "translation": "宫女独自坐着，仰望夜空中遥远的牵牛星和织女星。",
      "translation_keywords": [
        "坐看",
        "牵牛织女星"
      ],
      "explanation": "宫女孤单地坐在台阶上，抬头望着夜空中遥远的牵牛星和织女星，想象着他们一年一度的相会，反衬自己的孤独和对自由爱情的向往。"
    }
  ]
}