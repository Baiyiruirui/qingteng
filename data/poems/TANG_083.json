  "lines": [
    {
      "line_id": "TANG_083_L1",
      "content": "落日在楼西，",
      "imagery": [
        "落日",
        "楼"
      ],
      "emotion": [
        "感伤",
        "孤独"
      ],
      "translation": "夕阳西下，落在楼房的西边，",
      "translation_keywords": [
        {
          "word": "落日",
          "meaning": "夕阳，日落。常带有一丝伤感。"
        },
        {
          "word": "楼西",
          "meaning": "楼房的西侧。"
        }
      ],
      "explanation": "诗人以傍晚的落日景象开篇，营造出一种黄昏时分的寂寥感。落日余晖洒在楼宇西侧，暗示时间的流逝，也烘托出诗人内心的孤独。"
    },
    {
      "line_id": "TANG_083_L2",
      "content": "浮云在天际。",
      "imagery": [
        "浮云",
        "天际"
      ],
      "emotion": [
        "飘渺",
        "无常"
      ],
      "translation": "天空中的浮云飘荡在遥远的天边。",
      "translation_keywords": [
        {
          "word": "浮云",
          "meaning": "飘动的云朵。常用来比喻变幻无常的事物或漂泊不定的人。"
        },
        {
          "word": "天际",
          "meaning": "天空的尽头，极远的地方。"
        }
      ],
      "explanation": "天边的浮云飘忽不定，与诗人漂泊不定的心境相呼应。遥远的天际也暗示着故人的遥不可及，增添了离愁别绪。"
    },
    {
      "line_id": "TANG_083_L3",
      "content": "故人不可见，",
      "imagery": [
        "故人"
      ],
      "emotion": [
        "失落",
        "惆怅"
      ],
      "translation": "想要见到的老朋友却无法见到，",
      "translation_keywords": [
        {
          "word": "故人",
          "meaning": "老朋友，旧相识。"
        },
        {
          "word": "不可见",
          "meaning": "无法见到。"
        }
      ],
      "explanation": "这句直接点明了诗人的思念对象和内心的遗憾。眼前的景色虽美，却无法排解见不到故人的惆怅。"
    },
    {
      "line_id": "TANG_083_L4",
      "content": "相思长复离。",
      "imagery": [],
      "emotion": [
        "无奈",
        "悲伤"
      ],
      "translation": "思念的痛苦总是与离别的悲伤相伴。",
      "translation_keywords": [
        {
          "word": "相思",
          "meaning": "相互思念。"
        },
        {
          "word": "长复离",
          "meaning": "长久地与离别相伴。指思念之情总是因为离别而产生，并且绵延不绝。"
        }
      ],
      "explanation": "诗人感叹思念与离别是人生中循环往复的痛苦。每次思念都是因为离别，离别又会带来新的思念，表达了诗人对这种无尽思念和分离的无奈与悲伤。"
    }
  ]
}