{
  "poem_id": "TANG_040",
  "title": "春望",
  "author": "杜甫",
  "dynasty": "唐",
  "grade": "中学",
  "text_type": "律诗",
  "themes": [
    "家国情怀",
    "忧国忧民",
    "思亲怀乡",
    "战乱的痛苦",
    "时序变迁"
  ],
  "imagery": [
    "国",
    "山河",
    "城春",
    "草木",
    "花",
    "鸟",
    "烽火",
    "家书",
    "白头",
    "短发"
  ],
  "rhetoric": [
    "对仗",
    "拟人",
    "借景抒情",
    "反衬",
    "细节描写"
  ],
  "lines": [
    {
      "line_id": "TANG_040_L1",
      "content": "国破山河在，",
      "imagery": [
        "国",
        "山河"
      ],
      "emotion": [
        "悲痛",
        "苍凉",
        "沉重"
      ],
      "translation": "国家破碎，山河依然存在，",
      "translation_keywords": [
        "国破",
        "山河在"
      ],
      "explanation": "以雄浑悲壮的笔触开篇，描绘了安史之乱后长安的景象：国都沦陷，但自然山河依旧，强烈的对比震撼人心，表达了诗人深沉的忧国之情。"
    },
    {
      "line_id": "TANG_040_L2",
      "content": "城春草木深。",
      "imagery": [
        "城春",
        "草木"
      ],
      "emotion": [
        "荒凉",
        "萧条",
        "春意中的悲凉"
      ],
      "translation": "长安城春天到来，草木却丛生茂密，一片荒凉。",
      "translation_keywords": [
        "城春",
        "草木深"
      ],
      "explanation": "“城春”本应是繁华热闹，但“草木深”却暗示人烟稀少，一片衰败景象，用反常的春景衬托战乱带来的萧条和破坏。"
    },
    {
      "line_id": "TANG_040_L3",
      "content": "感时花溅泪，",
      "imagery": [
        "花"
      ],
      "emotion": [
        "悲伤",
        "痛苦"
      ],
      "translation": "感伤时局，连花朵也仿佛为之落泪，",
      "translation_keywords": [
        "感时",
        "花溅泪"
      ],
      "explanation": "诗人将自己的悲伤投射到自然景物上，以花“溅泪”来表达内心对国破家亡的极度痛苦和感伤，运用了拟人手法。"
    },
    {
      "line_id": "TANG_040_L4",
      "content": "恨别鸟惊心。",
      "imagery": [
        "鸟"
      ],
      "emotion": [
        "惊恐",
        "不安",
        "离愁"
      ],
      "translation": "怨恨离别，连鸟儿也因惊恐而心绪不宁。",
      "translation_keywords": [
        "恨别",
        "鸟惊心"
      ],
      "explanation": "同上句，将思念亲人的离愁别恨赋予鸟儿，鸟儿因惊恐而鸣叫，更衬托出诗人内心因战乱而骨肉分离的痛苦。"
    },
    {
      "line_id": "TANG_040_L5",
      "content": "烽火连三月，",
      "imagery": [
        "烽火"
      ],
      "emotion": [
        "战乱",
        "持久",
        "担忧"
      ],
      "translation": "战火连绵不绝已经持续了三个月，",
      "translation_keywords": [
        "烽火",
        "连三月"
      ],
      "explanation": "直接点出战乱的长期性，揭示了诗人被困长安的处境和对战事旷日持久的担忧。"
    },
    {
      "line_id": "TANG_040_L6",
      "content": "家书抵万金。",
      "imagery": [
        "家书"
      ],
      "emotion": [
        "思念",
        "珍贵",
        "渴望"
      ],
      "translation": "一封家书抵得上万两黄金般珍贵。",
      "translation_keywords": [
        "家书",
        "万金"
      ],
      "explanation": "极言战乱中与家人音信隔绝，一封家书的到来是何等珍贵和令人期盼，表现了诗人对家人的深切思念。"
    },
    {
      "line_id": "TANG_040_L7",
      "content": "白头搔更短，",
      "imagery": [
        "白头",
        "短发"
      ],
      "emotion": [
        "愁苦",
        "衰老",
        "焦躁"
      ],
      "translation": "忧愁使我原本稀疏的白发越搔越短，",
      "translation_keywords": [
        "白头",
        "搔更短"
      ],
      "explanation": "诗人因国事家事而愁白了头，却越搔越短，形象地刻画了诗人因愁苦而日益衰老、憔悴的形象，以及内心的焦躁不安。"
    },
    {
      "line_id": "TANG_040_L8",
      "content": "浑欲不胜簪。",
      "imagery": [
        "簪"
      ],
      "emotion": [
        "无奈",
        "疲惫"
      ],
      "translation": "简直连簪子也插不住了。",
      "translation_keywords": [
        "浑欲",
        "不胜簪"
      ],
      "explanation": "头发稀疏到无法束起插簪，进一步夸张地表达了诗人极度的忧愁和衰老，是诗人内心痛苦的外化，结尾沉重而充满无奈。"
    }
  ]
}