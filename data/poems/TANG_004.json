  "lines": [
    {
      "line_id": "TANG_004_L1",
      "content": "两个黄鹂鸣翠柳",
      "imagery": [
        "黄鹂",
        "翠柳"
      ],
      "emotion": [
        "欢快",
        "生机",
        "愉悦"
      ],
      "translation": "两只黄莺在翠绿的柳树间婉转鸣叫。",
      "translation_keywords": [
        "两只",
        "黄鹂",
        "鸣叫",
        "翠绿",
        "柳树"
      ],
      "explanation": "开篇点出春景，色彩鲜明（黄、翠），声音清脆（鸣），营造出一种生机勃勃、充满活力的春日画面，令人心旷神怡。"
    },
    {
      "line_id": "TANG_004_L2",
      "content": "一行白鹭上青天",
      "imagery": [
        "白鹭",
        "青天"
      ],
      "emotion": [
        "辽阔",
        "宁静",
        "自由"
      ],
      "translation": "一行白鹭展翅高飞，直冲向碧蓝的天空。",
      "translation_keywords": [
        "一行",
        "白鹭",
        "飞上",
        "青天"
      ],
      "explanation": "这句与上一句构成工整的对仗，色彩由地面翠绿转向天空湛蓝（白、青），动态感强，视野由近处的树木延伸至远方的高空，描绘了一幅开阔而宁静的画卷，动静结合。"
    },
    {
      "line_id": "TANG_004_L3",
      "content": "窗含西岭千秋雪",
      "imagery": [
        "窗",
        "西岭",
        "千秋雪"
      ],
      "emotion": [
        "壮阔",
        "深远",
        "永恒"
      ],
      "translation": "从窗户望去，西边山岭上千年不化的积雪尽收眼底。",
      "translation_keywords": [
        "窗户",
        "包含",
        "西岭",
        "千年",
        "积雪"
      ],
      "explanation": "诗人将视角转向室内，通过“窗含”表现一种由近及远的广阔感。西岭终年不化的积雪，给人以雄伟壮丽、亘古不变的永恒之感，将诗的意境推向更深远的历史和空间。"
    },
    {
      "line_id": "TANG_004_L4",
      "content": "门泊东吴万里船",
      "imagery": [
        "门",
        "东吴",
        "万里船"
      ],
      "emotion": [
        "开阔",
        "远方",
        "思乡/壮志"
      ],
      "translation": "门前的江边停泊着来自东吴、能够航行万里的船只。",
      "translation_keywords": [
        "门前",
        "停泊",
        "东吴",
        "万里",
        "船"
      ],
      "explanation": "这句与第三句形成对仗，将视野从高远的雪山拉回到门前的江面。来自远方“东吴”的“万里船”，不仅拓展了空间感，更暗示了诗人对外面世界的关注，以及一丝对远游或归乡的复杂情感，使全诗的意境更加开阔，富有想象力。"
    }
  ]
