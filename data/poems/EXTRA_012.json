{
  "poem_id": "EXTRA_012",
  "title": "九月九日忆山东兄弟",
  "author": "王维",
  "dynasty": "唐",
  "grade": "小学",
  "text_type": "绝句",
  "themes": [
    "思乡",
    "节日"
  ],
  "imagery": [
    "重阳",
    "茱萸",
    "登高"
  ],
  "rhetoric": [
    "直抒胸臆",
    "想象",
    "对比"
  ],
  "lines": [
    {
      "line_id": "EXTRA_012_L1",
      "content": "独在异乡为异客",
      "imagery": [
        "重阳",
        "茱萸",
        "登高"
      ],
      "emotion": [
        "思乡",
        "节日"
      ],
      "translation": "独自一个人在外地做客，成了异乡的客人。",
      "translation_keywords": [
        "独自",
        "异乡",
        "做客"
      ],
      "explanation": "开篇直接点明诗人独自漂泊在外的处境，“独”和两个“异”字，反复强调孤独和陌生感，为全诗奠定思乡的基调。"
    },
    {
      "line_id": "EXTRA_012_L2",
      "content": "每逢佳节倍思亲",
      "imagery": [
        "重阳",
        "茱萸",
        "登高"
      ],
      "emotion": [
        "思乡",
        "节日"
      ],
      "translation": "每当遇到美好的节日，就更加思念远方的亲人。",
      "translation_keywords": [
        "每逢",
        "佳节",
        "加倍",
        "思念"
      ],
      "explanation": "“每逢”说明不是一次两次，而是每次佳节都如此；“倍”字写出思念之深，是千古名句，道出了所有游子的心声。"
    },
    {
      "line_id": "EXTRA_012_L3",
      "content": "遥知兄弟登高处",
      "imagery": [
        "重阳",
        "茱萸",
        "登高"
      ],
      "emotion": [
        "思乡",
        "节日"
      ],
      "translation": "在遥远的地方，我想象兄弟们今天登上了高处。",
      "translation_keywords": [
        "遥想",
        "兄弟",
        "登高"
      ],
      "explanation": "诗人从自己思念亲人，转而想象亲人在家乡登高过节的情景，运用“对面落笔”的手法，使思念之情更加深沉动人。"
    },
    {
      "line_id": "EXTRA_012_L4",
      "content": "遍插茱萸少一人",
      "imagery": [
        "重阳",
        "茱萸",
        "登高"
      ],
      "emotion": [
        "思乡",
        "节日"
      ],
      "translation": "大家身上都插满了茱萸，却发现少了我一个人。",
      "translation_keywords": [
        "插茱萸",
        "缺少",
        "一人"
      ],
      "explanation": "“少一人”点出诗人缺席的遗憾，以亲人的遗憾反衬自己的孤独，情感含蓄而强烈，令人感同身受。"
    }
  ]
}
