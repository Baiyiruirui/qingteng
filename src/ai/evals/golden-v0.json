    {
      "id": "sub-jys-word-partial",
      "poemId": "TANG_001",
      "pointId": "p2",
      "userAnswer": "疑是好像的意思，写诗人把月光看成了霜，说明月光很白很冷。",
      "expectedCompletionMin": 0.45,
      "expectedCompletionMax": 0.85,
      "rationale": "答到字义、错觉和清冷月光，未充分联系思乡。"
    },
    {
      "id": "sub-jys-translate-strong",
      "poemId": "TANG_001",
      "pointId": "p5",
      "userAnswer": "我抬头望着明亮的月亮，又低下头思念远方的故乡。",
      "expectedCompletionMin": 0.65,
      "expectedCompletionMax": 1,
      "rationale": "翻译通顺，两个动作和思乡情感都到位。"
    },
    {
      "id": "sub-jyj-method-strong",
      "poemId": "TANG_023",
      "pointId": "p3",
      "userAnswer": "这里用了从对方着笔的虚写，想象兄弟重阳登高插茱萸时发现少了自己，从而反衬自己思亲，表达得很含蓄动人。",
      "expectedCompletionMin": 0.75,
      "expectedCompletionMax": 1,
      "rationale": "完整命中手法、想象情景、思亲效果和表达特点。"
    },
    {
      "id": "sub-jyj-emotion-partial",
      "poemId": "TANG_023",
      "pointId": "p5",
      "userAnswer": "写他重阳节很想念家人。",
      "expectedCompletionMin": 0.35,
      "expectedCompletionMax": 0.75,
      "rationale": "答到佳节思亲和亲人，缺少异乡孤寂与不能团聚遗憾。"
    },
    {
      "id": "sub-dg-word-strong",
      "poemId": "TANG_042",
      "pointId": "p4",
      "userAnswer": "常写出诗人长期漂泊在外，独写出他年老多病又独自登台，两个字叠加加深了悲凉孤苦之情。",
      "expectedCompletionMin": 0.75,
      "expectedCompletionMax": 1,
      "rationale": "完整命中常、独和情感叠加效果。"
    },
    {
      "id": "sub-dg-imagery-partial",
      "poemId": "TANG_042",
      "pointId": "p6",
      "userAnswer": "落木和长江营造出苍凉悲壮的意境，也让人想到时间流逝。",
      "expectedCompletionMin": 0.35,
      "expectedCompletionMax": 0.8,
      "rationale": "答到整体意境和时光流逝，但对两个意象的分别分析不足。"
    },
    {
      "id": "sub-dg-translate-weak",
      "poemId": "TANG_042",
      "pointId": "p7",
