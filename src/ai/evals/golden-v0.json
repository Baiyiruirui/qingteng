      "expectedIncludes": ["近期的情绪状态", "《登高》里的孤独"]
    },
    {
      "id": "mem-confusion-surfaces",
      "memories": [{ "content": "这位学生读不懂诗里的意象。", "source": "confusion", "similarity": 0.71 }],
