      "expectedIncludes": ["喜欢杜甫", "对漂泊主题有共鸣", "推荐诗歌时"]
    },
    {
      "id": "mem-preference-hard-constraint-copy",
      "memories": [{ "content": "这位学生不喜欢单纯背诵。", "source": "preference", "similarity": 0.83 }],
      "expectedIncludes": ["硬约束", "不喜欢单纯背诵"]
    },
    {
      "id": "mem-strict-rule-abstract-not-event",
