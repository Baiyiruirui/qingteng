      "expectedCompletionMin": 0.15,
      "expectedCompletionMax": 0.55,
      "rationale": "只触及艰难和停酒，缺少霜鬓、潦倒等关键翻译点。"
    },
    {
      "id": "sub-dg-method-strong",
      "poemId": "TANG_042",
      "pointId": "p3",
      "userAnswer": "这一联用了对偶，萧萧和滚滚是叠字，写出落叶纷飞、江水奔流的壮阔景象，也寄寓时光流逝、人生短暂的感慨。",
      "expectedCompletionMin": 0.75,
      "expectedCompletionMax": 1,
      "rationale": "完整命中对偶、叠字景象和情感寄托。"
    }
