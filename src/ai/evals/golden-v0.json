      "poemId": "TANG_001",
      "pointId": "p4",
      "userAnswer": "这首诗表达了游子客居他乡时的思乡之情，也写出了他借明月想念故乡和亲人的心情。",
      "expectedCompletionMin": 0.7,
      "expectedCompletionMax": 1,
      "rationale": "完整命中思乡、亲人、客居他乡等核心点。"
    },
    {
      "id": "sub-jys-emotion-partial",
      "poemId": "TANG_001",
      "pointId": "p4",
      "userAnswer": "表达了诗人想家的感情。",
      "expectedCompletionMin": 0.2,
      "expectedCompletionMax": 0.6,
      "rationale": "只答到思乡核心，缺少亲人、游子身份和诗句结合。"
